<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace></RootNamespace>
    <!-- CA1873: ILogger has no lazy-eval overload; all operational trading logs are always-enabled.
         Adding IsEnabled guards around every call would add pure boilerplate with no practical benefit. -->
    <NoWarn>$(NoWarn);CA1873</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\TopStepTrader.Core\TopStepTrader.Core.vbproj" />
    <ProjectReference Include="..\TopStepTrader.Data\TopStepTrader.Data.vbproj" />
    <ProjectReference Include="..\TopStepTrader.API\TopStepTrader.API.vbproj" />
    <ProjectReference Include="..\TopStepTrader.ML\TopStepTrader.ML.vbproj" />
  </ItemGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleToAttribute">
      <_Parameter1>TopStepTrader.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="9.*" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="9.*" />
    <PackageReference Include="Microsoft.Extensions.Logging" Version="9.*" />
    <PackageReference Include="Microsoft.Extensions.Options" Version="9.*" />
  </ItemGroup>

</Project>
