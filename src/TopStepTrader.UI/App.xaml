<Application x:Class="TopStepTrader.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:TopStepTrader.UI.Infrastructure"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Colors.xaml"/>
                <ResourceDictionary Source="Styles/Typography.xaml"/>
                <ResourceDictionary Source="Styles/Buttons.xaml"/>
                <ResourceDictionary Source="Styles/DataGrids.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Value converters (declared inline so the types resolve from this assembly) -->
            <converters:BrushKeyConverter              x:Key="BrushKeyConverter"/>
            <converters:BoolToVisibilityConverter      x:Key="BoolToVisibilityConverter"/>
            <converters:BoolToBorderThicknessConverter x:Key="BoolToBorderThicknessConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
