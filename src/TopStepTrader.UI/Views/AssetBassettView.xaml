<UserControl x:Class="TopStepTrader.UI.Views.AssetBassettView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <!--
        Layout: scrollable settings + strategy tiles (top)
                log fills remaining space (bottom)
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- settings, tiles, controls -->
            <RowDefinition Height="*"/>     <!-- log -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             TOP: Scrollable settings
             ══════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,12,16,8">

                <TextBlock Text="🐕  Asset Bassett — Single Asset, Multi Strategy"
                           Style="{StaticResource PageTitleStyle}"/>

                <!-- ── Panel 1: Account / Asset / Profile / Controls ── -->
                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Padding="12,8" Margin="0,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>  <!-- Account: label -->
                            <ColumnDefinition Width="160"/>   <!-- Account ComboBox -->
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>  <!-- Asset: label -->
                            <ColumnDefinition Width="160"/>   <!-- Asset ComboBox -->
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>  <!-- Lewis -->
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="Auto"/>  <!-- Damian -->
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="Auto"/>  <!-- Joe -->
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>  <!-- Conf%: label -->
                            <ColumnDefinition Width="52"/>    <!-- Conf% box -->
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>  <!-- Start -->
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>  <!-- Stop -->
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Account:"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,8,0"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding Accounts}"
                                  SelectedItem="{Binding SelectedAccount}"
                                  FontSize="13" Height="28"
                                  Style="{StaticResource UnclippedComboBoxStyle}"
                                  ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"
                                  IsEnabled="{Binding IsNotRunning}"
                                  ToolTip="Select the account to trade with">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Foreground="White" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Grid.Column="3" Text="Asset:"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,8,0"/>
                        <ComboBox Grid.Column="4"
                                  ItemsSource="{Binding AvailableContracts}"
                                  SelectedItem="{Binding SelectedContract}"
                                  FontSize="13" Height="28"
                                  Style="{StaticResource UnclippedComboBoxStyle}"
                                  ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"
                                  IsEnabled="{Binding IsNotRunning}"
                                  ToolTip="Select the single asset all strategies will monitor">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Foreground="White" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <!-- Lewis pill -->
                        <Button Grid.Column="6" Command="{Binding SelectProfileCommand}" CommandParameter="Lewis">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ProfileButtonStyle}">
                                    <Setter Property="BorderBrush" Value="#4CAF50"/>
                                    <Setter Property="Padding" Value="10,4"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLewisSelected}" Value="True">
                                            <Setter Property="Background" Value="#228B22"/>
                                            <Setter Property="BorderThickness" Value="2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="🛡  Lewis" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Button>

                        <!-- Damian pill -->
                        <Button Grid.Column="8" Command="{Binding SelectProfileCommand}" CommandParameter="Damian">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ProfileButtonStyle}">
                                    <Setter Property="BorderBrush" Value="#90A4AE"/>
                                    <Setter Property="Padding" Value="10,4"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDamianSelected}" Value="True">
                                            <Setter Property="Background" Value="#228B22"/>
                                            <Setter Property="BorderThickness" Value="2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="⚖  Damian" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Button>

                        <!-- Joe pill -->
                        <Button Grid.Column="10" Command="{Binding SelectProfileCommand}" CommandParameter="Joe">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ProfileButtonStyle}">
                                    <Setter Property="BorderBrush" Value="#EF5350"/>
                                    <Setter Property="Padding" Value="10,4"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsJoeSelected}" Value="True">
                                            <Setter Property="Background" Value="#228B22"/>
                                            <Setter Property="BorderThickness" Value="2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="🔥  Joe" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Button>

                        <!-- Confidence % -->
                        <TextBlock Grid.Column="12" Text="Conf%:"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"
                                   ToolTip="Minimum signal confidence required for any engine to fire"/>
                        <TextBox Grid.Column="13"
                                 Text="{Binding MinConfidencePct, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center" Height="26"
                                 ToolTip="Set by the active risk profile (Lewis=75, Damian=65, Joe=55). Override here if needed."/>

                        <!-- Start / Stop -->
                        <Button Grid.Column="15"
                                Content="▶  Start"
                                Command="{Binding StartCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Width="90" Height="28"
                                ToolTip="Start all enabled strategy engines on the selected asset"/>
                        <Button Grid.Column="17"
                                Content="■  Stop All"
                                Command="{Binding StopCommand}"
                                Style="{StaticResource DangerButtonStyle}"
                                Width="80" Height="28"
                                ToolTip="Stop all running engines"/>

                    </Grid>
                </Border>

                <!-- ── ATR Risk Tier ─────────────────────────────────── -->
                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Padding="12,6" Margin="0,4,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="ATR Tier:"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"
                                   ToolTip="Controls SL/TP bracket width as ATR multiples for all 6 strategies. All tiers maintain 1:2 R:R."/>

                        <Button Command="{Binding SelectAtrTierCommand}" CommandParameter="Tight"
                                Margin="0,0,4,0"
                                ToolTip="Tight: SL=0.75×ATR, TP=1.5×ATR. Tighter brackets — more signals.">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ProfileButtonStyle}">
                                    <Setter Property="MinWidth" Value="70"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAtrTightSelected}" Value="True">
                                            <Setter Property="Background" Value="#8B4513"/>
                                            <Setter Property="BorderThickness" Value="2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="📏  Tight" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Button>

                        <Button Command="{Binding SelectAtrTierCommand}" CommandParameter="Standard"
                                Margin="0,0,4,0"
                                ToolTip="Standard: SL=1.5×ATR, TP=3.0×ATR. Balanced brackets.">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ProfileButtonStyle}">
                                    <Setter Property="MinWidth" Value="70"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAtrStandardSelected}" Value="True">
                                            <Setter Property="Background" Value="#228B22"/>
                                            <Setter Property="BorderThickness" Value="2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="📐  Standard" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Button>

                        <Button Command="{Binding SelectAtrTierCommand}" CommandParameter="Wide"
                                ToolTip="Wide: SL=2.5×ATR, TP=5.0×ATR. Widest brackets — fewer whipsaws, patient exits.">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ProfileButtonStyle}">
                                    <Setter Property="MinWidth" Value="70"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAtrWideSelected}" Value="True">
                                            <Setter Property="Background" Value="#1A237E"/>
                                            <Setter Property="BorderThickness" Value="2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="🔭  Wide" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Button>

                        <TextBlock Margin="16,0,0,0" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                   FontFamily="Consolas">
                            <Run Text="SL "/>
                            <Run Text="{Binding SlMultipleOfN, StringFormat='{}{0:F2}×'}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"/>
                            <Run Text="  TP "/>
                            <Run Text="{Binding TpMultipleOfN, StringFormat='{}{0:F2}×'}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"/>
                            <Run Text="  ATR · applied to all 6 engines"/>
                        </TextBlock>

                        <!-- Extend TP on close -->
                        <CheckBox Margin="16,0,0,0" VerticalAlignment="Center"
                                  IsChecked="{Binding ExtendTpOnClose, Mode=TwoWay}"
                                  ToolTip="When a bar closes at or beyond the TP, advance the target by one TpMultiple × ATR (up to 3 times). Lets winning trades run further.">
                            <TextBlock Text="Extend TP on close" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                        </CheckBox>

                        <!-- STRAT-30: Regime override dropdowns -->
                        <Border Width="1" Height="16" Margin="10,0"
                                Background="{StaticResource BorderBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="Trending→" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"
                                   ToolTip="STRAT-30: Override all 6 strategy slots when regime = Trending (expanding ATR + ADX above threshold)."/>
                        <ComboBox ItemsSource="{Binding AvailableRegimeOverrides}"
                                  SelectedItem="{Binding SelectedTrendingOverrideName, Mode=TwoWay}"
                                  Width="130" Height="22" FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0"
                                  ToolTip="Strategy used in trending conditions. Both dropdowns must be set to activate."/>
                        <TextBlock Text="Ranging→" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"
                                   ToolTip="STRAT-30: Override all 6 strategy slots when regime = Ranging (contracting ATR or ADX below threshold)."/>
                        <ComboBox ItemsSource="{Binding AvailableRegimeOverrides}"
                                  SelectedItem="{Binding SelectedRangingOverrideName, Mode=TwoWay}"
                                  Width="130" Height="22" FontSize="10" VerticalAlignment="Center"
                                  ToolTip="Strategy used in ranging conditions. Both dropdowns must be set to activate."/>
                    </StackPanel>
                </Border>

                <!-- ── Panel 2: Risk settings ── -->
                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Padding="12,8" Margin="0,4,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="ADX≥:"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Text="{Binding AdxThreshold, UpdateSourceTrigger=PropertyChanged}"
                                 Width="40" Height="26" VerticalAlignment="Center"
                                 ToolTip="Minimum ADX value required to allow entry (trend-strength gate)"/>
                        <TextBlock Text="  Max Scale-ins:"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Text="{Binding MaxScaleIns, UpdateSourceTrigger=PropertyChanged}"
                                 Width="36" Height="26" VerticalAlignment="Center"
                                 ToolTip="Maximum additional positions after initial entry (0 = no scaling)"/>
                        <TextBlock Text="  (all strategies share these — SL/TP multiples are per-strategy)"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="10" FontStyle="Italic"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ── Panel 3: Strategy tiles — 2 rows × 5 ── -->
                <!-- Click = toggle enabled. Green highlight = will run on Start.    -->
                <!-- Tiles are non-interactive while running (IsHitTestVisible=False) -->
                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Padding="12,10" Margin="0,4,0,0">
                    <StackPanel>

                        <TextBlock Text="SELECT STRATEGIES  (click to toggle — green = will run)"
                                   Style="{StaticResource SectionHeadingStyle}"
                                   Margin="0,0,0,8"/>

                        <!-- Row 1 -->
                        <UniformGrid Columns="4">
                            <UniformGrid.IsHitTestVisible>
                                <Binding Path="IsNotRunning"/>
                            </UniformGrid.IsHitTestVisible>

                            <!-- 1. EMA/RSI Combined -->
                            <Button Command="{Binding ToggleEmaRsiCommand}" Margin="0,0,6,0"
                                    ToolTip="Toggle: 6-signal weighted EMA/RSI · 5-min bars · SL=1.0N · TP=2.0N">
                                <Button.Style>
                                    <Style BasedOn="{StaticResource StrategyCardStyle}" TargetType="Button">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEmaRsiEnabled}" Value="True">
                                                <Setter Property="Background"      Value="{StaticResource NavSelectedBrush}"/>
                                                <Setter Property="BorderBrush"     Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <ContentControl Template="{StaticResource EmaRsiCardContent}"/>
                            </Button>

                            <!-- 2. Multi-Confluence -->
                            <Button Command="{Binding ToggleMultiConfluenceCommand}" Margin="0,0,6,0"
                                    ToolTip="Toggle: 7-condition Ichimoku + MACD + StochRSI · 15-min · SL=1.5N · TP=3.0N">
                                <Button.Style>
                                    <Style BasedOn="{StaticResource StrategyCardStyle}" TargetType="Button">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMultiConfluenceEnabled}" Value="True">
                                                <Setter Property="Background"      Value="{StaticResource NavSelectedBrush}"/>
                                                <Setter Property="BorderBrush"     Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <ContentControl Template="{StaticResource MultiConfluenceCardContent}"/>
                            </Button>

                            <!-- 3. LULT Divergence -->
                            <Button Command="{Binding ToggleLultCommand}" Margin="0,0,6,0"
                                    ToolTip="Toggle: 6-step WaveTrend divergence · 5-min · SL=1.0N · TP=2.0N · no scale-in">
                                <Button.Style>
                                    <Style BasedOn="{StaticResource StrategyCardStyle}" TargetType="Button">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLultEnabled}" Value="True">
                                                <Setter Property="Background"      Value="{StaticResource NavSelectedBrush}"/>
                                                <Setter Property="BorderBrush"     Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <ContentControl Template="{StaticResource LultDivergenceCardContent}"/>
                            </Button>

                            <!-- 4. BB Squeeze Scalper -->
                            <Button Command="{Binding ToggleBbSqueezeCommand}" Margin="0"
                                    ToolTip="Toggle: Bollinger Squeeze · 5-min scalp · SL=0.8N · TP=1.6N · no scale-in">
                                <Button.Style>
                                    <Style BasedOn="{StaticResource StrategyCardStyle}" TargetType="Button">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBbSqueezeEnabled}" Value="True">
                                                <Setter Property="Background"      Value="{StaticResource NavSelectedBrush}"/>
                                                <Setter Property="BorderBrush"     Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <ContentControl Template="{StaticResource BbSqueezeCardContent}"/>
                            </Button>
                        </UniformGrid>

                        <!-- Row 2 -->
                        <UniformGrid Columns="4" Margin="0,6,0,0">
                            <UniformGrid.IsHitTestVisible>
                                <Binding Path="IsNotRunning"/>
                            </UniformGrid.IsHitTestVisible>

                            <!-- 5. VIDYA Cross -->
                            <Button Command="{Binding ToggleVidyaCommand}" Margin="0,0,6,0"
                                    ToolTip="Toggle: Variable Index Dynamic Average · 15-min · SL=1.2N · TP=2.4N">
                                <Button.Style>
                                    <Style BasedOn="{StaticResource StrategyCardStyle}" TargetType="Button">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsVidyaEnabled}" Value="True">
                                                <Setter Property="Background"      Value="{StaticResource NavSelectedBrush}"/>
                                                <Setter Property="BorderBrush"     Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <ContentControl Template="{StaticResource VidyaCrossCardContent}"/>
                            </Button>

                            <!-- 6. Naked Trader -->
                            <Button Command="{Binding ToggleNakedTraderCommand}" Margin="0,0,6,0"
                                    ToolTip="Toggle: 4-vote consensus · EMA(9/21) · MACD · DMI/ADX · VWAP · 5-min · SL=1.0N · TP=2.0N">
                                <Button.Style>
                                    <Style BasedOn="{StaticResource StrategyCardStyle}" TargetType="Button">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsNakedTraderEnabled}" Value="True">
                                                <Setter Property="Background"      Value="{StaticResource NavSelectedBrush}"/>
                                                <Setter Property="BorderBrush"     Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <ContentControl Template="{StaticResource NakedTraderCardContent}"/>
                            </Button>

                            <!-- 7. Double Bubble Butt -->
                            <Button Command="{Binding ToggleDoubleBubbleButtCommand}" Margin="0,0,6,0"
                                    ToolTip="Toggle: Double Bollinger Band · BB(20,1.0 SD) inner · BB(20,2.0 SD) outer · Long above upper 1-SD · Short below lower 1-SD · Exit on neutral-zone close · SL=outer band">
                                <Button.Style>
                                    <Style BasedOn="{StaticResource StrategyCardStyle}" TargetType="Button">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDoubleBubbleButtEnabled}" Value="True">
                                                <Setter Property="Background"      Value="{StaticResource NavSelectedBrush}"/>
                                                <Setter Property="BorderBrush"     Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <ContentControl Template="{StaticResource DoubleBubbleButtCardContent}"/>
                            </Button>

                            <!-- 8. Placeholder -->
                            <Button IsEnabled="False" Margin="0"
                                    Style="{StaticResource StrategyCardStyle}">
                                <ContentControl Template="{StaticResource PlaceholderCardContent}"/>
                            </Button>
                        </UniformGrid>

                        <!-- Hint: none selected -->
                        <TextBlock Text="Click any tile above to enable it. At least one must be selected to start."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="10" FontStyle="Italic"
                                   Margin="0,8,0,0"
                                   Visibility="{Binding HasAnyStrategyEnabled,
                                                Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                    </StackPanel>
                </Border>

                <!-- ── Panel 4: Status bar ── -->
                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Padding="12,8" Margin="0,4,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Status text + Danger Zone badge -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="Consolas" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <Border Background="#CC8B0000"
                                    CornerRadius="4" Padding="8,3"
                                    Margin="16,0,0,0" VerticalAlignment="Center"
                                    Visibility="{Binding IsDangerZoneVisible,
                                                 Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="⚠️  DANGER ZONE — SL at breakeven"
                                           Foreground="#FFFF5252"
                                           FontFamily="Consolas" FontSize="12"
                                           FontWeight="Bold"/>
                            </Border>
                        </StackPanel>

                        <!-- Asset name badge -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SelectedContractName}"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontFamily="Consolas" FontSize="12"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ══════════════════════════════════════════════════════════
             BOTTOM: Shared coordinator log
             ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="6" Padding="16,12"
                Margin="16,4,16,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="COORDINATOR LOG  (newest first)"
                           Style="{StaticResource SectionHeadingStyle}"
                           Margin="0,0,0,8"/>

                <ListBox Grid.Row="1"
                         x:Name="LogList"
                         ItemsSource="{Binding LogEntries}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="Consolas" FontSize="11"
                                       TextWrapping="Wrap"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0,1"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>

    </Grid>
</UserControl>
