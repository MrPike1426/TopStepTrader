<UserControl x:Class="TopStepTrader.UI.Views.SignalsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="🤖  AI Signals" Style="{StaticResource PageTitleStyle}" Margin="0"/>
            <Button Content="↻ Refresh"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="16,0,0,0" Padding="10,4" FontSize="11"/>
        </StackPanel>

        <!-- Filter bar -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                CornerRadius="6" Padding="12,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Contract ID filter:"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                <TextBox Width="120"
                         Text="{Binding FilterContractId, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusText}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="20,0,0,0" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Signals grid -->
        <DataGrid Grid.Row="4"
                  ItemsSource="{Binding Signals}"
                  SelectedItem="{Binding SelectedSignal}"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Time"        Binding="{Binding Time}"        Width="130"/>
                <DataGridTextColumn Header="Contract"    Binding="{Binding ContractId}"  Width="80"/>
                <DataGridTemplateColumn Header="Signal"  Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding SignalType}"
                                       Foreground="{Binding SignalColor, Converter={StaticResource BrushKeyConverter}}"
                                       FontWeight="Bold" VerticalAlignment="Center" Padding="4,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Confidence"  Binding="{Binding Confidence}"  Width="90"/>
                <DataGridTextColumn Header="Entry"       Binding="{Binding EntryPrice}"  Width="90"/>
                <DataGridTextColumn Header="Stop Loss"   Binding="{Binding StopLoss}"    Width="90"/>
                <DataGridTextColumn Header="Take Profit" Binding="{Binding TakeProfit}"  Width="95"/>
                <DataGridTextColumn Header="Model"       Binding="{Binding ModelVersion}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</UserControl>
