<UserControl x:Class="TopStepTrader.UI.Views.OrderBookView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>

        <!-- Title + Status -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="📋  Orders" Style="{StaticResource PageTitleStyle}" Margin="0"/>
            <Button Content="↻ Refresh"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="16,0,0,0" Padding="10,4" FontSize="11"/>
            <TextBlock Text="{Binding StatusText}"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="16,0,0,0" FontSize="12"/>
        </StackPanel>

        <!-- Place Order panel -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                CornerRadius="6" Padding="16,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Contract:" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1"
                         Text="{Binding NewContractId, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"/>

                <TextBlock Grid.Column="3" Text="Qty:" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                <TextBox Grid.Column="4"
                         Text="{Binding NewQuantity, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"/>

                <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="▲  BUY"
                            Command="{Binding PlaceBuyCommand}"
                            Style="{StaticResource BuyButtonStyle}"
                            Width="100" Margin="0,0,8,0"/>
                    <Button Content="▼  SELL"
                            Command="{Binding PlaceSellCommand}"
                            Style="{StaticResource SellButtonStyle}"
                            Width="100" Margin="0,0,8,0"/>
                    <Button Content="Cancel Selected"
                            Command="{Binding CancelOrderCommand}"
                            Style="{StaticResource DangerButtonStyle}"
                            Padding="12,8"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Open Orders -->
        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="OPEN ORDERS" Style="{StaticResource SectionHeadingStyle}"/>
            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding OpenOrders}"
                      SelectedItem="{Binding SelectedOrder}"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"        Binding="{Binding OrderId}"   Width="70"/>
                    <DataGridTextColumn Header="Contract"  Binding="{Binding ContractId}" Width="80"/>
                    <DataGridTemplateColumn Header="Side"  Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Side}"
                                           Foreground="{Binding SideColor, Converter={StaticResource BrushKeyConverter}}"
                                           FontWeight="Bold" VerticalAlignment="Center" Padding="4,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Qty"       Binding="{Binding Qty}"       Width="50"/>
                    <DataGridTextColumn Header="Type"      Binding="{Binding Price}"     Width="80"/>
                    <DataGridTextColumn Header="Status"    Binding="{Binding Status}"    Width="90"/>
                    <DataGridTextColumn Header="Placed"    Binding="{Binding PlacedAt}"  Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Section heading -->
        <TextBlock Grid.Row="6" Text="TODAY'S FILLED ORDERS" Style="{StaticResource SectionHeadingStyle}"/>

        <!-- Filled Orders -->
        <DataGrid Grid.Row="8"
                  ItemsSource="{Binding FilledOrders}"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"         Binding="{Binding OrderId}"   Width="70"/>
                <DataGridTextColumn Header="Contract"   Binding="{Binding ContractId}" Width="80"/>
                <DataGridTemplateColumn Header="Side"   Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Side}"
                                       Foreground="{Binding SideColor, Converter={StaticResource BrushKeyConverter}}"
                                       FontWeight="Bold" VerticalAlignment="Center" Padding="4,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Qty"        Binding="{Binding Qty}"       Width="50"/>
                <DataGridTextColumn Header="Fill Price" Binding="{Binding FillPrice}" Width="90"/>
                <DataGridTextColumn Header="Placed"     Binding="{Binding PlacedAt}"  Width="90"/>
                <DataGridTextColumn Header="Filled"     Binding="{Binding FilledAt}"  Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</UserControl>
