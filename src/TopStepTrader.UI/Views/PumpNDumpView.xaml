<UserControl x:Class="TopStepTrader.UI.Views.PumpNDumpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:TopStepTrader.UI.Controls"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,8">

            <TextBlock Text="💥  Pump-n-Dump"
                       Style="{StaticResource PageTitleStyle}"/>

            <!-- ── Strategy Description ── -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="6" Padding="14,10" Margin="0,8,0,0"
                    BorderBrush="{StaticResource AccentBrush}" BorderThickness="0,0,0,2">
                <StackPanel>
                    <TextBlock Text="HOW IT WORKS"
                               Style="{StaticResource SectionHeadingStyle}"
                               Margin="0,0,0,6"/>
                    <TextBlock TextWrapping="Wrap" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               LineHeight="18">
                        <Run Foreground="White" FontWeight="SemiBold">Entry — </Run>
                        <Run>Watches for 3 consecutive 1-minute bars all closing in the same direction. Three green bars triggers a Long (Pump). Three red bars triggers a Short (Dump). Reacts directly to vertical price action — no indicators, no lag.</Run>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,6,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               LineHeight="18">
                        <Run Foreground="White" FontWeight="SemiBold">Scale-In — </Run>
                        <Run>Adds 1 contract each time price moves the configured number of ticks further in the direction of the trade, up to the maximum size. Each scale-in gets its own TP/SL bracket.</Run>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,6,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               LineHeight="18">
                        <Run Foreground="White" FontWeight="SemiBold">Free Ride — </Run>
                        <Run>When unrealised P&amp;L reaches the dollar threshold, all stop losses are moved to average entry. The position runs with zero downside risk from that point — any outcome is at worst breakeven.</Run>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,6,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               LineHeight="18">
                        <Run Foreground="White" FontWeight="SemiBold">Momentum Fade — </Run>
                        <Run>Every poll, the last 3 bar ranges are compared to the ATR. When bars start getting smaller (the move is running out of steam), take-profit orders are tightened by the configured ticks per poll, locking in more of the gain before the reversal.</Run>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- ── Panel 1: Account / Contract ── -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="6" Padding="20,14" Margin="0,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Account:"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,8,0"/>

                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding Accounts}"
                              SelectedItem="{Binding SelectedAccount}"
                              FontSize="13" Height="28"
                              Style="{StaticResource UnclippedComboBoxStyle}"
                              ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"
                              IsEnabled="{Binding IsNotRunning}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"
                                           Foreground="White"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <controls:ContractSelectorControl
                        Grid.Column="3"
                        ContractId="{Binding ContractId, Mode=TwoWay}"
                        IsEnabled="{Binding IsNotRunning}"/>
                </Grid>
            </Border>

            <!-- ── Panel 2: Parameters ── -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="6" Padding="20,14" Margin="0,8,0,0">
                <StackPanel>
                    <TextBlock Text="PARAMETERS"
                               Style="{StaticResource SectionHeadingStyle}"
                               Margin="0,0,0,10"/>

                    <!-- Row 1: TP / SL / Free-Ride threshold -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="TP Ticks:"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,6,0"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding TakeProfitTicks, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsNotRunning}"
                                 ToolTip="Initial take profit distance in ticks. Starts wide — tightened as momentum fades."/>

                        <TextBlock Grid.Column="3" Text="SL Ticks:"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,6,0"/>
                        <TextBox Grid.Column="4"
                                 Text="{Binding StopLossTicks, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsNotRunning}"
                                 ToolTip="Initial stop loss in ticks. Moved to breakeven when Free Ride triggers."/>

                        <TextBlock Grid.Column="6" Text="Free-Ride $:"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,6,0"/>
                        <TextBox Grid.Column="7"
                                 Text="{Binding FreeRidePnlThreshold, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsNotRunning}"
                                 ToolTip="Dollar P&amp;L threshold to activate free-ride (move all SLs to avg entry)."/>
                    </Grid>

                    <!-- Row 2: Scale-in / Max heat / Max size -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="64"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Scale-In Ticks:"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,6,0"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding ScaleInTicks, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsNotRunning}"
                                 ToolTip="Price must move this many ticks from last entry before adding another contract."/>

                        <TextBlock Grid.Column="3" Text="Max Heat (t):"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,6,0"/>
                        <TextBox Grid.Column="4"
                                 Text="{Binding MaxRiskHeatTicks, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsNotRunning}"
                                 ToolTip="Maximum total tick risk across all open brackets. Scale-ins blocked when this is reached."/>

                        <TextBlock Grid.Column="6" Text="Max Size:"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,6,0"/>
                        <TextBox Grid.Column="7"
                                 Text="{Binding TargetTotalSize, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsNotRunning}"
                                 ToolTip="Maximum number of contracts to hold at once."/>
                    </Grid>

                    <!-- Row 3: Momentum fade / Tighten / Duration -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="64"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Fade ATR ×:"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,6,0"
                                   ToolTip="Fraction of ATR. If avg last-3-bar range falls below this, momentum is considered fading."/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding MomentumFadeAtrFraction, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsNotRunning}"
                                 ToolTip="E.g. 0.5 = fade detected when bar ranges drop below 50% of ATR(14)."/>

                        <TextBlock Grid.Column="3" Text="Tighten (t/poll):"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,6,0"/>
                        <TextBox Grid.Column="4"
                                 Text="{Binding TightenTicksPerBar, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsNotRunning}"
                                 ToolTip="Ticks to move TP closer to price on each 15-second poll when momentum is fading."/>

                        <TextBlock Grid.Column="6" Text="Duration (h):"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,6,0"/>
                        <TextBox Grid.Column="7"
                                 Text="{Binding DurationHours, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsNotRunning}"
                                 ToolTip="Session expires after this many hours. Engine stops and flattens all positions."/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Panel 3: Controls + Live Status ── -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="6" Padding="20,14" Margin="0,8,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="▶  Start"
                            Command="{Binding StartCommand}"
                            Width="90" Height="32"
                            Style="{StaticResource PrimaryButtonStyle}"/>

                    <Button Grid.Column="2"
                            Content="■  Stop"
                            Command="{Binding StopCommand}"
                            Width="80" Height="32"
                            Style="{StaticResource DangerButtonStyle}"/>

                    <!-- Live position info -->
                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding PositionDisplay}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" VerticalAlignment="Center"
                                   Margin="0,0,16,0"/>
                        <TextBlock Text="{Binding AverageEntryDisplay}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" VerticalAlignment="Center"
                                   Margin="0,0,16,0"/>
                        <TextBlock Text="{Binding UnrealisedPnlDisplay}"
                                   Foreground="{Binding UnrealisedPnlBrush}"
                                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Margin="0,0,16,0"/>
                        <TextBlock Text="{Binding FreeRideDisplay}"
                                   Foreground="#4ABA61"
                                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Margin="0,0,16,0"/>
                        <TextBlock Text="{Binding HeatDisplay}"
                                   Foreground="#E8A020"
                                   FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Panel 4: Performance ── -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="6" Padding="16,10" Margin="0,8,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding WinLossDisplay}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" VerticalAlignment="Center"
                               Margin="0,0,24,0"/>
                    <TextBlock Text="Session P&amp;L: "
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalPnlDisplay}"
                               Foreground="{Binding TotalPnlBrush}"
                               FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- ── Panel 5: Log ── -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="6" Padding="16,12" Margin="0,8,0,16">
                <StackPanel>
                    <TextBlock Text="ENGINE LOG"
                               Style="{StaticResource SectionHeadingStyle}"
                               Margin="0,0,0,8"/>
                    <ListBox x:Name="LogList"
                             ItemsSource="{Binding LogEntries}"
                             Background="Transparent"
                             BorderThickness="0"
                             Height="240"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.IsVirtualizing="True">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontFamily="Consolas" FontSize="11"
                                           TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0,1"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
