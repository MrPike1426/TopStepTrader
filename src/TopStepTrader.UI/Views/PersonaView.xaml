<UserControl x:Class="TopStepTrader.UI.Views.PersonaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,24">

            <!-- Page header -->
            <TextBlock Text="👤  Persona Configuration"
                       Style="{StaticResource PageTitleStyle}"
                       Margin="0,0,0,4"/>
            <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" Margin="0,0,0,20" TextWrapping="Wrap">
                Edit risk parameters for each trading persona. Changes take effect the next time a persona is applied on Hydra, Bassett, or Backtest.
                Use <Bold>Reset to Defaults</Bold> to restore the original appsettings.json values.
            </TextBlock>

            <!-- Three persona cards side by side -->
            <ItemsControl ItemsSource="{Binding Personas}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,12,0"
                                Background="{StaticResource SurfaceBrush}"
                                CornerRadius="8"
                                Padding="20,18">
                            <StackPanel>

                                <!-- ── Card header ── -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Border CornerRadius="4" Padding="8,2" Margin="0,0,10,0"
                                            Background="{Binding AccentBrush}">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="14" Foreground="Black"/>
                                    </Border>
                                    <TextBlock Text="{Binding RiskLabel}"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <Border Height="1" Background="{StaticResource BorderBrush}"
                                        Opacity="0.3" Margin="0,8,0,14"/>

                                <!-- ── Editable fields ── -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Capital -->
                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="Capital per trade ($)"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="0" Grid.Column="1"
                                             Text="{Binding TradeAmount, UpdateSourceTrigger=PropertyChanged, StringFormat=F0}"
                                             Height="26" VerticalContentAlignment="Center"
                                             HorizontalContentAlignment="Right"
                                             ToolTip="Cash amount committed per initial trade (USD)."/>

                                    <!-- Leverage -->
                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                               Text="Leverage (×)"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="2" Grid.Column="1"
                                             Text="{Binding Leverage, UpdateSourceTrigger=PropertyChanged}"
                                             Height="26" VerticalContentAlignment="Center"
                                             HorizontalContentAlignment="Right"
                                             ToolTip="Preferred leverage multiplier (capped by instrument regulatory maximum)."/>

                                    <!-- Max scale-ins -->
                                    <TextBlock Grid.Row="4" Grid.Column="0"
                                               Text="Max scale-ins"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="4" Grid.Column="1"
                                             Text="{Binding MaxScaleIns, UpdateSourceTrigger=PropertyChanged}"
                                             Height="26" VerticalContentAlignment="Center"
                                             HorizontalContentAlignment="Right"
                                             ToolTip="Maximum additional positions after initial entry (0 = no scale-in)."/>

                                    <!-- SL multiple -->
                                    <TextBlock Grid.Row="6" Grid.Column="0"
                                               Text="SL multiple of N"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="6" Grid.Column="1"
                                             Text="{Binding SlMultipleOfN, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                                             Height="26" VerticalContentAlignment="Center"
                                             HorizontalContentAlignment="Right"
                                             ToolTip="Stop-loss distance = SlMultipleOfN × ATR(14) × DollarPerPoint."/>

                                    <!-- Leveraged SL multiple -->
                                    <TextBlock Grid.Row="8" Grid.Column="0"
                                               Text="Leveraged SL multiple of N"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12" VerticalAlignment="Center"
                                               TextWrapping="Wrap"/>
                                    <TextBox Grid.Row="8" Grid.Column="1"
                                             Text="{Binding LeveragedSlMultipleOfN, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                                             Height="26" VerticalContentAlignment="Center"
                                             HorizontalContentAlignment="Right"
                                             ToolTip="Wider SL for leveraged CFDs (eToro spread buffer). 0 = disabled, falls back to SL multiple above."/>

                                    <!-- TP multiple -->
                                    <TextBlock Grid.Row="10" Grid.Column="0"
                                               Text="TP multiple of N"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="10" Grid.Column="1"
                                             Text="{Binding TpMultipleOfN, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                                             Height="26" VerticalContentAlignment="Center"
                                             HorizontalContentAlignment="Right"
                                             ToolTip="Take-profit distance = TpMultipleOfN × ATR(14) × DollarPerPoint."/>

                                    <!-- ADX threshold -->
                                    <TextBlock Grid.Row="12" Grid.Column="0"
                                               Text="Min ADX(14)"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="12" Grid.Column="1"
                                             Text="{Binding AdxThreshold, UpdateSourceTrigger=PropertyChanged, StringFormat=F0}"
                                             Height="26" VerticalContentAlignment="Center"
                                             HorizontalContentAlignment="Right"
                                             ToolTip="Minimum ADX value required for the trend-strength gate. Higher = only enter strong trends."/>

                                    <!-- Confidence -->
                                    <TextBlock Grid.Row="14" Grid.Column="0"
                                               Text="Min confidence (%)"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="14" Grid.Column="1"
                                             Text="{Binding DefaultConfidencePct, UpdateSourceTrigger=PropertyChanged}"
                                             Height="26" VerticalContentAlignment="Center"
                                             HorizontalContentAlignment="Right"
                                             ToolTip="Minimum weighted signal confidence score (0–100) required before placing a trade."/>
                                </Grid>

                                <!-- ── Buttons ── -->
                                <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                                    <Button Command="{Binding SaveCommand}"
                                            IsEnabled="{Binding IsBusy, Converter={StaticResource BoolInverseConverter}}"
                                            Padding="14,6" Margin="0,0,8,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Setter Property="Background" Value="{StaticResource BuyBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="💾  Save Persona"/>
                                    </Button>

                                    <Button Command="{Binding ResetCommand}"
                                            IsEnabled="{Binding IsBusy, Converter={StaticResource BoolInverseConverter}}"
                                            Style="{StaticResource SecondaryButtonStyle}">
                                        <TextBlock Text="↺  Reset to Defaults"/>
                                    </Button>
                                </StackPanel>

                                <!-- ── Status ── -->
                                <TextBlock Text="{Binding StatusMessage}"
                                           Margin="0,10,0,0"
                                           FontSize="12" FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding StatusMessage,
                                               Converter={StaticResource StringToVisibilityConverter}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsStatusSuccess}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource BuyBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsStatusSuccess}" Value="False">
                                                    <Setter Property="Foreground" Value="{StaticResource SellBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>

</UserControl>
