<Window x:Class="TopStepTrader.UI.Views.BarDownloadProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="TopStep AI Trader — Bar Data Download"
        Width="520" SizeToContent="Height"
        MinHeight="320" MaxHeight="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}"
        ShowInTaskbar="False">

    <Grid Margin="28,24,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Row 0: Header -->
            <RowDefinition Height="10"/>    <!-- Row 1: spacer -->
            <RowDefinition Height="Auto"/>  <!-- Row 2: Summary text -->
            <RowDefinition Height="16"/>    <!-- Row 3: spacer -->
            <RowDefinition Height="Auto"/>  <!-- Row 4: Items list -->
            <RowDefinition Height="16"/>    <!-- Row 5: spacer -->
            <RowDefinition Height="Auto"/>  <!-- Row 6: Progress area -->
            <RowDefinition Height="20"/>    <!-- Row 7: spacer -->
            <RowDefinition Height="Auto"/>  <!-- Row 8: Buttons -->
            <RowDefinition Height="4"/>     <!-- Row 9: bottom padding -->
        </Grid.RowDefinitions>

        <!-- ── Row 0: Header ──────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="📊"
                       FontSize="22"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>
            <TextBlock Text="Bar Data Download"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource AccentBrush}"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ── Row 2: Summary ─────────────────────────────────────────── -->
        <TextBlock Grid.Row="2"
                   Text="{Binding SummaryText}"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="13"
                   TextWrapping="Wrap"/>

        <!-- ── Row 4: Items list ──────────────────────────────────────── -->
        <Border Grid.Row="4"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="0,6">
            <ScrollViewer MaxHeight="220"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="16,5,16,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22"/>   <!-- status icon -->
                                    <ColumnDefinition Width="110"/>  <!-- contract name -->
                                    <ColumnDefinition Width="52"/>   <!-- timeframe -->
                                    <ColumnDefinition Width="*"/>    <!-- status text -->
                                </Grid.ColumnDefinitions>

                                <!-- Status icon -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding StatusIcon}"
                                           Foreground="{Binding StatusBrushKey,
                                               Converter={StaticResource BrushKeyConverter}}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>

                                <!-- Contract name -->
                                <TextBlock Grid.Column="1"
                                           Text="{Binding FriendlyName}"
                                           FontSize="13"
                                           VerticalAlignment="Center"/>

                                <!-- Timeframe label -->
                                <TextBlock Grid.Column="2"
                                           Text="{Binding TimeframeLabel}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12"
                                           VerticalAlignment="Center"/>

                                <!-- Status text -->
                                <TextBlock Grid.Column="3"
                                           Text="{Binding StatusText}"
                                           Foreground="{Binding StatusBrushKey,
                                               Converter={StaticResource BrushKeyConverter}}"
                                           FontSize="12"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ── Row 6: Progress area (shown during and after download) ─── -->
        <StackPanel Grid.Row="6"
                    Visibility="{Binding ShowProgressArea,
                        Converter={StaticResource BoolToVisibilityConverter}}">

            <ProgressBar Value="{Binding ProgressValue}"
                         Minimum="0" Maximum="100"
                         Height="6"
                         Foreground="{StaticResource AccentBrush}"
                         Background="{StaticResource SurfaceBrush}"
                         BorderBrush="{StaticResource BorderBrush}"
                         BorderThickness="1"/>

            <TextBlock Text="{Binding CurrentOperation}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12"
                       Margin="0,8,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- ── Row 8: Action buttons ──────────────────────────────────── -->

        <!-- Download + Skip  (shown before download starts) -->
        <StackPanel Grid.Row="8"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Visibility="{Binding ShowActionButtons,
                        Converter={StaticResource BoolToVisibilityConverter}}">

            <Button Content="  Download Missing Bars  "
                    Command="{Binding DownloadCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    MinWidth="180" Height="36"/>

            <Button Content="  Skip  "
                    Command="{Binding CloseCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    MinWidth="80" Height="36"
                    Margin="12,0,0,0"/>
        </StackPanel>

        <!-- Close  (shown after download completes) -->
        <Button Grid.Row="8"
                Content="  Close  "
                Command="{Binding CloseCommand}"
                Style="{StaticResource PrimaryButtonStyle}"
                HorizontalAlignment="Center"
                MinWidth="120" Height="36"
                Visibility="{Binding ShowCloseButton,
                    Converter={StaticResource BoolToVisibilityConverter}}"/>

    </Grid>
</Window>
