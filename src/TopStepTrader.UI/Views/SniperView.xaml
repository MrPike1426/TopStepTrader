<UserControl x:Class="TopStepTrader.UI.Views.SniperView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:TopStepTrader.UI.Controls"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>    <!-- TabControl fills space -->
            <RowDefinition Height="Auto"/> <!-- bottom control bar -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             TabControl: Live Sniper | Sniper Backtest
             ══════════════════════════════════════════════════════════ -->
        <TabControl Grid.Row="0" Background="{StaticResource BackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    x:Name="MainTabControl">

            <!-- ══════════════════════════════════════════════════════
                 TAB 1: Live Sniper
                 ══════════════════════════════════════════════════════ -->
            <TabItem Header="🎯  Live Sniper">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20,16,20,8">

                        <TextBlock Text="🎯  Sniper Trading"
                                   Style="{StaticResource PageTitleStyle}"/>

                        <!-- ── How It Works (collapsible) ── -->
                        <Expander IsExpanded="False" Margin="0,10,0,0"
                                  Foreground="{StaticResource TextPrimaryBrush}">
                            <Expander.Header>
                                <TextBlock Text="HOW IT WORKS"
                                           Style="{StaticResource SectionHeadingStyle}"
                                           VerticalAlignment="Center"/>
                            </Expander.Header>
                            <Border Background="{StaticResource SurfaceBrush}"
                                    CornerRadius="0,0,6,6" Padding="14,10,14,12"
                                    BorderBrush="{StaticResource AccentBrush}" BorderThickness="0,0,0,2">
                                <UniformGrid Columns="2" Margin="0,4,0,0">
                                    <!-- Entry -->
                                    <Border Margin="0,0,8,8" Padding="12,10"
                                            Background="{StaticResource CardBrush}" CornerRadius="5">
                                        <StackPanel>
                                            <TextBlock Text="① ENTRY" FontSize="12" FontWeight="Bold"
                                                       Foreground="{StaticResource AccentBrush}" Margin="0,0,0,5"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="13"
                                                       Foreground="{StaticResource TextSecondaryBrush}" LineHeight="19">
                                                EMA8 crosses EMA21 on the 1-minute chart, confirmed by price sitting on the correct side of a trending EMA50. Catches momentum spikes, rips and dumps as they develop.
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                    <!-- Pyramiding -->
                                    <Border Margin="0,0,0,8" Padding="12,10"
                                            Background="{StaticResource CardBrush}" CornerRadius="5">
                                        <StackPanel>
                                            <TextBlock Text="② PYRAMIDING" FontSize="12" FontWeight="Bold"
                                                       Foreground="{StaticResource AccentBrush}" Margin="0,0,0,5"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="13"
                                                       Foreground="{StaticResource TextSecondaryBrush}" LineHeight="19">
                                                Scales into up to the configured maximum in three tiers — Core → Momentum → Extension — each time price moves at least k×ATR in the trade direction and EMA8 stays aligned.
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                    <!-- Free Ride -->
                                    <Border Margin="0,0,8,0" Padding="12,10"
                                            Background="{StaticResource CardBrush}" CornerRadius="5">
                                        <StackPanel>
                                            <TextBlock Text="③ FREE RIDE" FontSize="12" FontWeight="Bold"
                                                       Foreground="{StaticResource AccentBrush}" Margin="0,0,0,5"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="13"
                                                       Foreground="{StaticResource TextSecondaryBrush}" LineHeight="19">
                                                Once 3+ contracts are open and all in profit, the stop is moved to average entry (breakeven). The position then runs with zero downside risk.
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                    <!-- Exit -->
                                    <Border Padding="12,10"
                                            Background="{StaticResource CardBrush}" CornerRadius="5">
                                        <StackPanel>
                                            <TextBlock Text="④ EXIT" FontSize="12" FontWeight="Bold"
                                                       Foreground="{StaticResource AccentBrush}" Margin="0,0,0,5"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="13"
                                                       Foreground="{StaticResource TextSecondaryBrush}" LineHeight="19">
                                                TP and SL brackets are placed at each entry. Optional structure-fail exit flattens everything if price closes back through EMA21 by more than the configured buffer after the minimum bar count.
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>
                            </Border>
                        </Expander>

                        <!-- ── Configuration ── -->
                        <Border Background="{StaticResource SurfaceBrush}"
                                CornerRadius="6" Padding="16,14" Margin="0,10,0,0">
                            <StackPanel>

                                <!-- Section: Account & Contract -->
                                <TextBlock Text="ACCOUNT &amp; CONTRACT"
                                           Style="{StaticResource SectionHeadingStyle}"
                                           Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="220"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Account"
                                               VerticalAlignment="Center" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,0,10,0"/>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding Accounts}"
                                              SelectedItem="{Binding SelectedAccount}"
                                              FontSize="26"
                                              Style="{StaticResource UnclippedComboBoxStyle}"
                                              ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"
                                              IsEnabled="{Binding IsNotRunning}">
                                        <ComboBox.ToolTip>
                                            <ToolTip><TextBlock TextWrapping="Wrap" MaxWidth="260" FontSize="13"
                                                Text="The funded account to trade on. Cannot be changed while the Sniper is running."/></ToolTip>
                                        </ComboBox.ToolTip>
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}" Foreground="White" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <TextBlock Grid.Column="3" Text="Contract"
                                               VerticalAlignment="Center" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,0,10,0"/>
                                    <controls:ContractSelectorControl
                                               Grid.Column="4"
                                               IsEnabled="{Binding IsNotRunning}"
                                               ContractId="{Binding ContractId, Mode=TwoWay,
                                                           UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>

                                <Separator Margin="0,12,0,10" Background="{StaticResource BorderBrush}"/>

                                <!-- Section: Risk & Brackets -->
                                <TextBlock Text="RISK &amp; BRACKETS"
                                           Style="{StaticResource SectionHeadingStyle}"
                                           Margin="0,0,0,8"/>

                                <!-- 4-column parameter grid -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Row 0 labels -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Take Profit ($)"
                                               VerticalAlignment="Center" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="1"/>
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Stop Loss ($)"
                                               VerticalAlignment="Center" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="6" Text="Max Heat (ticks)"
                                               VerticalAlignment="Center" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="9" Text="Duration (hrs)"
                                               VerticalAlignment="Center" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>

                                    <!-- Row 2 values -->
                                    <TextBox Grid.Row="2" Grid.Column="0"
                                             Text="{Binding TpAtrMultiple, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding IsNotRunning}">
                                        <TextBox.ToolTip>
                                            <ToolTip><TextBlock TextWrapping="Wrap" MaxWidth="260" FontSize="13"
                                                Text="Take-profit distance as a multiple of ATR(14) at entry. Example: 3.0 means TP is 3× the current ATR from entry price."/></ToolTip>
                                        </TextBox.ToolTip>
                                    </TextBox>
                                    <TextBox Grid.Row="2" Grid.Column="3"
                                             Text="{Binding SlAtrMultiple, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding IsNotRunning}">
                                        <TextBox.ToolTip>
                                            <ToolTip><TextBlock TextWrapping="Wrap" MaxWidth="260" FontSize="13"
                                                Text="Stop-loss distance as a multiple of ATR(14) at entry. Example: 1.5 means SL is 1.5× the current ATR from entry price."/></ToolTip>
                                        </TextBox.ToolTip>
                                    </TextBox>
                                    <TextBox Grid.Row="2" Grid.Column="6"
                                             Text="{Binding MaxRiskHeatTicks, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding IsNotRunning}">
                                        <TextBox.ToolTip>
                                            <ToolTip><TextBlock TextWrapping="Wrap" MaxWidth="260" FontSize="13"
                                                Text="Safety cap on total open risk. Measured as the sum of stop distances across all open contracts in ticks. No new entries are taken once this limit is reached. Default: 30."/></ToolTip>
                                        </TextBox.ToolTip>
                                    </TextBox>
                                    <TextBox Grid.Row="2" Grid.Column="9"
                                             Text="{Binding DurationHours, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding IsNotRunning}">
                                        <TextBox.ToolTip>
                                            <ToolTip><TextBlock TextWrapping="Wrap" MaxWidth="260" FontSize="13"
                                                Text="How many hours to keep the Sniper running from the moment you press Start. After this time no new signals are taken but open positions continue to be managed. Default: 2."/></ToolTip>
                                        </TextBox.ToolTip>
                                    </TextBox>
                                </Grid>

                                <Separator Margin="0,12,0,10" Background="{StaticResource BorderBrush}"/>

                                <!-- Section: Pyramid Sizing -->
                                <TextBlock Text="PYRAMID SIZING"
                                           Style="{StaticResource SectionHeadingStyle}"
                                           Margin="0,0,0,8"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Row labels -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Max Contracts"
                                               VerticalAlignment="Center" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Core Fraction"
                                               VerticalAlignment="Center" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="6" Text="Core Entries"
                                               VerticalAlignment="Center" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="9" Text="Scale Factor (k)"
                                               VerticalAlignment="Center" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>

                                    <!-- Row values -->
                                    <TextBox Grid.Row="2" Grid.Column="0"
                                             Text="{Binding TargetTotalSize, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding IsNotRunning}">
                                        <TextBox.ToolTip>
                                            <ToolTip><TextBlock TextWrapping="Wrap" MaxWidth="260" FontSize="13"
                                                Text="The maximum number of contracts the Sniper will hold at any one time across all pyramid tiers. Example: 10 means the position can grow from 1 up to 10 contracts."/></ToolTip>
                                        </TextBox.ToolTip>
                                    </TextBox>
                                    <TextBox Grid.Row="2" Grid.Column="3"
                                             Text="{Binding CoreSizeFraction, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding IsNotRunning}">
                                        <TextBox.ToolTip>
                                            <ToolTip><TextBlock TextWrapping="Wrap" MaxWidth="260" FontSize="13"
                                                Text="The proportion of the total position size reserved for the initial Core tier entries. Example: 0.55 means 55% of contracts are placed in the first few adds, with the remainder available for Momentum and Extension tiers."/></ToolTip>
                                        </TextBox.ToolTip>
                                    </TextBox>
                                    <TextBox Grid.Row="2" Grid.Column="6"
                                             Text="{Binding CoreAddsCount, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding IsNotRunning}">
                                        <TextBox.ToolTip>
                                            <ToolTip><TextBlock TextWrapping="Wrap" MaxWidth="260" FontSize="13"
                                                Text="How many scale-in steps to spread the Core allocation across. Example: 2 means the core contracts are split equally over the first 2 add-ins."/></ToolTip>
                                        </TextBox.ToolTip>
                                    </TextBox>
                                    <TextBox Grid.Row="2" Grid.Column="9"
                                             Text="{Binding ScaleInTriggerTicks, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding IsNotRunning}">
                                        <TextBox.ToolTip>
                                            <ToolTip><TextBlock TextWrapping="Wrap" MaxWidth="260" FontSize="13"
                                                Text="Distance multiplier for triggering each pyramid add. Price must move k × ATR from the last entry before the next scale-in is allowed. Example: 0.4 means 40% of the current ATR."/></ToolTip>
                                        </TextBox.ToolTip>
                                    </TextBox>

                                    <!-- Momentum / Extension labels -->
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Momentum Add"
                                               VerticalAlignment="Center" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="3" Text="Extension Add"
                                               VerticalAlignment="Center" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="6" Text="Allow Extension"
                                               VerticalAlignment="Center" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>

                                    <!-- Momentum / Extension values -->
                                    <TextBox Grid.Row="6" Grid.Column="0"
                                             Text="{Binding MomentumTierSize, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding IsNotRunning}">
                                        <TextBox.ToolTip>
                                            <ToolTip><TextBlock TextWrapping="Wrap" MaxWidth="260" FontSize="13"
                                                Text="Number of contracts added each time the Momentum tier triggers. Momentum adds happen after the Core is filled, while the move is accelerating. Example: 1 adds one contract per momentum signal."/></ToolTip>
                                        </TextBox.ToolTip>
                                    </TextBox>
                                    <TextBox Grid.Row="6" Grid.Column="3"
                                             Text="{Binding ExtensionTierSize, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding IsNotRunning}">
                                        <TextBox.ToolTip>
                                            <ToolTip><TextBlock TextWrapping="Wrap" MaxWidth="260" FontSize="13"
                                                Text="Number of contracts added per Extension tier trigger. Extension adds are the final, most aggressive scale-ins during an extended trend. Only used when Allow Extension is enabled."/></ToolTip>
                                        </TextBox.ToolTip>
                                    </TextBox>
                                    <CheckBox Grid.Row="6" Grid.Column="6"
                                              IsChecked="{Binding ExtensionAllowed}"
                                              VerticalAlignment="Center"
                                              IsEnabled="{Binding IsNotRunning}"
                                              Foreground="{StaticResource TextSecondaryBrush}">
                                        <CheckBox.ToolTip>
                                            <ToolTip><TextBlock TextWrapping="Wrap" MaxWidth="260" FontSize="13"
                                                Text="When checked, the Sniper will add Extension tier contracts once the Momentum tier is exhausted and the trend continues. Disable this for more conservative sizing."/></ToolTip>
                                        </CheckBox.ToolTip>
                                    </CheckBox>
                                </Grid>

                                <Separator Margin="0,12,0,10" Background="{StaticResource BorderBrush}"/>

                                <!-- Section: Structure-Fail Exit -->
                                <TextBlock Text="STRUCTURE-FAIL EXIT"
                                           Style="{StaticResource SectionHeadingStyle}"
                                           Margin="0,0,0,8"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="EMA21 Break (ticks)"
                                               VerticalAlignment="Center" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Min Bars Held"
                                               VerticalAlignment="Center" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="6" Text="Enable"
                                               VerticalAlignment="Center" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,0,8,0"/>

                                    <TextBox Grid.Row="2" Grid.Column="0"
                                             Text="{Binding Ema21BreakTicks, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding IsNotRunning}">
                                        <TextBox.ToolTip>
                                            <ToolTip><TextBlock TextWrapping="Wrap" MaxWidth="260" FontSize="13"
                                                Text="How far price must close beyond the EMA21 line (in ticks) to count as a structure break and trigger an immediate flat exit. A small buffer (e.g. 2) avoids premature exits on wicks."/></ToolTip>
                                        </TextBox.ToolTip>
                                    </TextBox>
                                    <TextBox Grid.Row="2" Grid.Column="3"
                                             Text="{Binding MinBarsBeforeExit, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding IsNotRunning}">
                                        <TextBox.ToolTip>
                                            <ToolTip><TextBlock TextWrapping="Wrap" MaxWidth="260" FontSize="13"
                                                Text="The structure-fail check is suppressed for this many bars after entry. Prevents getting shaken out by normal initial volatility before the trade has had time to develop."/></ToolTip>
                                        </TextBox.ToolTip>
                                    </TextBox>
                                    <CheckBox Grid.Row="2" Grid.Column="6"
                                              IsChecked="{Binding EnableStructureFailExit}"
                                              VerticalAlignment="Center"
                                              IsEnabled="{Binding IsNotRunning}"
                                              Foreground="{StaticResource TextSecondaryBrush}">
                                        <CheckBox.ToolTip>
                                            <ToolTip><TextBlock TextWrapping="Wrap" MaxWidth="260" FontSize="13"
                                                Text="When enabled, all open positions are flattened immediately if price closes through EMA21 by more than the configured tick buffer after the minimum bar count. Useful for cutting losses on failed breakouts quickly."/></ToolTip>
                                        </CheckBox.ToolTip>
                                    </CheckBox>
                                </Grid>

                            </StackPanel>
                        </Border>

                        <!-- ── Live Status ── -->
                        <Border Background="{StaticResource SurfaceBrush}"
                                CornerRadius="6" Padding="16,12" Margin="0,10,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Position -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="POSITION" FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                                    <TextBlock Text="{Binding PositionDisplay}"
                                               FontFamily="Consolas" FontSize="15"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <!-- Avg Entry -->
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="AVG ENTRY" FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                                    <TextBlock Text="{Binding AverageEntryDisplay}"
                                               FontFamily="Consolas" FontSize="15"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <!-- Risk Heat -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="RISK HEAT" FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                                    <TextBlock Text="{Binding HeatDisplay}"
                                               FontFamily="Consolas" FontSize="15"
                                               Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>

                                <!-- Win / Loss -->
                                <StackPanel Grid.Column="3">
                                    <TextBlock Text="WIN / LOSS" FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                                    <TextBlock Text="{Binding WinLossDisplay}"
                                               FontFamily="Consolas" FontSize="15"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <!-- Session P&L -->
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="SESSION P&amp;L" FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                                    <TextBlock Text="{Binding TotalPnlDisplay}"
                                               FontFamily="Consolas" FontSize="15"
                                               Foreground="{Binding TotalPnlBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ── Signal Log ── -->
                        <Border Background="{StaticResource SurfaceBrush}"
                                CornerRadius="6" Padding="16,12" Margin="0,10,0,8">
                            <StackPanel>
                                <TextBlock Text="SIGNAL LOG"
                                           Style="{StaticResource SectionHeadingStyle}"
                                           Margin="0,0,0,8"/>
                                <ListBox x:Name="LogList"
                                         ItemsSource="{Binding LogEntries}"
                                         Height="210"
                                         Background="{StaticResource CardBrush}"
                                         BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       FontFamily="Consolas" FontSize="13"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════════════════════════════════════════════════
                 TAB 2: Sniper Backtest
                 ══════════════════════════════════════════════════════ -->
            <TabItem Header="📊  Sniper Backtest">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20,16,20,8">

                        <TextBlock Text="📊  Sniper Backtest"
                                   Style="{StaticResource PageTitleStyle}"/>

                        <!-- ── Setup ── -->
                        <Border Background="{StaticResource SurfaceBrush}"
                                CornerRadius="6" Padding="16,14" Margin="0,10,0,0">
                            <StackPanel>

                                <TextBlock Text="SETUP" Style="{StaticResource SectionHeadingStyle}" Margin="0,0,0,10"/>

                                <!-- Row: Contract + date range -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="130"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Contract"
                                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="4" Text="From"
                                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="7" Text="To"
                                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>

                                    <controls:ContractSelectorControl
                                               Grid.Row="2" Grid.Column="1"
                                               IsEnabled="{Binding IsNotBacktesting}"
                                               ContractId="{Binding BacktestContractId, Mode=TwoWay,
                                                           UpdateSourceTrigger=PropertyChanged}"/>
                                    <DatePicker Grid.Row="2" Grid.Column="4"
                                                SelectedDate="{Binding BacktestStartDate}"
                                                IsEnabled="{Binding IsNotBacktesting}"
                                                Background="{StaticResource CardBrush}"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                BorderBrush="{StaticResource BorderBrush}">
                                        <DatePicker.ToolTip>
                                            <ToolTip><TextBlock TextWrapping="Wrap" MaxWidth="260" FontSize="13"
                                                Text="Start date of the historical period to test. The Sniper will replay every 1-minute bar from this date forward."/></ToolTip>
                                        </DatePicker.ToolTip>
                                    </DatePicker>
                                    <DatePicker Grid.Row="2" Grid.Column="7"
                                                SelectedDate="{Binding BacktestEndDate}"
                                                IsEnabled="{Binding IsNotBacktesting}"
                                                Background="{StaticResource CardBrush}"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                BorderBrush="{StaticResource BorderBrush}">
                                        <DatePicker.ToolTip>
                                            <ToolTip><TextBlock TextWrapping="Wrap" MaxWidth="260" FontSize="13"
                                                Text="End date of the historical period. The backtest stops after the last bar on this date."/></ToolTip>
                                        </DatePicker.ToolTip>
                                    </DatePicker>
                                </Grid>

                                <Separator Margin="0,12,0,10" Background="{StaticResource BorderBrush}"/>

                                <!-- TP / SL row -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Take Profit (ticks)"
                                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Stop Loss (ticks)"
                                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>

                                    <TextBox Grid.Row="2" Grid.Column="0"
                                             Text="{Binding BtTpTicks, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding IsNotBacktesting}">
                                        <TextBox.ToolTip>
                                            <ToolTip><TextBlock TextWrapping="Wrap" MaxWidth="260" FontSize="13"
                                                Text="Take-profit distance in ticks from average entry for the backtest. Example: 20 ticks on MES = $25 per contract."/></ToolTip>
                                        </TextBox.ToolTip>
                                    </TextBox>
                                    <TextBox Grid.Row="2" Grid.Column="3"
                                             Text="{Binding BtSlTicks, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding IsNotBacktesting}">
                                        <TextBox.ToolTip>
                                            <ToolTip><TextBlock TextWrapping="Wrap" MaxWidth="260" FontSize="13"
                                                Text="Stop-loss distance in ticks from average entry for the backtest. Example: 10 ticks on MES = $12.50 per contract."/></ToolTip>
                                        </TextBox.ToolTip>
                                    </TextBox>
                                </Grid>

                                <Separator Margin="0,12,0,10" Background="{StaticResource BorderBrush}"/>

                                <!-- Run -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Content="▶  Run Backtest"
                                            Command="{Binding RunBacktestCommand}"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Width="150"/>

                                    <ProgressBar Grid.Column="2"
                                                 Value="{Binding BacktestProgress}"
                                                 Minimum="0" Maximum="100"
                                                 Height="6"
                                                 VerticalAlignment="Center"
                                                 Foreground="{StaticResource AccentBrush}"
                                                 Background="{StaticResource CardBrush}"
                                                 BorderThickness="0"
                                                 Visibility="{Binding IsBacktesting,
                                                             Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ── Results Summary ── -->
                        <Border Background="{StaticResource SurfaceBrush}"
                                CornerRadius="6" Padding="16,14" Margin="0,10,0,0"
                                Visibility="{Binding HasBacktestResults,
                                             Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="RESULTS" Style="{StaticResource SectionHeadingStyle}" Margin="0,0,0,12"/>

                                <UniformGrid Columns="5">
                                    <!-- Trades -->
                                    <Border Margin="0,0,6,0" Padding="0,10"
                                            Background="{StaticResource CardBrush}" CornerRadius="5">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding BtTotalTrades}"
                                                       FontSize="24" FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="Trades"
                                                       FontSize="13"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Win Rate -->
                                    <Border Margin="0,0,6,0" Padding="0,10"
                                            Background="{StaticResource CardBrush}" CornerRadius="5">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding BtWinRateDisplay}"
                                                       FontSize="24" FontWeight="Bold"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="Win Rate"
                                                       FontSize="13"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Net P&L -->
                                    <Border Margin="0,0,6,0" Padding="0,10"
                                            Background="{StaticResource CardBrush}" CornerRadius="5">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding BtNetPnlDisplay}"
                                                       FontSize="24" FontWeight="Bold"
                                                       Foreground="{Binding BtPnlBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="Net P&amp;L"
                                                       FontSize="13"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Max Drawdown -->
                                    <Border Margin="0,0,6,0" Padding="0,10"
                                            Background="{StaticResource CardBrush}" CornerRadius="5">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding BtMaxDrawdownDisplay}"
                                                       FontSize="24" FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="Max Drawdown"
                                                       FontSize="13"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Avg / Trade -->
                                    <Border Padding="0,10"
                                            Background="{StaticResource CardBrush}" CornerRadius="5">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding BtAvgPnlDisplay}"
                                                       FontSize="24" FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="Avg / Trade"
                                                       FontSize="13"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <!-- ── Trade List ── -->
                        <Border Background="{StaticResource SurfaceBrush}"
                                CornerRadius="6" Padding="16,14" Margin="0,10,0,12"
                                Visibility="{Binding HasBacktestResults,
                                             Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="TRADES" Style="{StaticResource SectionHeadingStyle}" Margin="0,0,0,10"/>

                                <DataGrid ItemsSource="{Binding BacktestTrades}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserResizeRows="False"
                                          HeadersVisibility="Column"
                                          MaxHeight="300"
                                          Background="{StaticResource CardBrush}"
                                          BorderThickness="0"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                                          RowBackground="{StaticResource CardBrush}"
                                          AlternatingRowBackground="{StaticResource SurfaceBrush}"
                                          Foreground="{StaticResource TextPrimaryBrush}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Entry" Binding="{Binding EntryTimeDisplay}" Width="90"/>
                                        <DataGridTextColumn Header="Side"  Binding="{Binding SideDisplay}"      Width="55"/>
                                        <DataGridTextColumn Header="Entry $" Binding="{Binding EntryPrice, StringFormat=F2}" Width="75"/>
                                        <DataGridTextColumn Header="Exit $"  Binding="{Binding ExitPrice, StringFormat=F2}"  Width="75"/>
                                        <DataGridTextColumn Header="Reason"  Binding="{Binding ExitReason}"     Width="60"/>
                                        <DataGridTextColumn Header="P&amp;L" Binding="{Binding PnLDisplay}"    Width="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- ══════════════════════════════════════════════════════════
             BOTTOM: Live Sniper control bar (only for Tab 1)
             ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,10"
                Visibility="{Binding IsLiveTabSelected,
                             Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="🎯  Start Sniper"
                        Command="{Binding StartCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="150"
                        IsEnabled="{Binding CanStart}"/>

                <Button Grid.Column="2"
                        Content="⏹  Stop"
                        Command="{Binding StopCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="90"
                        IsEnabled="{Binding IsRunning}"/>

                <TextBlock Grid.Column="4"
                           Text="{Binding FreeRideDisplay}"
                           VerticalAlignment="Center"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{Binding FreeRideBrush}"/>
            </Grid>
        </Border>

    </Grid>
</UserControl>
