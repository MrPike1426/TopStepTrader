<UserControl x:Class="TopStepTrader.UI.Views.HydraView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <!--
        Layout: scrollable settings + asset boxes + log (top, fills all space)
                control bar (bottom, auto height).
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- settings panels -->
            <RowDefinition Height="3*"/>    <!-- indicator grid -->
            <RowDefinition Height="2*"/>    <!-- log fills remaining space -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             TOP: Scrollable settings area
             ══════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,12,16,8">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>  <!-- page title -->
                        <ColumnDefinition Width="16"/>    <!-- gap -->
                        <ColumnDefinition Width="*"/>     <!-- active strategy pill -->
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="🐙  Hydra - Multi-Asset, Single Strategy"
                               Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Grid.Column="2"
                               Text="{Binding ActiveStrategyText}"
                               Foreground="{StaticResource AccentBrush}"
                               FontFamily="Consolas" FontSize="11"
                               VerticalAlignment="Bottom" Margin="0,0,0,4"
                               TextTrimming="CharacterEllipsis"/>
                </Grid>

                <!-- ── Panel 1: Account / Profile / Controls — single compact bar ── -->
                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Padding="12,8" Margin="0,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>  <!-- Account: label -->
                            <ColumnDefinition Width="160"/>   <!-- Account ComboBox -->
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>  <!-- Lewis -->
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="Auto"/>  <!-- Damian -->
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="Auto"/>  <!-- Joe -->
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>  <!-- Conf%: label -->
                            <ColumnDefinition Width="52"/>    <!-- Conf% box -->
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>  <!-- Force Close?: -->
                            <ColumnDefinition Width="Auto"/>  <!-- Yes/No radios -->
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>  <!-- $Amt: -->
                            <ColumnDefinition Width="70"/>    <!-- $Amt box -->
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>  <!-- Start -->
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>  <!-- Stop -->
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Account:"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,8,0"/>

                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding Accounts}"
                                  SelectedItem="{Binding SelectedAccount}"
                                  FontSize="13" Height="28"
                                  Style="{StaticResource UnclippedComboBoxStyle}"
                                  ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"
                                  ToolTip="Select the combine account to trade with">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Foreground="White" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <!-- Lewis pill -->
                        <Button Grid.Column="3" Command="{Binding SelectProfileCommand}" CommandParameter="Lewis">
                            <Button.ToolTip>
                                <ToolTip>
                                    <StackPanel Width="240">
                                        <TextBlock Text="🛡  Lewis — Risk Averse"
                                                   FontWeight="Bold" FontSize="13" Foreground="#4CAF50"
                                                   Margin="0,0,0,6"/>
                                        <TextBlock Text="Patient entries. Only trades the strongest, most confirmed trends."
                                                   FontStyle="Italic" TextWrapping="Wrap" Opacity="0.8"
                                                   Margin="0,0,0,8"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition/><RowDefinition/><RowDefinition/>
                                                <RowDefinition/><RowDefinition/><RowDefinition/>
                                                <RowDefinition/><RowDefinition/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Capital per trade"   Opacity="0.7"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="$200 × 5× = $1,000 notional" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Stop loss (N-multiple)"  Opacity="0.7" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="1.5× N  (lev CFD: 2.5× N)" FontWeight="SemiBold" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Take profit (N-multiple)" Opacity="0.7" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="3.0× N" FontWeight="SemiBold" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="ATR trail step"           Opacity="0.7" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" Text="0.5× N per advance"       FontWeight="SemiBold" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="ADX trend gate"           Opacity="0.7" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="4" Grid.Column="1" Text="≥ 25 (strong trends only)" FontWeight="SemiBold" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Min signal confidence"    Opacity="0.7" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="5" Grid.Column="1" Text="75 %" FontWeight="SemiBold" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Max scale-ins"            Opacity="0.7" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="6" Grid.Column="1" Text="1  (2 positions total)"   FontWeight="SemiBold" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Risk:reward"              Opacity="0.7" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="7" Grid.Column="1" Text="1 : 2"                    FontWeight="SemiBold" Margin="0,3,0,0"/>
                                        </Grid>
                                    </StackPanel>
                                </ToolTip>
                            </Button.ToolTip>
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ProfileButtonStyle}">
                                    <Setter Property="BorderBrush" Value="#4CAF50"/>
                                    <Setter Property="Padding"     Value="10,4"/>
                                    <Setter Property="FontSize"    Value="12"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLewisSelected}" Value="True">
                                            <Setter Property="Background"      Value="#228B22"/>
                                            <Setter Property="BorderThickness" Value="2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="🛡  Lewis" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Button>

                        <!-- Damian pill -->
                        <Button Grid.Column="5" Command="{Binding SelectProfileCommand}" CommandParameter="Damian">
                            <Button.ToolTip>
                                <ToolTip>
                                    <StackPanel Width="240">
                                        <TextBlock Text="⚖  Damian — Moderate"
                                                   FontWeight="Bold" FontSize="13" Foreground="#90A4AE"
                                                   Margin="0,0,0,6"/>
                                        <TextBlock Text="Balanced risk. Standard 1:2 risk-reward. Application default profile."
                                                   FontStyle="Italic" TextWrapping="Wrap" Opacity="0.8"
                                                   Margin="0,0,0,8"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition/><RowDefinition/><RowDefinition/>
                                                <RowDefinition/><RowDefinition/><RowDefinition/>
                                                <RowDefinition/><RowDefinition/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Capital per trade"   Opacity="0.7"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="$500 × 10× = $5,000 notional" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Stop loss (N-multiple)"  Opacity="0.7" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="1.0× N  (lev CFD: 2.0× N)" FontWeight="SemiBold" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Take profit (N-multiple)" Opacity="0.7" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="2.0× N" FontWeight="SemiBold" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="ATR trail step"           Opacity="0.7" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" Text="0.5× N per advance"       FontWeight="SemiBold" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="ADX trend gate"           Opacity="0.7" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="4" Grid.Column="1" Text="≥ 20"                    FontWeight="SemiBold" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Min signal confidence"    Opacity="0.7" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="5" Grid.Column="1" Text="65 %" FontWeight="SemiBold" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Max scale-ins"            Opacity="0.7" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="6" Grid.Column="1" Text="2  (3 positions total)"   FontWeight="SemiBold" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Risk:reward"              Opacity="0.7" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="7" Grid.Column="1" Text="1 : 2"                    FontWeight="SemiBold" Margin="0,3,0,0"/>
                                        </Grid>
                                    </StackPanel>
                                </ToolTip>
                            </Button.ToolTip>
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ProfileButtonStyle}">
                                    <Setter Property="BorderBrush" Value="#90A4AE"/>
                                    <Setter Property="Padding"     Value="10,4"/>
                                    <Setter Property="FontSize"    Value="12"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDamianSelected}" Value="True">
                                            <Setter Property="Background"      Value="#228B22"/>
                                            <Setter Property="BorderThickness" Value="2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="⚖  Damian" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Button>

                        <!-- Joe pill -->
                        <Button Grid.Column="7" Command="{Binding SelectProfileCommand}" CommandParameter="Joe">
                            <Button.ToolTip>
                                <ToolTip>
                                    <StackPanel Width="240">
                                        <TextBlock Text="🔥  Joe — Aggressive"
                                                   FontWeight="Bold" FontSize="13" Foreground="#EF5350"
                                                   Margin="0,0,0,6"/>
                                        <TextBlock Text="High frequency. Tight brackets capture shorter moves with more bracket advances."
                                                   FontStyle="Italic" TextWrapping="Wrap" Opacity="0.8"
                                                   Margin="0,0,0,8"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition/><RowDefinition/><RowDefinition/>
                                                <RowDefinition/><RowDefinition/><RowDefinition/>
                                                <RowDefinition/><RowDefinition/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Capital per trade"   Opacity="0.7"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="$1,000 × 10× = $10,000 notional" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Stop loss (N-multiple)"  Opacity="0.7" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="1.5× N  (lev CFD: 3.0× N)" FontWeight="SemiBold" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Take profit (N-multiple)" Opacity="0.7" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="2.0× N" FontWeight="SemiBold" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="ATR trail step"           Opacity="0.7" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" Text="0.5× N per advance"       FontWeight="SemiBold" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="ADX trend gate"           Opacity="0.7" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="4" Grid.Column="1" Text="≥ 15 (wider entry window)" FontWeight="SemiBold" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Min signal confidence"    Opacity="0.7" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="5" Grid.Column="1" Text="55 %" FontWeight="SemiBold" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Max scale-ins"            Opacity="0.7" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="6" Grid.Column="1" Text="3  (4 positions total)"   FontWeight="SemiBold" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Risk:reward"              Opacity="0.7" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="7" Grid.Column="1" Text="1 : 1.3"                  FontWeight="SemiBold" Margin="0,3,0,0"/>
                                        </Grid>
                                    </StackPanel>
                                </ToolTip>
                            </Button.ToolTip>
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ProfileButtonStyle}">
                                    <Setter Property="BorderBrush" Value="#EF5350"/>
                                    <Setter Property="Padding"     Value="10,4"/>
                                    <Setter Property="FontSize"    Value="12"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsJoeSelected}" Value="True">
                                            <Setter Property="Background"      Value="#228B22"/>
                                            <Setter Property="BorderThickness" Value="2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="🔥  Joe" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Button>

                        <!-- Confidence % -->
                        <TextBlock Grid.Column="9" Text="Conf%:"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"
                                   ToolTip="Minimum weighted score 0–100 required to fire a signal across all 5 assets"/>
                        <TextBox Grid.Column="10"
                                 Text="{Binding MinConfidencePct, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center" Height="26"
                                 ToolTip="Set by the active risk profile (Lewis=90, Damian=80, Joe=70). Override here if needed"/>

                        <!-- Force Close -->
                        <TextBlock Grid.Column="12" Text="Force Close?:"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <StackPanel Grid.Column="13" Orientation="Horizontal" VerticalAlignment="Center">
                            <RadioButton Content="Yes" GroupName="ForceClose"
                                         IsChecked="{Binding ForceCloseEnabled, Mode=TwoWay}"
                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <RadioButton Content="No" GroupName="ForceClose"
                                         IsChecked="{Binding ForceCloseEnabled, Converter={StaticResource BoolInverseConverter}, Mode=TwoWay}"
                                         VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Grid.Column="15" Text="$Amt:"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Grid.Column="16"
                                 Text="{Binding ForceCloseAmount, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center" Height="26"
                                 ToolTip="If Force Close = Yes, any live position with unrealised P&amp;L ≥ this amount will be closed immediately."/>

                        <!-- Start / Stop -->
                        <Button Grid.Column="18"
                                Content="▶  Start"
                                Command="{Binding StartCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Width="90" Height="28"
                                IsEnabled="{Binding IsNotRunning}"
                                ToolTip="Start all 5 asset monitoring sessions concurrently"/>
                        <Button Grid.Column="20"
                                Content="■  Stop All"
                                Command="{Binding StopCommand}"
                                Style="{StaticResource DangerButtonStyle}"
                                Width="80" Height="28"
                                ToolTip="Stop all 5 running asset sessions"/>
                    </Grid>
                </Border>

                <!-- ── ATR Risk Tier ─────────────────────────────────── -->
                <!-- Controls SL/TP bracket width in ATR multiples.
                     Independent of persona — persona sets capital/leverage/confidence/scale-ins;
                     ATR tier sets how many ATR units the SL/TP brackets span (elasticity). -->
                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Padding="12,6" Margin="0,4,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="ATR Tier:"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"
                                   ToolTip="Controls SL/TP bracket width as ATR multiples. All tiers maintain 1:2 R:R."/>

                        <!-- Tight tier -->
                        <Button Command="{Binding SelectAtrTierCommand}" CommandParameter="Tight"
                                Margin="0,0,4,0"
                                ToolTip="Tight: SL=0.75×ATR, TP=1.5×ATR. Narrowest brackets — more signals, tighter stops.">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ProfileButtonStyle}">
                                    <Setter Property="MinWidth" Value="70"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAtrTightSelected}" Value="True">
                                            <Setter Property="Background" Value="#8B4513"/>
                                            <Setter Property="BorderThickness" Value="2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="📏  Tight" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Button>

                        <!-- Standard tier -->
                        <Button Command="{Binding SelectAtrTierCommand}" CommandParameter="Standard"
                                Margin="0,0,4,0"
                                ToolTip="Standard: SL=1.5×ATR, TP=3.0×ATR. Balanced brackets (Lewis-equivalent defaults).">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ProfileButtonStyle}">
                                    <Setter Property="MinWidth" Value="70"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAtrStandardSelected}" Value="True">
                                            <Setter Property="Background" Value="#228B22"/>
                                            <Setter Property="BorderThickness" Value="2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="📐  Standard" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Button>

                        <!-- Wide tier -->
                        <Button Command="{Binding SelectAtrTierCommand}" CommandParameter="Wide"
                                ToolTip="Wide: SL=2.5×ATR, TP=5.0×ATR. Widest brackets — fewer whipsaws, patient exits.">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ProfileButtonStyle}">
                                    <Setter Property="MinWidth" Value="70"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAtrWideSelected}" Value="True">
                                            <Setter Property="Background" Value="#1A237E"/>
                                            <Setter Property="BorderThickness" Value="2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="🔭  Wide" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Button>

                        <!-- Current multiples display -->
                        <TextBlock Margin="16,0,0,0" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="16"
                                   FontFamily="Consolas">
                            <Run Text="SL "/>
                            <Run Text="{Binding SlMultipleOfN, StringFormat='{}{0:F2}×'}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"/>
                            <Run Text="  TP "/>
                            <Run Text="{Binding TpMultipleOfN, StringFormat='{}{0:F2}×'}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"/>
                            <Run Text="  ATR"/>
                        </TextBlock>

                        <!-- Extend TP on close -->
                        <CheckBox Margin="16,0,0,0" VerticalAlignment="Center"
                                  IsChecked="{Binding ExtendTpOnClose, Mode=TwoWay}"
                                  ToolTip="When a bar closes at or beyond the TP, advance the target by one TpMultiple × ATR (up to 3 times). Lets winning trades run further.">
                            <TextBlock Text="Extend TP on close" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                        </CheckBox>

                        <!-- STRAT-30: Regime override dropdowns -->
                        <Border Width="1" Height="16" Margin="10,0"
                                Background="{StaticResource BorderBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="Trending→" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"
                                   ToolTip="STRAT-30: Override strategy used in trending markets (expanding ATR + ADX above threshold). Off = disabled."/>
                        <ComboBox ItemsSource="{Binding AvailableRegimeOverrides}"
                                  SelectedItem="{Binding SelectedTrendingOverrideName, Mode=TwoWay}"
                                  Width="130" Height="22" FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0"
                                  ToolTip="Strategy to use when regime = Trending. Both dropdowns must be set to activate the regime filter."/>
                        <TextBlock Text="Ranging→" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"
                                   ToolTip="STRAT-30: Override strategy used in ranging markets (contracting ATR or ADX below threshold). Off = disabled."/>
                        <ComboBox ItemsSource="{Binding AvailableRegimeOverrides}"
                                  SelectedItem="{Binding SelectedRangingOverrideName, Mode=TwoWay}"
                                  Width="130" Height="22" FontSize="10" VerticalAlignment="Center"
                                  ToolTip="Strategy to use when regime = Ranging. Both dropdowns must be set to activate the regime filter."/>

                        <!-- Vertical separator -->
                        <Border Width="1" Height="16" Margin="14,0"
                                Background="{StaticResource BorderBrush}" VerticalAlignment="Center"/>

                        <!-- Bars-updated status label — flashes bold white for 0.5 s on each update -->
                        <TextBlock Text="{Binding BarsUpdatedText}" FontFamily="Consolas" FontSize="11"
                                   VerticalAlignment="Center"
                                   ToolTip="Timestamp of the last successful bar refresh across all monitored assets.">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                    <Setter Property="FontWeight" Value="Normal"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBarsUpdatedFlashing}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ── Panel 2: Strategy Selection ──────────────────── -->
                <!-- Collapses once monitoring starts; reappears when stopped -->
                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Padding="12,8" Margin="0,6,0,0"
                        Visibility="{Binding IsNotRunning, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>

                        <!-- Remove 'Select a strategy' label and move buttons up -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>     <!-- active strategy text -->
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding ActiveStrategyText}"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontFamily="Consolas" FontSize="13"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>

                        <!-- Strategy selection — 2 rows of 4.
                             Card content is defined once in Styles/StrategyCards.xaml
                             and referenced here via ContentControl Template. -->

                        <!-- ── Row 1 ────────────────────────────────────────── -->
                        <UniformGrid Columns="4" Margin="0,0,0,0">

                            <!-- 1. EMA/RSI Combined -->
                            <Button Command="{Binding SelectEmaRsiCombinedCommand}"
                                    Margin="0,0,6,0"
                                    ToolTip="6-signal weighted EMA/RSI strategy applied to all 5 assets concurrently. Fires Long/Short when score ≥ Confidence % threshold.">
                                <Button.Style>
                                    <Style BasedOn="{StaticResource StrategyCardStyle}" TargetType="Button">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEmaRsiActive}" Value="True">
                                                <Setter Property="Background"      Value="{StaticResource NavSelectedBrush}"/>
                                                <Setter Property="BorderBrush"     Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <ContentControl Template="{StaticResource EmaRsiCardContent}"/>
                            </Button>

                            <!-- 2. Multi-Confluence Engine -->
                            <Button Command="{Binding SelectMultiConfluenceEngineCommand}"
                                    Margin="0,0,6,0"
                                    ToolTip="All 7 conditions must align: Ichimoku Cloud, EMA21, Tenkan/Kijun, Lagging Span, ADX &gt; 25 + DI, MACD histogram, StochRSI gate. SL = min(1.5×ATR, cloud edge); TP = 2:1 R:R. 15-min commodity bars.">
                                <Button.Style>
                                    <Style BasedOn="{StaticResource StrategyCardStyle}" TargetType="Button">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMultiConfluenceActive}" Value="True">
                                                <Setter Property="Background"      Value="{StaticResource NavSelectedBrush}"/>
                                                <Setter Property="BorderBrush"     Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <ContentControl Template="{StaticResource MultiConfluenceCardContent}"/>
                            </Button>

                            <!-- 3. LULT Divergence -->
                            <Button Command="{Binding SelectLultDivergenceCommand}"
                                    Margin="0,0,6,0"
                                    ToolTip="6-step momentum divergence (Market Cipher B simulation): Anchor wave (WT ≷ ±60) → Trigger wave (shallower — reset if deeper) → price divergence → Green/Red Dot (WT1×WT2 cross) → engulfing candle. NQ 5-min bars · 07:00–11:00 EST · SL at trigger extreme · TP = 2R.">
                                <Button.Style>
                                    <Style BasedOn="{StaticResource StrategyCardStyle}" TargetType="Button">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLultActive}" Value="True">
                                                <Setter Property="Background"      Value="{StaticResource NavSelectedBrush}"/>
                                                <Setter Property="BorderBrush"     Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <ContentControl Template="{StaticResource LultDivergenceCardContent}"/>
                            </Button>

                            <!-- 4. BB Squeeze Scalper -->
                            <Button Command="{Binding SelectBbSqueezeScalperCommand}"
                                    Margin="0"
                                    ToolTip="Dual-mode BB scalper — Mode A: Squeeze Breakout (BBW &lt; SMA(BBW,20) for ≥3 bars then close breaks outer band, EMA5 slope + RSI7 confirm) · Mode B: Band Bounce (%B &lt; 0 or &gt; 1, RSI7 extreme, rejection wick ≥60%). 1-min bars · 15s polling.">
                                <Button.Style>
                                    <Style BasedOn="{StaticResource StrategyCardStyle}" TargetType="Button">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBbSqueezeActive}" Value="True">
                                                <Setter Property="Background"      Value="{StaticResource NavSelectedBrush}"/>
                                                <Setter Property="BorderBrush"     Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <ContentControl Template="{StaticResource BbSqueezeCardContent}"/>
                            </Button>

                        </UniformGrid>

                        <!-- ── Row 2 ────────────────────────────────────────── -->
                        <UniformGrid Columns="4" Margin="0,6,0,0">

                            <!-- 5. VIDYA Cross -->
                            <Button Command="{Binding SelectVidyaCommand}"
                                    Margin="0,0,6,0"
                                    ToolTip="VIDYA Cross — Variable Index Dynamic Average adaptive EMA. Dynamic alpha = EMA-alpha × |CMO(9)|. Fast in trends, near-flat in chop. Long on close crossing above VIDYA; Short on close crossing below. 5-min bars.">
                                <Button.Style>
                                    <Style BasedOn="{StaticResource StrategyCardStyle}" TargetType="Button">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsVidyaActive}" Value="True">
                                                <Setter Property="Background"      Value="{StaticResource NavSelectedBrush}"/>
                                                <Setter Property="BorderBrush"     Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <ContentControl Template="{StaticResource VidyaCrossCardContent}"/>
                            </Button>

                            <!-- 6. Naked Trader -->
                            <Button Command="{Binding SelectNakedTraderCommand}"
                                    Margin="0,0,6,0"
                                    ToolTip="4-vote consensus: EMA(9/21) + MACD(8,17,9) + DMI/ADX(14) + VWAP on 5-min bars. Fires on Medium (3/4 votes, ADX≥20) or High (all votes, ADX≥25+vol) confidence. Low confidence stays flat.">
                                <Button.Style>
                                    <Style BasedOn="{StaticResource StrategyCardStyle}" TargetType="Button">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsNakedTraderActive}" Value="True">
                                                <Setter Property="Background"      Value="{StaticResource NavSelectedBrush}"/>
                                                <Setter Property="BorderBrush"     Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <ContentControl Template="{StaticResource NakedTraderCardContent}"/>
                            </Button>

                            <!-- 7. Double Bubble Butt -->
                            <Button Command="{Binding SelectDoubleBubbleButtCommand}"
                                    Margin="0,0,6,0"
                                    ToolTip="Double Bollinger Band (Kathy Lien): BB(20,1.0 SD) inner + BB(20,2.0 SD) outer define Buy/Sell/Neutral zones. Long when close enters Buy Zone (above upper 1.0 SD). Short when close enters Sell Zone (below lower 1.0 SD). Exit when price returns to Neutral Zone.">
                                <Button.Style>
                                    <Style BasedOn="{StaticResource StrategyCardStyle}" TargetType="Button">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDoubleBubbleButtActive}" Value="True">
                                                <Setter Property="Background"      Value="{StaticResource NavSelectedBrush}"/>
                                                <Setter Property="BorderBrush"     Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <ContentControl Template="{StaticResource DoubleBubbleButtCardContent}"/>
                            </Button>

                            <!-- 8. Placeholder -->
                            <Button IsEnabled="False" Margin="0"
                                    Style="{StaticResource StrategyCardStyle}">
                                <ContentControl Template="{StaticResource PlaceholderCardContent}"/>
                            </Button>

                        </UniformGrid>

                    </StackPanel>
                </Border>

                <!-- ── Panel 3: Asset Status — 5 column cards ──────── -->
                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Padding="20,14" Margin="0,4,0,0">
                    <StackPanel>



                        <!-- 5 equal-width columns, one per asset -->
                        <ItemsControl ItemsSource="{Binding Assets}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Top-accent card — dark green bg on high-confidence open positions -->
                                    <Border Background="{Binding TileBackground}"
                                            CornerRadius="6"
                                            Margin="0,0,6,0"
                                            BorderThickness="0,3,0,0"
                                            BorderBrush="{Binding StatusBorderBrush}">
                                        <!-- FontSize=10 cascades to all text; ForestGreen cascades when tradeable -->
                                        <StackPanel Margin="8,8,8,8"
                                                    HorizontalAlignment="Center"
                                                    TextElement.FontSize="10"
                                                    TextElement.Foreground="{Binding CardForeground}">

                                            <!-- Icon + Symbol name inline -->
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding Icon, Mode=OneWay}"
                                                       FontSize="14" FontWeight="Normal"/>
                                            <TextBlock Text="{Binding Symbol, Mode=OneWay}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Margin="4,0,0,0"/>
                                            </StackPanel>

                                            <!-- Divider -->
                                            <Border Height="1"
                                                    Background="{StaticResource BorderBrush}"
                                                    Margin="0,6,0,6"/>

                                            <!-- Direction + confidence summary -->
                                            <TextBlock Text="{Binding SummaryLine}"
                                                       Foreground="{Binding DirectionForeground}"
                                                       FontFamily="Consolas"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"/>

                                            <!-- Live position / P&L — shown first (most time-critical when in a trade) -->
                                            <TextBlock Text="{Binding TradeStatusLine}"
                                                       FontFamily="Consolas"
                                                       FontSize="11"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Foreground="{Binding TradeStatusForeground}"
                                                       Margin="0,5,0,0"
                                                       ToolTip="Live position status: entry price, size, and unrealised P&amp;L. Updates every 30 s via broker API. Turtle bracket SL advances on each TP hit."/>

                                            <!-- Turtle bracket confirmation (timestamp of last advance) -->
                                            <TextBlock Text="{Binding TurtleStatusLine}"
                                                       FontFamily="Consolas"
                                                       FontSize="10"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       Foreground="#FFFF9500"
                                                       Margin="0,3,0,0"
                                                       Visibility="{Binding HasTurtleStatus, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                            <!-- Current bracket SL and TP prices -->
                                            <TextBlock Text="{Binding BracketPriceDisplay}"
                                                       FontFamily="Consolas"
                                                       FontSize="11"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       Foreground="#FFFF9500"
                                                       Margin="0,1,0,0"
                                                       ToolTip="Current Turtle bracket stop-loss and take-profit price levels."
                                                       Visibility="{Binding HasBracketPrices, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                            <!-- Free Ride badge: shown when SL has advanced past break-even -->
                                            <TextBlock Text="✅ Free Ride"
                                                       FontFamily="Consolas"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       Foreground="#FF228B22"
                                                       Margin="0,3,0,0"
                                                       ToolTip="Stop-loss is above entry price — this trade is guaranteed to close in profit."
                                                       Visibility="{Binding IsFreeRide, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                            <!-- Per-asset bracket controls — shown only when a position is open -->
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        Margin="0,6,0,0"
                                                        Visibility="{Binding HasOpenPosition, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <Button Content="⟳ Nudge SL"
                                                        Command="{Binding NudgeBracketCommand}"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        Padding="5,2"
                                                        FontSize="10"
                                                        Margin="0,0,4,0"
                                                        ToolTip="Tighten the resting stop-loss by 10% of its distance to entry (minimum 1 tick)."/>
                                                <Button Content="✕ Close"
                                                        Command="{Binding CloseCommand}"
                                                        Style="{StaticResource DangerButtonStyle}"
                                                        Padding="5,2"
                                                        FontSize="10"
                                                        ToolTip="Cancel all bracket orders and close this position immediately."/>
                                            </StackPanel>

                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </Border>

                <!-- ── Panel 4: Strategy Description — hidden once running ── -->
                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Padding="14,10" Margin="0,4,0,0"
                        Visibility="{Binding IsStrategyDescriptionVisible,
                                     Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="{Binding StrategyDescriptionHeading}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <TextBox Text="{Binding StrategyDescription, Mode=OneWay}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 FontSize="13"
                                 Padding="0,0,0,2"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 ToolTip="Click a strategy card above to see its description. Disappears when monitoring starts."/>
                    </StackPanel>
                </Border>

                            </StackPanel>
                        </ScrollViewer>

                        <!-- ── Indicator Grid — one live row per asset ─────────────────────── -->
                        <Border Grid.Row="1"
                                Background="{StaticResource SidebarBrush}"
                                CornerRadius="6" Margin="24,4,24,8" Padding="8,6">
                            <Grid>

                                <!-- ══ EMA/RSI Combined Grid ══════════════════════════════════════════ -->
                                <DataGrid ItemsSource="{Binding Assets}"
                                          Visibility="{Binding IsEmaRsiActive, Converter={StaticResource BoolToVisibilityConverter}}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserSortColumns="False"
                                          CanUserResizeRows="False"
                                          RowHeight="45"
                                          Background="Transparent"
                                          BorderThickness="2"
                                          FontFamily="Consolas" FontSize="12"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background"      Value="#FF1A2845"/>
                                            <Setter Property="Foreground"      Value="{StaticResource TextSecondaryBrush}"/>
                                            <Setter Property="FontFamily"      Value="Segoe UI"/>
                                            <Setter Property="FontSize"        Value="9"/>
                                            <Setter Property="FontWeight"      Value="SemiBold"/>
                                            <Setter Property="Padding"         Value="6,5"/>
                                            <Setter Property="BorderBrush"     Value="#FF2E3F6E"/>
                                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                            <Setter Property="ContentTemplate">
                                                <Setter.Value>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}"
                                                                   TextWrapping="Wrap"
                                                                   FontFamily="Segoe UI"
                                                                   FontSize="9"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </DataTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Background"               Value="Transparent"/>
                                            <Setter Property="BorderThickness"          Value="0"/>
                                            <Setter Property="Padding"                  Value="0"/>
                                            <Setter Property="Foreground"               Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="VerticalContentAlignment" Value="Top"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#1A4A9FFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.Columns>
                                        <!-- Asset -->
                                        <DataGridTextColumn Header="Asset"  Binding="{Binding Symbol}"      Width="60"/>
                                        <!-- Time -->
                                        <DataGridTextColumn Header="Time"   Binding="{Binding LastUpdated}" Width="72"/>
                                        <!-- Close -->
                                        <DataGridTextColumn Header="Close"  Binding="{Binding GridClose}"   Width="76"/>
                                        <!-- EMA21 / EMA50 (stacked) -->
                                        <DataGridTemplateColumn Header="EMA21 | EMA50" Width="82">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="6,4" HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding GridEma21}" FontFamily="Consolas" FontSize="12"/>
                                                        <TextBlock Text="{Binding GridEma50}" FontFamily="Consolas" FontSize="12"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <!-- RSI14 -->
                                        <DataGridTextColumn Header="RSI14"  Binding="{Binding GridRsi14}"   Width="55"/>
                                        <!-- ADX -->
                                        <DataGridTextColumn Header="ADX"    Binding="{Binding GridAdx}"     Width="50"/>
                                        <!-- DI+ / DI- (stacked, colour coded) -->
                                        <DataGridTemplateColumn Header="DI + / -" Width="50">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="6,4" HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding GridDiPlus}"  FontFamily="Consolas" FontSize="12"
                                                                   Foreground="{StaticResource BuyBrush}"/>
                                                        <TextBlock Text="{Binding GridDiMinus}" FontFamily="Consolas" FontSize="12"
                                                                   Foreground="{StaticResource SellBrush}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <!-- Bull% / Bear% (stacked) -->
                                        <DataGridTemplateColumn Header="Bull% / Bear%" Width="76">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="6,4" HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding UpPct,   StringFormat='{}{0}%'}" FontFamily="Consolas" FontSize="12"
                                                                   Foreground="{StaticResource BuyBrush}"/>
                                                        <TextBlock Text="{Binding DownPct, StringFormat='{}{0}%'}" FontFamily="Consolas" FontSize="12"
                                                                   Foreground="{StaticResource SellBrush}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <!-- Conf -->
                                        <DataGridTextColumn Header="Conf"   Binding="{Binding GridConf}"    Width="90"/>
                                        <!-- Explain -->
                                        <DataGridTemplateColumn Header="Explain" Width="*" MinWidth="260">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding GridExplain}"
                                                               FontFamily="Consolas" FontSize="10"
                                                               TextWrapping="Wrap"
                                                               Margin="6,4"
                                                               VerticalAlignment="Top"
                                                               ToolTip="{Binding GridExplain}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- ══ Multi-Confluence Grid ═══════════════════════════════════════════ -->
                                <DataGrid ItemsSource="{Binding Assets}"
                                          Visibility="{Binding IsMultiConfluenceActive, Converter={StaticResource BoolToVisibilityConverter}}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserSortColumns="False"
                                          CanUserResizeRows="False"
                                          RowHeight="48"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          FontFamily="Consolas" FontSize="12"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background"      Value="#FF1A2845"/>
                                            <Setter Property="Foreground"      Value="{StaticResource TextSecondaryBrush}"/>
                                            <Setter Property="FontFamily"      Value="Segoe UI"/>
                                            <Setter Property="FontSize"        Value="9"/>
                                            <Setter Property="FontWeight"      Value="SemiBold"/>
                                            <Setter Property="Padding"         Value="6,5"/>
                                            <Setter Property="BorderBrush"     Value="#FF2E3F6E"/>
                                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                            <Setter Property="ContentTemplate">
                                                <Setter.Value>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}"
                                                                   TextWrapping="Wrap"
                                                                   FontFamily="Segoe UI"
                                                                   FontSize="9"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </DataTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Background"               Value="Transparent"/>
                                            <Setter Property="BorderThickness"          Value="0"/>
                                            <Setter Property="Padding"                  Value="2"/>
                                            <Setter Property="Foreground"               Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="VerticalContentAlignment" Value="Top"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#1A4A9FFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.Columns>
                                        <!-- Asset -->
                                        <DataGridTextColumn Header="Asset"  Binding="{Binding Symbol}"      Width="60"/>
                                        <!-- Time -->
                                        <DataGridTextColumn Header="Time"   Binding="{Binding LastUpdated}" Width="72"/>
                                        <!-- Close -->
                                        <DataGridTextColumn Header="Close"  Binding="{Binding GridClose}"   Width="76"/>
                                        <!-- Ichi High / Ichi Low (stacked) -->
                                        <DataGridTemplateColumn Header="Ichi High&#x0A;Ichi Low" Width="80">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="6,4" HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding GridCloud1}" FontFamily="Consolas" FontSize="12"/>
                                                        <TextBlock Text="{Binding GridCloud2}" FontFamily="Consolas" FontSize="12"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <!-- T: / K: (stacked) -->
                                        <DataGridTemplateColumn Header="Tenkan:&#x0A;Kijun:" Width="80">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="6,4" HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding GridTenkan}" FontFamily="Consolas" FontSize="12"/>
                                                        <TextBlock Text="{Binding GridKijun}"  FontFamily="Consolas" FontSize="12"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <!-- EMA21: / EMA50: (stacked) -->
                                        <DataGridTemplateColumn Header="EMA21:&#x0A;EMA50:" Width="80">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="6,4" HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding GridEma21}" FontFamily="Consolas" FontSize="12"/>
                                                        <TextBlock Text="{Binding GridEma50}" FontFamily="Consolas" FontSize="12"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <!-- ADX -->
                                        <DataGridTextColumn Header="ADX:"  Binding="{Binding GridAdx}"   Width="50"/>
                                        <!-- DI+ / DI- (stacked, colour coded) -->
                                        <DataGridTemplateColumn Header="DI+&#x0A;DI-" Width="50">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="6,4" HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding GridDiPlus}"  FontFamily="Consolas" FontSize="12"
                                                                   Foreground="{StaticResource BuyBrush}"/>
                                                        <TextBlock Text="{Binding GridDiMinus}" FontFamily="Consolas" FontSize="12"
                                                                   Foreground="{StaticResource SellBrush}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <!-- MACD / MACD Prev (stacked) -->
                                        <DataGridTemplateColumn Header="MACD&#x0A;MACD Prev" Width="82">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="6,4" HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding GridMacd}"     FontFamily="Consolas" FontSize="12"/>
                                                        <TextBlock Text="{Binding GridMacdPrev}" FontFamily="Consolas" FontSize="12"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <!-- Stoch RSI -->
                                        <DataGridTextColumn Header="Stoch&#x0A;RSI"  Binding="{Binding GridStochRsi}"   Width="50"/>
                                        <!-- Long x/7 -->
                                        <DataGridTextColumn Header="Long&#x0A;x/7"   Binding="{Binding GridLongScore}"  Width="46"/>
                                        <!-- Short x/7 -->
                                        <DataGridTextColumn Header="Short&#x0A;x/7"  Binding="{Binding GridShortScore}" Width="46"/>
                                        <!-- Conf -->
                                        <DataGridTextColumn Header="Conf"             Binding="{Binding GridConf}"       Width="90"/>
                                        <!-- Explain: 3-line natural-language summary of which conditions pass/fail -->
                                        <DataGridTemplateColumn Header="Explain" Width="*" MinWidth="220">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding GridExplain}"
                                                               FontFamily="Consolas" FontSize="10"
                                                               TextWrapping="Wrap"
                                                               Margin="6,4"
                                                               VerticalAlignment="Top"
                                                               ToolTip="{Binding GridExplain}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- ══ VIDYA Cross Grid ══════════════════════════════════════════════ -->
                                <DataGrid ItemsSource="{Binding Assets}"
                                          Visibility="{Binding IsVidyaGridVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserSortColumns="False"
                                          CanUserResizeRows="False"
                                          RowHeight="45"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          FontFamily="Consolas" FontSize="12"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background"      Value="#FF1A2845"/>
                                            <Setter Property="Foreground"      Value="{StaticResource TextSecondaryBrush}"/>
                                            <Setter Property="FontFamily"      Value="Segoe UI"/>
                                            <Setter Property="FontSize"        Value="9"/>
                                            <Setter Property="FontWeight"      Value="SemiBold"/>
                                            <Setter Property="Padding"         Value="6,5"/>
                                            <Setter Property="BorderBrush"     Value="#FF2E3F6E"/>
                                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                            <Setter Property="ContentTemplate">
                                                <Setter.Value>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}"
                                                                   TextWrapping="Wrap"
                                                                   FontFamily="Segoe UI"
                                                                   FontSize="9"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </DataTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Background"               Value="Transparent"/>
                                            <Setter Property="BorderThickness"          Value="0"/>
                                            <Setter Property="Padding"                  Value="0"/>
                                            <Setter Property="Foreground"               Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="VerticalContentAlignment" Value="Top"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#1A4A9FFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Asset"        Binding="{Binding Symbol}"       Width="60"/>
                                        <DataGridTextColumn Header="Time"         Binding="{Binding LastUpdated}"  Width="72"/>
                                        <DataGridTextColumn Header="Close"        Binding="{Binding GridClose}"    Width="76"/>
                                        <!-- VIDYA value + above/below indicator -->
                                        <DataGridTextColumn Header="VIDYA(14)&#x0A;▲/▼ pos" Binding="{Binding GridVidya}" Width="90"/>
                                        <!-- CMO(9) momentum -->
                                        <DataGridTextColumn Header="CMO(9)"       Binding="{Binding GridCmo}"      Width="60"/>
                                        <!-- 6-bar delta volume -->
                                        <DataGridTextColumn Header="ΔVol&#x0A;6-bar"   Binding="{Binding GridDeltaVol}" Width="64"/>
                                        <!-- Bull% / Bear% -->
                                        <DataGridTemplateColumn Header="Bull% / Bear%" Width="76">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="6,4" HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding UpPct,   StringFormat='{}{0}%'}" FontFamily="Consolas" FontSize="12"
                                                                   Foreground="{StaticResource BuyBrush}"/>
                                                        <TextBlock Text="{Binding DownPct, StringFormat='{}{0}%'}" FontFamily="Consolas" FontSize="12"
                                                                   Foreground="{StaticResource SellBrush}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Conf"         Binding="{Binding GridConf}"     Width="90"/>
                                        <!-- Explain: cross state + gate result -->
                                        <DataGridTemplateColumn Header="Status" Width="*" MinWidth="240">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding GridExplain}"
                                                               FontFamily="Consolas" FontSize="10"
                                                               TextWrapping="Wrap"
                                                               Margin="6,4"
                                                               VerticalAlignment="Top"
                                                               ToolTip="{Binding GridExplain}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- ══ VIDYA Description (shown before Start) ════════════════════════ -->
                                <Border Visibility="{Binding IsVidyaDescriptionVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Padding="20,14">
                                    <StackPanel>
                                        <TextBlock Text="〰  VIDYA CROSS  ·  Variable Index Dynamic Average — Adaptive EMA"
                                                   FontFamily="Consolas" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>
                                        <TextBlock FontFamily="Consolas" FontSize="12"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextWrapping="Wrap" LineHeight="20">
                                            <Run Text="Entry:" FontWeight="SemiBold"/>
                                            <Run Text="  Long when price crosses ABOVE the VIDYA line · Short when price crosses BELOW"/>
                                            <LineBreak/>
                                            <Run Text="Gate:" FontWeight="SemiBold"/>
                                            <Run Text="   6-bar ΔVol must be ≥ +20% (Long) or ≤ −20% (Short) — ignores low-conviction crosses"/>
                                            <LineBreak/>
                                            <LineBreak/>
                                            <Run Text="How VIDYA adapts:" FontWeight="SemiBold"/>
                                            <LineBreak/>
                                            <Run Text="  VIDYA(14) uses CMO(9) to control its smoothing speed."/>
                                            <LineBreak/>
                                            <Run Text="  Dynamic α = EMA-α × |CMO|  →  fast in trending markets, near-flat in chop."/>
                                            <LineBreak/>
                                            <Run Text="  Self-adapts: reacts quickly when momentum is strong, barely moves when ranging."/>
                                            <LineBreak/>
                                            <LineBreak/>
                                            <Run Text="Confidence:" FontWeight="SemiBold"/>
                                            <Run Text="  |ΔVol| × 100  (e.g. 35% delta → confidence 35%)"/>
                                            <LineBreak/>
                                            <Run Text="Timeframe:" FontWeight="SemiBold"/>
                                            <Run Text="   5-min bars · 5 assets concurrently"/>
                                            <LineBreak/>
                                            <LineBreak/>
                                            <Run Text="Click  ▶ Start  to begin monitoring and activate the live indicator grid."
                                                 Foreground="#FF90A4AE"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- ══ Placeholders ══════════════════════════════════════════════════ -->
                                <!-- Shown when no strategy card has been selected yet -->
                                <TextBlock Text="Select a strategy above to view the live indicator grid."
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="13" FontFamily="Segoe UI"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Margin="0,20"
                                           Visibility="{Binding HasNoStrategySelected, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <!-- Shown when LULT or BB Squeeze is active (indicator grid not built yet) -->
                                <TextBlock Text="Indicator grid not yet available for this strategy."
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="13" FontFamily="Segoe UI"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Margin="0,20"
                                           Visibility="{Binding IsOtherStrategyActive, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            </Grid>
                        </Border>

                        <!-- ── Log Panel ────────────────────────────────────── -->
                        <Border Grid.Row="2"
                                Background="{StaticResource SidebarBrush}"
                                CornerRadius="6" Margin="24,0,24,8" Padding="8,6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="ENGINE LOG"
                                           Style="{StaticResource SectionHeadingStyle}"
                                           Margin="0,0,0,4"/>
                                <ListBox Grid.Row="1"
                                         ItemsSource="{Binding LogEntries}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         VirtualizingPanel.IsVirtualizing="True">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0,1"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Focusable" Value="False"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       FontFamily="Consolas" FontSize="11"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextWrapping="Wrap"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                    </Grid>
                </UserControl>
