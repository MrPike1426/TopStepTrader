<UserControl x:Class="TopStepTrader.UI.Views.RiskGuardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title + Refresh -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🛡️  Risk Guard" Style="{StaticResource PageTitleStyle}" Margin="0"/>
                <Button Content="↻ Refresh"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="16,0,0,0" Padding="10,4" FontSize="11"/>
            </StackPanel>

            <!-- Halt Status Banner -->
            <Border Grid.Row="2"
                    Background="{Binding HaltStatusColor, Converter={StaticResource BrushKeyConverter}}"
                    CornerRadius="6" Padding="20,16">
                <StackPanel>
                    <TextBlock Text="{Binding HaltStatusText}"
                               FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding HaltReason, StringFormat='Reason: {0}'}"
                               Foreground="#CCFFFFFF" Margin="0,4,0,0"
                               Visibility="{Binding IsHalted, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </Border>

            <!-- Metrics -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Daily P&L meter -->
                <Border Grid.Column="0" Background="{StaticResource CardBrush}" CornerRadius="6" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="DAILY P&amp;L" Style="{StaticResource SectionHeadingStyle}"/>
                        <TextBlock Text="{Binding DailyPnL, StringFormat=C0}"
                                   Style="{StaticResource MetricValueStyle}"
                                   Foreground="{Binding DailyPnLColor, Converter={StaticResource BrushKeyConverter}}"
                                   Margin="0,4,0,12"/>
                        <ProgressBar Value="{Binding DailyPnLPct}" Maximum="100" Height="12"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="$0" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Text="{Binding DailyLossLimit, StringFormat='Limit: {0:C0}'}"
                                       Style="{StaticResource LabelStyle}" HorizontalAlignment="Right"
                                       Margin="0,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding DailyLossLimit, StringFormat='Daily Loss Limit: {0:C0}'}"
                                   Style="{StaticResource LabelStyle}" Margin="0,4,0,0"
                                   Foreground="{StaticResource SellBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Drawdown meter -->
                <Border Grid.Column="2" Background="{StaticResource CardBrush}" CornerRadius="6" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="DRAWDOWN" Style="{StaticResource SectionHeadingStyle}"/>
                        <TextBlock Text="{Binding Drawdown, StringFormat=C0}"
                                   Style="{StaticResource MetricValueStyle}"
                                   Foreground="{Binding DrawdownColor, Converter={StaticResource BrushKeyConverter}}"
                                   Margin="0,4,0,12"/>
                        <ProgressBar Value="{Binding DrawdownPct}" Maximum="100" Height="12"
                                     Foreground="{Binding DrawdownColor, Converter={StaticResource BrushKeyConverter}}"/>
                        <TextBlock Text="{Binding MaxDrawdownLimit, StringFormat='Max Drawdown Limit: {0:C0}'}"
                                   Style="{StaticResource LabelStyle}" Margin="0,10,0,0"
                                   Foreground="{StaticResource SellBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Section: Manual Reset -->
            <Border Grid.Row="6" Background="{StaticResource SurfaceBrush}"
                    CornerRadius="6" Padding="20,16"
                    Visibility="{Binding IsHalted, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="MANUAL RESET — FOR TESTING ONLY"
                               Style="{StaticResource SectionHeadingStyle}"
                               Foreground="{StaticResource HaltedBrush}"/>
                    <TextBlock Text="Enter a reason (min 5 chars) to re-enable trading for this session:"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,4,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox Width="300"
                                 Text="{Binding ResetReason, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,12,0"/>
                        <Button Content="Reset Trading Halt"
                                Command="{Binding ResetHaltCommand}"
                                Style="{StaticResource DangerButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Status -->
            <TextBlock Grid.Row="8"
                       Text="{Binding StatusText}"
                       Style="{StaticResource LabelStyle}"
                       HorizontalAlignment="Right"/>

        </Grid>
    </ScrollViewer>
</UserControl>
