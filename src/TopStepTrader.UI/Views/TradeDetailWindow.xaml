<Window x:Class="TopStepTrader.UI.Views.TradeDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Width="1100" Height="700"
        WindowStartupLocation="CenterOwner"
        Background="#0D1B2A">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header band -->
        <Border Grid.Row="0" Background="#1A2A3A" CornerRadius="6" Padding="12,8">
            <TextBlock Text="{Binding HeaderLine}"
                       Foreground="White" FontSize="12" FontWeight="SemiBold"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Tabs -->
        <TabControl Grid.Row="2" Background="#0D1B2A" Foreground="White" BorderBrush="#2A3A5A">

            <TabItem Header="Orders">
                <DataGrid ItemsSource="{Binding Orders}" AutoGenerateColumns="False" IsReadOnly="True"
                          Background="#0D1B2A" Foreground="White" BorderBrush="#1E2E42"
                          RowBackground="#0D1B2A" AlternatingRowBackground="#0F1F30"
                          GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                          FontSize="12" RowHeight="24">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="OrderId" Binding="{Binding TopStepXOrderId}" Width="100"/>
                        <DataGridTextColumn Header="OrderType" Binding="{Binding OrderType}" Width="100"/>
                        <DataGridTextColumn Header="Side" Binding="{Binding Side}" Width="60"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                        <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="60"/>
                        <DataGridTextColumn Header="LimitPrice" Binding="{Binding LimitPrice}" Width="100"/>
                        <DataGridTextColumn Header="StopPrice" Binding="{Binding StopPrice}" Width="100"/>
                        <DataGridTextColumn Header="FilledPrice" Binding="{Binding FilledPrice}" Width="100"/>
                        <DataGridTextColumn Header="CreatedAt" Binding="{Binding CreatedAt}" Width="170"/>
                        <DataGridTextColumn Header="UpdatedAt" Binding="{Binding UpdatedAt}" Width="170"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Position">
                <DataGrid ItemsSource="{Binding Positions}" AutoGenerateColumns="False" IsReadOnly="True"
                          Background="#0D1B2A" Foreground="White" BorderBrush="#1E2E42"
                          RowBackground="#0D1B2A" AlternatingRowBackground="#0F1F30"
                          GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                          FontSize="12" RowHeight="24">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="PositionId" Binding="{Binding TopStepXPositionId}" Width="110"/>
                        <DataGridTextColumn Header="Side" Binding="{Binding Side}" Width="60"/>
                        <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="60"/>
                        <DataGridTextColumn Header="AvgEntryPrice" Binding="{Binding AvgEntryPrice}" Width="120"/>
                        <DataGridTextColumn Header="RealisedPnL" Binding="{Binding RealisedPnL}" Width="110"/>
                        <DataGridTextColumn Header="OpenedAt" Binding="{Binding OpenedAt}" Width="170"/>
                        <DataGridTextColumn Header="ClosedAt" Binding="{Binding ClosedAt}" Width="170"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Trades">
                <DataGrid ItemsSource="{Binding Fills}" AutoGenerateColumns="False" IsReadOnly="True"
                          Background="#0D1B2A" Foreground="White" BorderBrush="#1E2E42"
                          RowBackground="#0D1B2A" AlternatingRowBackground="#0F1F30"
                          GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                          FontSize="12" RowHeight="24">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="TradeId" Binding="{Binding TopStepXTradeId}" Width="100"/>
                        <DataGridTextColumn Header="OrderId" Binding="{Binding TopStepXOrderId}" Width="100"/>
                        <DataGridTextColumn Header="Side" Binding="{Binding Side}" Width="60"/>
                        <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="60"/>
                        <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="100"/>
                        <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="170"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Ratchet">
                <DataGrid ItemsSource="{Binding RatchetRows}" AutoGenerateColumns="False" IsReadOnly="True"
                          Background="#0D1B2A" Foreground="White" BorderBrush="#1E2E42"
                          RowBackground="#0D1B2A" AlternatingRowBackground="#0F1F30"
                          GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                          FontSize="12" RowHeight="24">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="170"/>
                        <DataGridTextColumn Header="OldStop" Binding="{Binding OldStop}" Width="100"/>
                        <DataGridTextColumn Header="NewStop" Binding="{Binding NewStop}" Width="100"/>
                        <DataGridTextColumn Header="TriggerReason" Binding="{Binding TriggerReason}" Width="140"/>
                        <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

        </TabControl>

        <!-- Bottom bar -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Run Post-Mortem"
                    Command="{Binding RunPostMortemCommand}"
                    Padding="16,6" Background="#1E5A88" Foreground="White" BorderBrush="#2A6AA0"/>

            <TextBlock Grid.Column="1"
                       Text="{Binding StatusText}"
                       Foreground="#8899BB" FontSize="11"
                       Margin="16,0" VerticalAlignment="Center"/>

            <Button Grid.Column="2"
                    Content="Close"
                    Command="{Binding CloseCommand}"
                    Padding="16,6" Background="#2A3A5A" Foreground="White" BorderBrush="#3A4A6A"/>
        </Grid>

    </Grid>
</Window>
