<UserControl x:Class="TopStepTrader.UI.Views.ScalperTestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#070C14">

    <UserControl.Resources>
        <SolidColorBrush x:Key="C_Bg"          Color="#070C14"/>
        <SolidColorBrush x:Key="C_Card"        Color="#111D30"/>
        <SolidColorBrush x:Key="C_Border"      Color="#1E3050"/>
        <SolidColorBrush x:Key="C_Blue"        Color="#00C8F0"/>
        <SolidColorBrush x:Key="C_Amber"       Color="#F0A030"/>
        <SolidColorBrush x:Key="C_Green"       Color="#00DF7A"/>
        <SolidColorBrush x:Key="C_Red"         Color="#F03355"/>
        <SolidColorBrush x:Key="C_Text"        Color="#C0D0E8"/>
        <SolidColorBrush x:Key="C_TextDim"     Color="#506080"/>

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="{StaticResource C_TextDim}"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>

        <Style TargetType="TextBox" x:Key="InputStyle">
            <Setter Property="Background"   Value="#080E1A"/>
            <Setter Property="Foreground"   Value="{StaticResource C_Text}"/>
            <Setter Property="BorderBrush"  Value="{StaticResource C_Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="6,4"/>
            <Setter Property="FontSize"     Value="13"/>
        </Style>

        <Style TargetType="ComboBox" x:Key="ComboStyle">
            <Setter Property="Background"   Value="#080E1A"/>
            <Setter Property="Foreground"   Value="{StaticResource C_Text}"/>
            <Setter Property="BorderBrush"  Value="{StaticResource C_Border}"/>
            <Setter Property="Padding"      Value="6,4"/>
            <Setter Property="FontSize"     Value="13"/>
        </Style>

        <Style TargetType="Button" x:Key="ActionBuyStyle">
            <Setter Property="Background"   Value="{StaticResource C_Green}"/>
            <Setter Property="Foreground"   Value="#001810"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="FontSize"     Value="14"/>
            <Setter Property="Padding"      Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin"       Value="0,0,8,0"/>
        </Style>
        <Style TargetType="Button" x:Key="ActionSellStyle" BasedOn="{StaticResource ActionBuyStyle}">
            <Setter Property="Background"   Value="{StaticResource C_Red}"/>
            <Setter Property="Foreground"   Value="#180005"/>
        </Style>
        <Style TargetType="Button" x:Key="ActionCloseStyle" BasedOn="{StaticResource ActionBuyStyle}">
            <Setter Property="Background"   Value="{StaticResource C_Amber}"/>
            <Setter Property="Foreground"   Value="#181000"/>
            <Setter Property="Margin"       Value="8,0,0,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="🧪 SCALPER TEST — Live Price + P&amp;L Validation"
                   Foreground="{StaticResource C_Blue}"
                   FontSize="16" FontWeight="Bold"
                   Margin="0,0,0,16"/>

        <!-- CONFIG -->
        <Border Grid.Row="1" Background="{StaticResource C_Card}"
                BorderBrush="{StaticResource C_Border}" BorderThickness="1"
                CornerRadius="4" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="ACCOUNT" Style="{StaticResource LabelStyle}"/>
                    <ComboBox Style="{StaticResource ComboStyle}"
                              ItemsSource="{Binding Accounts}"
                              SelectedItem="{Binding SelectedAccount, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                    <TextBlock Text="CONTRACT" Style="{StaticResource LabelStyle}"/>
                    <ComboBox Style="{StaticResource ComboStyle}"
                              ItemsSource="{Binding Contracts}"
                              SelectedItem="{Binding SelectedContract, Mode=TwoWay}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,8,0">
                    <TextBlock Text="SIZE (contracts)" Style="{StaticResource LabelStyle}"/>
                    <TextBox Style="{StaticResource InputStyle}" Text="{Binding Size, Mode=TwoWay}"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,8,0">
                    <TextBlock Text="SL (ticks)" Style="{StaticResource LabelStyle}"/>
                    <TextBox Style="{StaticResource InputStyle}" Text="{Binding SlTicks, Mode=TwoWay}"/>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="TP (ticks)" Style="{StaticResource LabelStyle}"/>
                    <TextBox Style="{StaticResource InputStyle}" Text="{Binding TpTicks, Mode=TwoWay}"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Grid.ColumnSpan="5"
                           Foreground="{StaticResource C_TextDim}"
                           FontSize="11" Margin="0,8,0,0"
                           Text="{Binding TickSizeHint}"/>
            </Grid>
        </Border>

        <!-- ACTIONS -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="BUY"   Style="{StaticResource ActionBuyStyle}"   Command="{Binding BuyCommand}"   MinWidth="120"/>
            <Button Content="SELL"  Style="{StaticResource ActionSellStyle}"  Command="{Binding SellCommand}"  MinWidth="120"/>
            <Button Content="CLOSE" Style="{StaticResource ActionCloseStyle}" Command="{Binding CloseCommand}" MinWidth="120"/>
            <TextBlock Text="{Binding Status}"
                       Foreground="{StaticResource C_Text}"
                       VerticalAlignment="Center"
                       Margin="20,0,0,0" FontSize="12"/>
        </StackPanel>

        <!-- LIVE PANEL -->
        <Border Grid.Row="3" Background="{StaticResource C_Card}"
                BorderBrush="{StaticResource C_Border}" BorderThickness="1"
                CornerRadius="4" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="CURRENT PRICE" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Text="{Binding CurrentPriceText}"
                               Foreground="{StaticResource C_Blue}"
                               FontSize="32" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="ENTRY PRICE" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="  📌 corrected"
                                   Foreground="{StaticResource C_Amber}"
                                   FontSize="10" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding EntryCorrected, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding EntryPriceText}"
                               Foreground="{StaticResource C_Text}"
                               FontSize="32" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="UNREALISED P&amp;L" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Text="{Binding UnrealisedPnLText}"
                               FontSize="32" FontWeight="Bold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource C_Green}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPnLPositive}" Value="False">
                                        <Setter Property="Foreground" Value="{StaticResource C_Red}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,12,0,0">
                    <TextBlock Text="Source: " Foreground="{StaticResource C_TextDim}" FontSize="11"/>
                    <TextBlock Text="{Binding PriceSource}" FontSize="11" FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource C_Blue}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PriceSource}" Value="Bar">
                                        <Setter Property="Foreground" Value="{StaticResource C_Amber}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="   |   Age: " Foreground="{StaticResource C_TextDim}" FontSize="11"/>
                    <TextBlock Text="{Binding PriceAgeMs}" Foreground="{StaticResource C_Text}" FontSize="11"/>
                    <TextBlock Text=" ms" Foreground="{StaticResource C_TextDim}" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DIAGNOSTIC LOG -->
        <Border Grid.Row="4" Background="{StaticResource C_Card}"
                BorderBrush="{StaticResource C_Border}" BorderThickness="1"
                CornerRadius="4" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,8">
                    <TextBlock Text="DIAGNOSTIC LOG" Style="{StaticResource LabelStyle}" DockPanel.Dock="Left"/>
                    <Button Content="CLEAR" Command="{Binding ClearLogCommand}"
                            Background="#080E1A" Foreground="{StaticResource C_Text}"
                            BorderBrush="{StaticResource C_Border}" Padding="8,2"
                            DockPanel.Dock="Right"/>
                </DockPanel>
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding DiagnosticLog}"
                         Background="#080E1A" Foreground="{StaticResource C_Text}"
                         BorderThickness="0"
                         FontFamily="Consolas" FontSize="11"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
