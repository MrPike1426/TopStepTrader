<UserControl x:Class="TopStepTrader.UI.Views.DebugTradeViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <Style x:Key="ActionRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding ActionType}" Value="Closed">
                    <Setter Property="Foreground" Value="#E74C3C"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ActionType}" Value="StopLossModified">
                    <Setter Property="Foreground" Value="#F39C12"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ActionType}" Value="StopLossPlaced">
                    <Setter Property="Foreground" Value="#F39C12"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ActionType}" Value="EntryFilled">
                    <Setter Property="Foreground" Value="#2ECC71"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ActionType}" Value="OrderPlaced">
                    <Setter Property="Foreground" Value="#3498DB"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page title bar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,12">
            <DockPanel>
                <TextBlock Text="&#x1F50D;  Trade Post-Mortem"
                           Style="{StaticResource PageTitleStyle}"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"/>
                <Button Content="Refresh"
                        Command="{Binding RefreshCommand}"
                        HorizontalAlignment="Right"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="14,6"
                        DockPanel.Dock="Right"/>
                <Button Content="Reconcile with TopStepX"
                        Command="{Binding ReconcileCommand}"
                        HorizontalAlignment="Right"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="14,6"
                        Margin="0,0,8,0"
                        DockPanel.Dock="Right"/>
            </DockPanel>
        </Border>

        <!-- Loading overlay -->
        <Grid Grid.Row="1"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="Loading..." HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="16"/>
        </Grid>

        <!-- Main content -->
        <Grid Grid.Row="1"
              Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" MinWidth="240"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left pane: trade list -->
            <Border Grid.Column="0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Captured Trades"
                               Style="{StaticResource SectionHeadingStyle}"
                               Margin="12,10,12,6"/>

                    <!-- Empty state -->
                    <Border Grid.Row="1"
                            Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}"
                            Padding="16" VerticalAlignment="Center">
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13"
                                   Text="{Binding StatusMessage}"/>
                    </Border>

                    <DataGrid Grid.Row="1"
                              Visibility="{Binding IsEmpty, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                              ItemsSource="{Binding Trades}"
                              SelectedItem="{Binding SelectedTrade, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              Background="Transparent"
                              RowBackground="Transparent"
                              AlternatingRowBackground="#12FFFFFF"
                              BorderThickness="0"
                              FontSize="12"
                              ColumnWidth="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Instrument" Binding="{Binding Instrument}" Width="80"/>
                            <DataGridTextColumn Header="Dir"        Binding="{Binding Direction}"  Width="45"/>
                            <DataGridTextColumn Header="Entry Time" Binding="{Binding EntryTime}"  Width="*"/>
                            <DataGridTextColumn Header="PnL"        Binding="{Binding FinalPnL}"   Width="70"/>
                            <DataGridTextColumn Header="Status"     Binding="{Binding Status}"     Width="55"/>
                            <DataGridTextColumn Header="Recon"      Binding="{Binding ReconciliationStatus}" Width="180"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="2"
                               Text="{Binding StatusMessage}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"
                               Margin="12,4,12,6"
                               TextWrapping="Wrap"
                               Visibility="{Binding IsEmpty, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                </Grid>
            </Border>

            <!-- Drag splitter -->
            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- Right pane: trade detail -->
            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="16,12,16,16">

                    <!-- No-selection placeholder -->
                    <TextBlock Text="Select a trade to inspect"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="15" Margin="0,40,0,0"
                               HorizontalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTrade}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Detail panel -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTrade}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- Header card -->
                        <Border Background="{StaticResource CardBrush}"
                                CornerRadius="6" Padding="14,12" Margin="0,0,0,12"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <!-- BUG-82 F4: incomplete-timeline chip — debug capture was off for part of this trade. -->
                                <Border Background="#3D1F1F" CornerRadius="4" Padding="10,5" Margin="0,0,0,10"
                                        HorizontalAlignment="Left"
                                        BorderBrush="#E74C3C" BorderThickness="1"
                                        Visibility="{Binding SelectedTrade.HasIncompleteTimeline, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="⚠ Capture was disabled — timeline is incomplete"
                                               Foreground="#FFB3B3" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                                <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.ColumnSpan="3" Grid.Row="0"
                                           Text="{Binding SelectedTrade.TradeId, StringFormat='Trade ID: {0}'}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11" Margin="0,0,0,8"/>

                                <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,8,4">
                                    <TextBlock Text="INSTRUMENT" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="{Binding SelectedTrade.Instrument}" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,0,8,4">
                                    <TextBlock Text="DIRECTION" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="{Binding SelectedTrade.Direction}" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Grid.Row="1" Margin="0,0,0,4">
                                    <TextBlock Text="ENTRY MODE" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="{Binding SelectedTrade.EntryMode}" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="0" Grid.Row="2" Margin="0,4,8,0">
                                    <TextBlock Text="ENTRY TIME" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="{Binding SelectedTrade.EntryTime}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Grid.Row="2" Margin="0,4,8,0">
                                    <TextBlock Text="CONTRACTS" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="{Binding SelectedTrade.ContractCount}" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Grid.Row="2" Margin="0,4,0,0">
                                    <TextBlock Text="FINAL PNL" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="{Binding SelectedTrade.FinalPnL}" FontWeight="Bold" FontSize="14" Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>
                            </Grid>
                            </StackPanel>
                        </Border>

                        <!-- AI Check card -->
                        <Border Background="{StaticResource CardBrush}"
                                CornerRadius="6" Padding="14,10" Margin="0,0,0,12"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="AI CHECK" Style="{StaticResource SectionHeadingStyle}" Margin="0,0,0,6"/>
                                <DockPanel Margin="0,2">
                                    <TextBlock Text="Result: " Foreground="{StaticResource TextSecondaryBrush}" Width="60" FontSize="12"/>
                                    <TextBlock Text="{Binding SelectedTrade.Record.AiCheckResult, FallbackValue='—'}"
                                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                                </DockPanel>
                                <DockPanel Margin="0,4">
                                    <TextBlock Text="Reason: " Foreground="{StaticResource TextSecondaryBrush}" Width="60" FontSize="12"/>
                                    <TextBlock Text="{Binding SelectedTrade.Record.AiCheckReason, FallbackValue='—'}"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <!-- SuperTrend Config (collapsible) -->
                        <Expander IsExpanded="{Binding IsConfigExpanded, Mode=TwoWay}"
                                  Margin="0,0,0,12"
                                  Foreground="{StaticResource TextPrimaryBrush}">
                            <Expander.Header>
                                <TextBlock Text="SUPERTREND CONFIG JSON"
                                           Style="{StaticResource SectionHeadingStyle}"
                                           VerticalAlignment="Center"/>
                            </Expander.Header>
                            <Border Background="{StaticResource SurfaceBrush}"
                                    CornerRadius="0,0,6,6" Padding="12,8"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,1,1">
                                <TextBox Text="{Binding ConfigJson, Mode=OneWay}"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         FontFamily="Consolas" FontSize="11"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{StaticResource TextSecondaryBrush}"
                                         MaxHeight="200"
                                         VerticalScrollBarVisibility="Auto"/>
                            </Border>
                        </Expander>

                        <!-- FEAT-56: Reconciliation summary -->
                        <Border Background="{StaticResource CardBrush}"
                                CornerRadius="6" Padding="14,10" Margin="0,0,0,12"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="RECONCILIATION" Style="{StaticResource SectionHeadingStyle}" Margin="0,0,0,6"/>
                                <DockPanel Margin="0,2">
                                    <TextBlock Text="Status: " Foreground="{StaticResource TextSecondaryBrush}" Width="90" FontSize="12"/>
                                    <TextBlock Text="{Binding SelectedTrade.ReconciliationStatus, FallbackValue='—'}"
                                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                                </DockPanel>
                                <DockPanel Margin="0,4">
                                    <TextBlock Text="Exit Price: " Foreground="{StaticResource TextSecondaryBrush}" Width="90" FontSize="12"/>
                                    <TextBlock Text="{Binding SelectedTrade.Record.ExitPrice, FallbackValue='—'}"
                                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                                </DockPanel>
                                <DockPanel Margin="0,4">
                                    <TextBlock Text="Exit Reason: " Foreground="{StaticResource TextSecondaryBrush}" Width="90" FontSize="12"/>
                                    <TextBlock Text="{Binding SelectedTrade.ExitReason, FallbackValue='—'}"
                                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                                </DockPanel>
                                <DockPanel Margin="0,4">
                                    <TextBlock Text="Last check: " Foreground="{StaticResource TextSecondaryBrush}" Width="90" FontSize="12"/>
                                    <TextBlock Text="{Binding SelectedTrade.Record.ReconciledAt, FallbackValue='Never'}"
                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <!-- Export buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Content="Export CSV"
                                    Command="{Binding ExportCsvCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="14,6" Margin="0,0,8,0"/>
                            <Button Content="Export JSON"
                                    Command="{Binding ExportJsonCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="14,6" Margin="0,0,8,0"/>
                            <Button Content="Open in Excel"
                                    Command="{Binding OpenInExcelCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="14,6"/>
                        </StackPanel>

                        <!-- Action timeline -->
                        <Border Background="{StaticResource CardBrush}"
                                CornerRadius="6" Padding="12,10"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="ACTION TIMELINE"
                                           Style="{StaticResource SectionHeadingStyle}"
                                           Margin="0,0,0,8"/>
                                <DataGrid ItemsSource="{Binding Actions}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserSortColumns="True"
                                          SelectionMode="Single"
                                          GridLinesVisibility="Horizontal"
                                          HeadersVisibility="Column"
                                          Background="Transparent"
                                          RowBackground="Transparent"
                                          AlternatingRowBackground="#12FFFFFF"
                                          BorderThickness="0"
                                          FontSize="12"
                                          MaxHeight="400"
                                          RowStyle="{StaticResource ActionRowStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#"          Binding="{Binding Id}"         Width="40"/>
                                        <DataGridTextColumn Header="Timestamp"  Binding="{Binding Timestamp}"  Width="170"/>
                                        <DataGridTextColumn Header="Action"     Binding="{Binding ActionType}" Width="150"/>
                                        <DataGridTextColumn Header="Detail"     Binding="{Binding Detail}"     Width="*"/>
                                        <DataGridTextColumn Header="Source"     Binding="{Binding Source}"     Width="70"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
