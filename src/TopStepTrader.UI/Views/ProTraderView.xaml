<UserControl x:Class="TopStepTrader.UI.Views.ProTraderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- header panels -->
            <RowDefinition Height="*"/>      <!-- tile grid -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             TOP: Header settings area
             ══════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,12,16,8">

                <!-- Page title -->
                <TextBlock Text="⚡  Pro-Trader"
                           Style="{StaticResource PageTitleStyle}"/>

                <!-- ── Panel 1: Account / Controls ── -->
                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Padding="12,8" Margin="0,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>  <!-- Account: label -->
                            <ColumnDefinition Width="160"/>   <!-- Account ComboBox -->
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>  <!-- Conf%: label -->
                            <ColumnDefinition Width="52"/>    <!-- Conf% box -->
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>  <!-- $Amt: -->
                            <ColumnDefinition Width="70"/>    <!-- $Amt box -->
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>  <!-- Start -->
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>  <!-- Stop -->
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Account:"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,8,0"/>

                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding Accounts}"
                                  SelectedItem="{Binding SelectedAccount}"
                                  FontSize="13" Height="28"
                                  Style="{StaticResource UnclippedComboBoxStyle}"
                                  ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"
                                  ToolTip="Select the combine account to trade with">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Foreground="White" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <!-- Confidence % -->
                        <TextBlock Grid.Column="3" Text="Conf%:"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"
                                   ToolTip="Minimum weighted score 0–100 required to fire a signal"/>
                        <TextBox Grid.Column="4"
                                 Text="{Binding MinConfidencePct, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center" Height="26"
                                 ToolTip="Override global confidence threshold"/>

                        <!-- $Amt -->
                        <TextBlock Grid.Column="6" Text="$Amt:"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Grid.Column="7"
                                 Text="{Binding TradeAmount, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center" Height="26"
                                 ToolTip="Dollar amount per trade"/>

                        <!-- Start / Stop -->
                        <Button Grid.Column="9"
                                Content="▶  Start"
                                Command="{Binding StartCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Width="90" Height="28"
                                IsEnabled="{Binding IsNotRunning}"
                                ToolTip="Start Pro-Trader session"/>
                        <Button Grid.Column="11"
                                Content="■  Stop"
                                Command="{Binding StopCommand}"
                                Style="{StaticResource DangerButtonStyle}"
                                Width="80" Height="28"
                                ToolTip="Stop Pro-Trader session"/>
                    </Grid>
                </Border>

                <!-- ── Panel 2: ATR Risk Tier (with Override toggle, FEAT-18) ── -->
                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Padding="12,6" Margin="0,4,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="ATR Tier:"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"
                                   ToolTip="Global bracket override. When on, all slot engines use these multiples instead of their per-slot defaults."/>

                        <!-- Override toggle (FEAT-18) -->
                        <CheckBox Content="Override ATR" IsChecked="{Binding AtrOverrideEnabled}"
                                  VerticalAlignment="Center" Margin="0,0,12,0"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  ToolTip="Enable to apply a global ATR tier to all slots, overriding per-slot multiples."/>

                        <!-- Tier buttons + multiples — dimmed when Override is off -->
                        <StackPanel Orientation="Horizontal">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Opacity" Value="0.45"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AtrOverrideEnabled}" Value="True">
                                            <Setter Property="Opacity" Value="1.0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <!-- Tight tier -->
                            <Button Command="{Binding SelectAtrTierCommand}" CommandParameter="Tight"
                                    Margin="0,0,4,0"
                                    ToolTip="Tight: SL=0.75×ATR, TP=1.5×ATR. Narrowest brackets — more signals, tighter stops.">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ProfileButtonStyle}">
                                        <Setter Property="MinWidth" Value="70"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAtrTightSelected}" Value="True">
                                                <Setter Property="Background" Value="#8B4513"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="📏  Tight" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Button>

                            <!-- Standard tier -->
                            <Button Command="{Binding SelectAtrTierCommand}" CommandParameter="Standard"
                                    Margin="0,0,4,0"
                                    ToolTip="Standard: SL=1.5×ATR, TP=3.0×ATR. Balanced brackets.">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ProfileButtonStyle}">
                                        <Setter Property="MinWidth" Value="70"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAtrStandardSelected}" Value="True">
                                                <Setter Property="Background" Value="#228B22"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="📐  Standard" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Button>

                            <!-- Wide tier -->
                            <Button Command="{Binding SelectAtrTierCommand}" CommandParameter="Wide"
                                    Margin="0,0,4,0"
                                    ToolTip="Wide: SL=2.5×ATR, TP=5.0×ATR. Widest brackets — fewer whipsaws, patient exits.">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ProfileButtonStyle}">
                                        <Setter Property="MinWidth" Value="70"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAtrWideSelected}" Value="True">
                                                <Setter Property="Background" Value="#1A237E"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="🔭  Wide" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Button>

                            <!-- Ultra tier -->
                            <Button Command="{Binding SelectAtrTierCommand}" CommandParameter="Ultra"
                                    Margin="0,0,4,0"
                                    ToolTip="Ultra: SL=5×ATR, TP=10×ATR. Maximum room — rides large macro moves, very few signals.">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ProfileButtonStyle}">
                                        <Setter Property="MinWidth" Value="70"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAtrUltraSelected}" Value="True">
                                                <Setter Property="Background" Value="#4A0072"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="🚀  Ultra" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Button>

                            <!-- Current multiples display -->
                            <TextBlock Margin="16,0,0,0" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="16"
                                       FontFamily="Consolas">
                                <Run Text="SL "/>
                                <Run Text="{Binding SlMultipleOfN, StringFormat='{}{0:F2}×'}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"/>
                                <Run Text="  TP "/>
                                <Run Text="{Binding TpMultipleOfN, StringFormat='{}{0:F2}×'}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"/>
                                <Run Text="  ATR"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ══════════════════════════════════════════════════════════
             BODY: Active-position panel (visible when a trade is open)
             ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- active positions panel -->
                <RowDefinition Height="*"/>      <!-- slot tile grid -->
            </Grid.RowDefinitions>

            <!-- Active position panel -->
            <Border Grid.Row="0" Margin="12,4,12,0"
                    Background="#1A1A2E" CornerRadius="6"
                    BorderBrush="#E53935" BorderThickness="0,0,0,2">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasActiveSlots}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Margin="10,8,10,8">
                    <TextBlock Text="⚡  Active Positions"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="#E53935" Margin="0,0,0,6"/>
                    <ItemsControl ItemsSource="{Binding ActivePositionSlots}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,2" Padding="8,6" CornerRadius="4"
                                        Background="{StaticResource SurfaceBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>   <!-- symbol -->
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>      <!-- bracket prices -->
                                            <ColumnDefinition Width="Auto"/>   <!-- free ride badge -->
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>   <!-- nudge -->
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="Auto"/>   <!-- close -->
                                        </Grid.ColumnDefinitions>

                                        <!-- Symbol -->
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Symbol}"
                                                   FontSize="13" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>

                                        <!-- SL/TP display -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding BracketPriceDisplay}"
                                                   FontSize="12" FontFamily="Consolas"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   VerticalAlignment="Center"/>

                                        <!-- Free Ride badge -->
                                        <Border Grid.Column="3" CornerRadius="3" Padding="5,2"
                                                Background="#1B5E20" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFreeRide}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="Free Ride" FontSize="10"
                                                       Foreground="#A5D6A7" FontWeight="SemiBold"/>
                                        </Border>

                                        <!-- Nudge button -->
                                        <Button Grid.Column="5"
                                                Content="⟳ Nudge"
                                                Command="{Binding NudgeBracketCommand}"
                                                Style="{StaticResource ProfileButtonStyle}"
                                                FontSize="11" Height="24" Padding="8,2"
                                                ToolTip="Tighten SL by 10% toward entry"/>

                                        <!-- Close button -->
                                        <Button Grid.Column="7"
                                                Content="✕ Close"
                                                Command="{Binding CloseCommand}"
                                                Style="{StaticResource DangerButtonStyle}"
                                                FontSize="11" Height="24" Padding="8,2"
                                                ToolTip="Flatten this position now"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        <!-- ══════════════════════════════════════════════════════════
             BODY: Slot tile grid
             ══════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" Margin="12,4,12,12" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Slots}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Tile: ~204px wide, left-border accent when enabled -->
                        <Border Width="204" Margin="4" CornerRadius="6"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{Binding PersonaAccentBrush}"
                                ClipToBounds="True">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Opacity" Value="0.45"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                            <Setter Property="Opacity" Value="1.0"/>
                                            <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <StackPanel Margin="10,8,10,10">
                                <!-- Row 1: Symbol + enable toggle -->
                                <DockPanel LastChildFill="True">
                                    <CheckBox DockPanel.Dock="Right"
                                              IsChecked="{Binding IsEnabled}"
                                              VerticalAlignment="Center"
                                              ToolTip="Enable this slot"/>
                                    <TextBlock Text="{Binding Symbol}"
                                               FontSize="15" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                </DockPanel>

                                <!-- Row 2: Strategy · Timeframe -->
                                <TextBlock Text="{Binding StrategyTimeframeLabel}"
                                           Margin="0,3,0,0" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>

                                <!-- Row 3: Persona badge -->
                                <Border Margin="0,5,0,0" CornerRadius="3" Padding="6,2"
                                        HorizontalAlignment="Left"
                                        Background="{Binding PersonaAccentBrush}">
                                    <TextBlock Text="{Binding PersonaName}"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="White"/>
                                </Border>

                                <!-- Row 4: Confidence bar (hidden when Stopped) -->
                                <ProgressBar Value="{Binding ConfidencePct}" Maximum="100"
                                             Height="4" Margin="0,6,0,0">
                                    <ProgressBar.Style>
                                        <Style TargetType="ProgressBar">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusText}" Value="Stopped">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ProgressBar.Style>
                                </ProgressBar>

                                <!-- Row 5: Status badge -->
                                <Border Margin="0,5,0,0" CornerRadius="3" Padding="6,2"
                                        HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#2A2A2A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusText}" Value="Monitoring">
                                                    <Setter Property="Background" Value="#0D47A1"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}" Value="Signal">
                                                    <Setter Property="Background" Value="#1B5E20"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}" Value="Trading">
                                                    <Setter Property="Background" Value="#B71C1C"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}" Value="Paused">
                                                    <Setter Property="Background" Value="#4A148C"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding StatusText}"
                                               FontSize="10" Foreground="White"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        </Grid><!-- end inner Grid (active-position panel + tile grid) -->

    </Grid>
</UserControl>
