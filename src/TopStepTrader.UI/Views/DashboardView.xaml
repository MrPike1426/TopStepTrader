<UserControl x:Class="TopStepTrader.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Page Title -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="📊  Dashboard" Style="{StaticResource PageTitleStyle}" Margin="0"/>
                <Button Content="↻ Refresh"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="16,0,0,0" Padding="10,4" FontSize="11"/>
            </StackPanel>

            <!-- Risk Status Banner -->
            <Border Grid.Row="2"
                    Background="{Binding RiskStatusColor, Converter={StaticResource BrushKeyConverter}}"
                    CornerRadius="6" Padding="16,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding RiskStatusText}"
                               Style="{StaticResource BadgeTextStyle}"
                               FontSize="15" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding HaltReason, StringFormat=' — Reason: {0}'}"
                               Foreground="#CCFFFFFF" FontSize="12" Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               Visibility="{Binding IsHalted, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </Border>

            <!-- Metric cards row -->
            <UniformGrid Grid.Row="4" Columns="4" HorizontalAlignment="Stretch">

                <!-- Account Balance -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="6"
                        Margin="0,0,8,0" Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="ACCOUNT BALANCE" Style="{StaticResource SectionHeadingStyle}"/>
                        <TextBlock Text="{Binding Balance, StringFormat=C0}"
                                   Style="{StaticResource MetricValueStyle}" Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding AccountName}" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Daily P&L -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="6"
                        Margin="4,0,4,0" Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="DAILY P&amp;L" Style="{StaticResource SectionHeadingStyle}"/>
                        <TextBlock Text="{Binding DailyPnL, StringFormat=C0}"
                                   Style="{StaticResource MetricValueStyle}"
                                   Foreground="{Binding PnLColor, Converter={StaticResource BrushKeyConverter}}"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding DailyLossLimit, StringFormat='Limit: {0:C0}'}"
                                   Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Drawdown -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="6"
                        Margin="4,0,4,0" Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="DRAWDOWN" Style="{StaticResource SectionHeadingStyle}"/>
                        <TextBlock Text="{Binding Drawdown, StringFormat=C0}"
                                   Style="{StaticResource MetricValueStyle}"
                                   Foreground="{Binding DrawdownColor, Converter={StaticResource BrushKeyConverter}}"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding MaxDrawdownLimit, StringFormat='Limit: {0:C0}'}"
                                   Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Last Signal -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="6"
                        Margin="8,0,0,0" Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="LAST AI SIGNAL" Style="{StaticResource SectionHeadingStyle}"/>
                        <TextBlock Text="{Binding LastSignalText}"
                                   Style="{StaticResource MetricValueStyle}"
                                   Foreground="{Binding LastSignalColor, Converter={StaticResource BrushKeyConverter}}"
                                   Margin="0,4,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding LastSignalConfidence, StringFormat='Conf: {0:P0}'}"
                                       Style="{StaticResource LabelStyle}"/>
                            <TextBlock Text="{Binding LastSignalTime, StringFormat='  @ {0}'}"
                                       Style="{StaticResource LabelStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- Status bar -->
            <TextBlock Grid.Row="6"
                       Text="{Binding StatusMessage}"
                       Style="{StaticResource LabelStyle}"
                       HorizontalAlignment="Right"/>

        </Grid>
    </ScrollViewer>
</UserControl>
