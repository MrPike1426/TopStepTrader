<UserControl x:Class="TopStepTrader.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:infra="clr-namespace:TopStepTrader.UI.Infrastructure"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Page Title -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="📊  Dashboard" Style="{StaticResource PageTitleStyle}" Margin="0"/>
                <Button Content="↻ Refresh"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="16,0,0,0" Padding="10,4" FontSize="11"/>
            </StackPanel>

            <!-- Active Broker Banner -->
            <Border Grid.Row="2"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="6" Padding="16,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="ACTIVE PLATFORM:"
                               Style="{StaticResource SectionHeadingStyle}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding ActiveBrokerLabel}"
                               FontSize="15" FontWeight="SemiBold" Foreground="White"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ConnectionStatusText}"
                               Foreground="{Binding ConnectionStatusColor, Converter={StaticResource BrushKeyConverter}}"
                               FontSize="12" FontWeight="SemiBold"
                               Margin="24,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Metric cards row -->
            <UniformGrid Grid.Row="4" Columns="4" HorizontalAlignment="Stretch">

                <!-- Account Selector -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="6"
                        Margin="0,0,8,0" Padding="16,14">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="SELECT ACCOUNT" Style="{StaticResource SectionHeadingStyle}"/>
                            <TextBlock Text="{Binding ActiveBrokerLabel}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="10" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ComboBox ItemsSource="{Binding Accounts}"
                                  SelectedItem="{Binding SelectedAccount}"
                                  Margin="0,8,0,0"
                                  FontSize="26"
                                  Style="{StaticResource UnclippedComboBoxStyle}"
                                  ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}" Foreground="White" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Account Balance -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="6"
                        Margin="4,0,4,0" Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="TOTAL VALUE" Style="{StaticResource SectionHeadingStyle}"/>
                        <TextBlock Text="{Binding Balance, StringFormat=C0}"
                                   Style="{StaticResource MetricValueStyle}" Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding AccountName}" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Daily P&L -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="6"
                        Margin="4,0,4,0" Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="DAILY P&amp;L" Style="{StaticResource SectionHeadingStyle}"/>
                        <TextBlock Text="{Binding DailyPnL, StringFormat=C0}"
                                   Style="{StaticResource MetricValueStyle}"
                                   Foreground="{Binding PnLColor, Converter={StaticResource BrushKeyConverter}}"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding DailyLossLimit, StringFormat='Limit: {0:C0}'}"
                                   Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Drawdown -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="6"
                        Margin="8,0,0,0" Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="DRAWDOWN" Style="{StaticResource SectionHeadingStyle}"/>
                        <TextBlock Text="{Binding Drawdown, StringFormat=C0}"
                                   Style="{StaticResource MetricValueStyle}"
                                   Foreground="{Binding DrawdownColor, Converter={StaticResource BrushKeyConverter}}"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding MaxDrawdownLimit, StringFormat='Limit: {0:C0}'}"
                                   Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- Accounts Section -->
            <Border Grid.Row="6" Background="{StaticResource CardBrush}" CornerRadius="6" Padding="16,14">
                <StackPanel>
                    <!-- Balance History Table -->
                    <TextBlock Text="BALANCE HISTORY (8 DAYS)" Style="{StaticResource SectionHeadingStyle}" Margin="0,0,0,12"/>
                    <DataGrid ItemsSource="{Binding BalanceHistoryRows}"
                              AutoGenerateColumns="False"
                              Background="{StaticResource SurfaceBrush}"
                              BorderThickness="1"
                              BorderBrush="{StaticResource BorderBrush}"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                              RowHeight="32">
                        <DataGrid.Resources>
                            <infra:BindingProxy x:Key="VmProxy" Data="{Binding}"/>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Account" Binding="{Binding AccountName}" Width="150"/>
                            <DataGridTextColumn Header="Current" Binding="{Binding CurrentBalance, StringFormat=C0}" Width="110"/>
                            <DataGridTextColumn Header="{Binding Data.Date1Header, Source={StaticResource VmProxy}}" Binding="{Binding Date1Balance, StringFormat=C0}" Width="90"/>
                            <DataGridTextColumn Header="{Binding Data.Date2Header, Source={StaticResource VmProxy}}" Binding="{Binding Date2Balance, StringFormat=C0}" Width="90"/>
                            <DataGridTextColumn Header="{Binding Data.Date3Header, Source={StaticResource VmProxy}}" Binding="{Binding Date3Balance, StringFormat=C0}" Width="90"/>
                            <DataGridTextColumn Header="{Binding Data.Date4Header, Source={StaticResource VmProxy}}" Binding="{Binding Date4Balance, StringFormat=C0}" Width="90"/>
                            <DataGridTextColumn Header="{Binding Data.Date5Header, Source={StaticResource VmProxy}}" Binding="{Binding Date5Balance, StringFormat=C0}" Width="90"/>
                            <DataGridTextColumn Header="{Binding Data.Date6Header, Source={StaticResource VmProxy}}" Binding="{Binding Date6Balance, StringFormat=C0}" Width="90"/>
                            <DataGridTextColumn Header="{Binding Data.Date7Header, Source={StaticResource VmProxy}}" Binding="{Binding Date7Balance, StringFormat=C0}" Width="90"/>
                            <DataGridTextColumn Header="{Binding Data.Date8Header, Source={StaticResource VmProxy}}" Binding="{Binding Date8Balance, StringFormat=C0}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Settings Sections -->
                    <StackPanel Margin="0,20,0,0">
                        <!-- Auto-Execution -->
                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="6" Padding="12,12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="AUTO-EXECUTION" Style="{StaticResource SectionHeadingStyle}" Foreground="{StaticResource HaltedBrush}" Margin="0,0,0,8"/>
                                <TextBlock Text="⚠  When enabled, the AI will automatically place real orders on live accounts." Foreground="{StaticResource WarningBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <CheckBox Content="Enable Autonomous Order Execution" IsChecked="{Binding AutoExecutionEnabled}" Foreground="{StaticResource HaltedBrush}" FontWeight="SemiBold" FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <!-- Risk Settings (One Line) -->
                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="6" Padding="12,12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="RISK GUARD SETTINGS" Style="{StaticResource SectionHeadingStyle}" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                                    <!-- Daily Loss Limit -->
                                    <StackPanel Width="180" Margin="0,0,12,0">
                                        <TextBlock Text="Daily Loss Limit ($):" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="0,0,0,2"/>
                                        <TextBox Text="{Binding DailyLossLimitEditable, UpdateSourceTrigger=PropertyChanged}" Height="28"/>
                                    </StackPanel>

                                    <!-- Max Position -->
                                    <StackPanel Width="180" Margin="0,0,12,0">
                                        <TextBlock Text="Max Position (contracts):" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="0,0,0,2"/>
                                        <TextBox Text="{Binding MaxPositionEditable, UpdateSourceTrigger=PropertyChanged}" Height="28"/>
                                    </StackPanel>

                                    <!-- Min Signal Confidence -->
                                    <StackPanel Width="180" Margin="0,0,12,0">
                                        <TextBlock Text="Min Confidence (%):" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="0,0,0,2"/>
                                        <TextBox Text="{Binding MinConfidenceEditable, UpdateSourceTrigger=PropertyChanged}" Height="28"/>
                                    </StackPanel>

                                    <!-- Apply Button -->
                                    <StackPanel VerticalAlignment="Bottom">
                                        <Button Content="Apply" Command="{Binding ApplyRiskCommand}" Style="{StaticResource PrimaryButtonStyle}" Padding="16,6" Height="28" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- API Status -->
                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="6" Padding="12,10">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="API Status:" Foreground="{StaticResource TextSecondaryBrush}" Width="80" Margin="0,0,12,0" FontSize="11"/>
                                <TextBlock Text="{Binding ConnectionStatusText}" Foreground="{Binding ConnectionStatusColor, Converter={StaticResource BrushKeyConverter}}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button Content="Reconnect" Command="{Binding ConnectCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="10,4" FontSize="10" Height="24"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Status bar -->
            <TextBlock Grid.Row="7"
                       Text="{Binding StatusMessage}"
                       Style="{StaticResource LabelStyle}"
                       HorizontalAlignment="Right"
                       Margin="0,16,0,0"/>

        </Grid>
    </ScrollViewer>
</UserControl>
