<UserControl x:Class="TopStepTrader.UI.Views.SuperTrendPlusView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:TopStepTrader.UI.Infrastructure"
             xmlns:controls="clr-namespace:TopStepTrader.UI.Controls"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,8">

            <!-- ── Page title + How-It-Works toggle on same row ── -->
            <Grid Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="&#x1F4C8;  SuperTrend+"
                           Style="{StaticResource PageTitleStyle}"
                           VerticalAlignment="Center"/>

                <Border Grid.Column="2"
                        Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6"
                        BorderBrush="#3A5A8A" BorderThickness="1"
                        VerticalAlignment="Center">
                    <ToggleButton x:Name="HowItWorksToggle"
                                  IsChecked="{Binding IsHowItWorksExpanded, Mode=TwoWay}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Cursor="Hand"
                                  Padding="12,6"
                                  HorizontalContentAlignment="Stretch">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4A1;" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="How does SuperTrend+ Autopilot work?"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock VerticalAlignment="Center" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="&#x25B2; hide"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, ElementName=HowItWorksToggle}" Value="False">
                                                <Setter Property="Text" Value="&#x25BC; show"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </ToggleButton>
                </Border>
            </Grid>

            <!-- How-It-Works collapsible body -->
            <Border Margin="0,6,0,0"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="6"
                    BorderBrush="#3A5A8A" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChecked, ElementName=HowItWorksToggle}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border Padding="16,6,16,16">
                    <StackPanel>

                        <!-- ── Personas ── -->
                        <Border Background="#16213A" CornerRadius="6" Padding="14,10" Margin="0,4,0,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="&#x1F464;" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Trading Personas" Foreground="White" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock Text="  —  choose before starting" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Three persona cards -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Lewis -->
                                    <Border Grid.Column="0" Background="#0D1B2E" CornerRadius="5" Padding="10,8"
                                            BorderBrush="#1565C0" BorderThickness="1,3,1,1">
                                        <StackPanel>
                                            <TextBlock Text="Lewis" Foreground="#42A5F5" FontSize="12" FontWeight="Bold" Margin="0,0,0,4"/>
                                            <TextBlock Text="Risk-Averse" Foreground="#90CAF9" FontSize="12" Margin="0,0,0,6"/>
                                            <TextBlock Foreground="#8090A0" FontSize="12" LineHeight="16">
                                                <Run Foreground="White" FontWeight="SemiBold">Min ADX</Run>  40+&#xA;<Run Foreground="White" FontWeight="SemiBold">ST mult</Run>    3.5×&#xA;<Run Foreground="White" FontWeight="SemiBold">RR target</Run>  0.75&#xA;<Run Foreground="White" FontWeight="SemiBold">Entries</Run>    Latte / Espresso
                                            </TextBlock>
                                            <Border Background="#0A1520" CornerRadius="3" Padding="6,4" Margin="0,6,0,0">
                                                <TextBlock TextWrapping="Wrap" Foreground="White" FontSize="12" LineHeight="15">Fewer, higher-conviction entries. Tight selectivity with capital preservation as the primary goal.</TextBlock>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- Damian -->
                                    <Border Grid.Column="2" Background="#0D1B2E" CornerRadius="5" Padding="10,8"
                                            BorderBrush="#2E7D32" BorderThickness="1,3,1,1">
                                        <StackPanel>
                                            <TextBlock Text="Damian" Foreground="#66BB6A" FontSize="12" FontWeight="Bold" Margin="0,0,0,4"/>
                                            <TextBlock Text="Balanced  (default)" Foreground="#A5D6A7" FontSize="12" Margin="0,0,0,6"/>
                                            <TextBlock Foreground="#8090A0" FontSize="12" LineHeight="16">
                                                <Run Foreground="White" FontWeight="SemiBold">Min ADX</Run>  30+&#xA;<Run Foreground="White" FontWeight="SemiBold">ST mult</Run>    3.0×&#xA;<Run Foreground="White" FontWeight="SemiBold">RR target</Run>  1.5&#xA;<Run Foreground="White" FontWeight="SemiBold">Entries</Run>    All bands ≥ 30
                                            </TextBlock>
                                            <Border Background="#0A1520" CornerRadius="3" Padding="6,4" Margin="0,6,0,0">
                                                <TextBlock TextWrapping="Wrap" Foreground="White" FontSize="12" LineHeight="15">Balanced mix of frequency and quality. Momentum and continuation setups across all trend bands.</TextBlock>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- Joe -->
                                    <Border Grid.Column="4" Background="#0D1B2E" CornerRadius="5" Padding="10,8"
                                            BorderBrush="#E65100" BorderThickness="1,3,1,1">
                                        <StackPanel>
                                            <TextBlock Text="Joe" Foreground="#FFA726" FontSize="12" FontWeight="Bold" Margin="0,0,0,4"/>
                                            <TextBlock Text="Reward-Seeking" Foreground="#FFCC80" FontSize="12" Margin="0,0,0,6"/>
                                            <TextBlock Foreground="#8090A0" FontSize="12" LineHeight="16">
                                                <Run Foreground="White" FontWeight="SemiBold">Min ADX</Run>  20+&#xA;<Run Foreground="White" FontWeight="SemiBold">ST mult</Run>    2.5×&#xA;<Run Foreground="White" FontWeight="SemiBold">RR target</Run>  2.0&#xA;<Run Foreground="White" FontWeight="SemiBold">Entries</Run>    All bands ≥ 20
                                            </TextBlock>
                                            <Border Background="#0A1520" CornerRadius="3" Padding="6,4" Margin="0,6,0,0">
                                                <TextBlock TextWrapping="Wrap" Foreground="White" FontSize="12" LineHeight="15">Higher frequency, wider signals. Accepts more losses in exchange for larger winners. Precise entries critical.</TextBlock>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Foreground="White" FontSize="12" LineHeight="15">
                                    <Run Foreground="#FFD54F" FontWeight="SemiBold">RR Target</Run> is a visual milestone only — no hard take-profit bracket is placed. The position runs until the trend weakens, managed entirely by the phased stop system. When the RR target is reached the slot title turns gold.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- ── Monitoring ── -->
                        <Border Background="#16213A" CornerRadius="6" Padding="14,10" Margin="0,0,0,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="&#x1F4E1;" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Monitoring" Foreground="White" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" Foreground="#8090A0" FontSize="12" LineHeight="17">Every 15 seconds SuperTrend+ scans all watchlist instruments on the selected timeframe. For each it computes the SuperTrend line, ADX, and Directional Indicators (+DI / -DI) to classify trend direction and strength. The watchlist updates live; the three slot boxes track any open positions.</TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- ── Signal Detection ── -->
                        <Border Background="#16213A" CornerRadius="6" Padding="14,10" Margin="0,0,0,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="&#x1F50D;" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Signal Detection" Foreground="White" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" Foreground="#8090A0" FontSize="12" LineHeight="17" Margin="0,0,0,6">A trade signal qualifies when all three conditions are met:</TextBlock>
                                <Border Background="#1A2440" CornerRadius="4" Padding="10,8" Margin="0,0,0,6">
                                    <StackPanel>
                                        <TextBlock Foreground="#8090A0" FontSize="12" LineHeight="18" Margin="0,0,0,2">
                                            <Run Foreground="#42A5F5" FontWeight="SemiBold">&#x2460;  SuperTrend direction</Run>  — price above ST line (long) or below (short)
                                        </TextBlock>
                                        <TextBlock Foreground="#8090A0" FontSize="12" LineHeight="18" Margin="0,0,0,2">
                                            <Run Foreground="#42A5F5" FontWeight="SemiBold">&#x2461;  DI alignment</Run>  — +DI &gt; −DI confirms long; −DI &gt; +DI confirms short
                                        </TextBlock>
                                        <TextBlock Foreground="#8090A0" FontSize="12" LineHeight="18">
                                            <Run Foreground="#42A5F5" FontWeight="SemiBold">&#x2462;  ADX gate</Run>  — ADX at or above the active persona's minimum (Lewis 40 / Damian 30 / Joe 20)
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                                <TextBlock TextWrapping="Wrap" Foreground="White" FontSize="12" LineHeight="15">In <Run Foreground="Gold" FontWeight="SemiBold">Pre-emptive early entry</Run> mode a fourth trigger is checked: multi-timeframe reversal anticipation (5min + 15min + 1hr alignment). In <Run Foreground="White" FontWeight="SemiBold">On Bar Close</Run> mode only the bar-close signal is used.</TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- ── ADX Bands &amp; Contract Sizing ── -->
                        <Border Background="#16213A" CornerRadius="6" Padding="14,10" Margin="0,0,0,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="&#x2615;" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="ADX Bands &amp; Contract Sizing" Foreground="White" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" Foreground="#8090A0" FontSize="12" LineHeight="17" Margin="0,0,0,8">The ADX value at entry determines how many contracts the bot places. Bands are fixed regardless of persona — the persona only controls which bands are reachable via its ADX gate.</TextBlock>

                                <!-- Band cards -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="#1A2440" CornerRadius="4" Padding="10,8" BorderBrush="#2A3A5A" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="L0  Decaff" Foreground="#90CAF9" FontSize="11" FontWeight="Bold" Margin="0,0,0,3"/>
                                            <TextBlock Text="ADX 25 – 39" Foreground="White" FontSize="12" Margin="0,0,0,5"/>
                                            <Border Background="#0D1520" CornerRadius="3" Padding="8,5">
                                                <TextBlock Text="1 contract" Foreground="White" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="Mild trend. Damian and Joe may enter here." Foreground="White" FontSize="12" LineHeight="14" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" Background="#1A2440" CornerRadius="4" Padding="10,8" BorderBrush="#1565C0" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="L2  Latte" Foreground="#42A5F5" FontSize="11" FontWeight="Bold" Margin="0,0,0,3"/>
                                            <TextBlock Text="ADX 40 – 59" Foreground="White" FontSize="12" Margin="0,0,0,5"/>
                                            <Border Background="#0D1520" CornerRadius="3" Padding="8,5">
                                                <TextBlock Text="2 contracts" Foreground="White" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="Solid momentum. All personas may enter here." Foreground="White" FontSize="12" LineHeight="14" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="4" Background="#1A2440" CornerRadius="4" Padding="10,8" BorderBrush="#E65100" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="L3  Espresso" Foreground="#FFA726" FontSize="11" FontWeight="Bold" Margin="0,0,0,3"/>
                                            <TextBlock Text="ADX 60+" Foreground="White" FontSize="12" Margin="0,0,0,5"/>
                                            <Border Background="#0D1520" CornerRadius="3" Padding="8,5">
                                                <TextBlock Text="3 contracts" Foreground="White" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="High-conviction trend. All personas size up here." Foreground="White" FontSize="12" LineHeight="14" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <TextBlock TextWrapping="Wrap" Foreground="White" FontSize="12" LineHeight="15">Up to <Run Foreground="White" FontWeight="SemiBold">3 concurrent slots</Run> can be open across different instruments simultaneously. If ADX rises while a position is open, the bot scale-ins +1 contract to match the new band. If ADX falls mid-trade, exit management handles the position — contracts are never automatically reduced.</TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- ── The Scalper — Profit Protection & Exit ── -->
                        <Border Background="#16213A" CornerRadius="6" Padding="14,10" Margin="0,0,0,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="&#x1F6E1;" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="The Scalper — Profit Protection &amp; Exit" Foreground="White" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" Foreground="#8090A0" FontSize="12" LineHeight="17" Margin="0,0,0,8">
                                    Once a position is open, exit management is owned by <Run Foreground="White" FontWeight="SemiBold">The Scalper</Run> — a reusable service that ratchets the stop on closed 15-second bars. The stop never moves backwards. <Run Foreground="#90CAF9">R = initial risk (entry − stop at entry).</Run>
                                </TextBlock>

                                <Border Background="#1A2440" CornerRadius="4" Padding="10,8">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Phase" Foreground="#42A5F5" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="1" Text="Trigger" Foreground="#42A5F5" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="2" Text="Stop trail" Foreground="#42A5F5" FontSize="12" FontWeight="SemiBold"/>
                                        </Grid>
                                        <Rectangle Height="1" Fill="#2A3A5A" Margin="0,0,0,4"/>
                                        <Grid Margin="0,0,0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Initial"     Foreground="#8090A0" FontSize="12"/>
                                            <TextBlock Grid.Column="1" Text="Entry"       Foreground="White" FontSize="12"/>
                                            <TextBlock Grid.Column="2" Text="15s SuperTrend line (ratchet only)" Foreground="#8090A0" FontSize="12"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Breakeven"   Foreground="#A5D6A7" FontSize="12"/>
                                            <TextBlock Grid.Column="1" Text="0.5R profit" Foreground="White" FontSize="12"/>
                                            <TextBlock Grid.Column="2" Text="max(entry, 15s ST) — risk eliminated" Foreground="#8090A0" FontSize="12"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="ProfitLock"  Foreground="#66BB6A" FontSize="12"/>
                                            <TextBlock Grid.Column="1" Text="1.5R profit" Foreground="White" FontSize="12"/>
                                            <TextBlock Grid.Column="2" Text="15s BB lower (LONG) / upper (SHORT) — band trail, ST trail dropped" Foreground="#8090A0" FontSize="12"/>
                                        </Grid>
                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="ScaredyCat"  Foreground="#FFCC80" FontSize="12"/>
                                            <TextBlock Grid.Column="1" Text="One-way arm" Foreground="White" FontSize="12"/>
                                            <TextBlock Grid.Column="2" Text="8 consecutive 15s BB-middle bars against trade + 15s ST disagrees → BB mult 2.0 → 1.5 for the rest of the trade" Foreground="#8090A0" FontSize="12" TextWrapping="Wrap"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#8090A0" FontSize="12" LineHeight="17">
                                    Exit fires when a closed 15s bar crosses the latest stop. After a release, the same instrument cannot re-enter until the closed 15s bar agrees with the new direction relative to the BB middle (length 10, mult 2.0).
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- ── ORB — Opening Range Breakout ── -->
                        <Border Background="#16213A" CornerRadius="6" Padding="14,10" Margin="0,8,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="&#x1F4D0;" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="ORB — Opening Range Breakout" Foreground="White" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock Text="  (equity index futures only: MES · MNQ · M2K · MYM)" Foreground="#8090A0" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" Foreground="#8090A0" FontSize="12" LineHeight="17" Margin="0,0,0,8">The ORB strategy uses the first 30 minutes of the regular US equity session to define a range, then trades breakouts from that range during the first half of the session only. It runs on <Run Foreground="White" FontWeight="SemiBold">5-minute bars</Run> regardless of the timeframe selected above.</TextBlock>

                                <Border Background="#1A2440" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Phase" Foreground="#42A5F5" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="1" Text="What happens" Foreground="#42A5F5" FontSize="12" FontWeight="SemiBold"/>
                                        </Grid>
                                        <Rectangle Height="1" Fill="#2A3A5A" Margin="0,0,0,4"/>
                                        <Grid Margin="0,0,0,3">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Pre-market" Foreground="#8090A0" FontSize="12"/>
                                            <TextBlock Grid.Column="1" Text="Before 09:30 ET — watching, no signal" Foreground="#8090A0" FontSize="12"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,3">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="09:30 – 10:00" Foreground="Gold" FontSize="12"/>
                                            <TextBlock Grid.Column="1" Text="Opening range builds — high and low of the first 6 bars define the OR" Foreground="#8090A0" FontSize="12"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,3">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="10:00 – 12:45" Foreground="#66BB6A" FontSize="12"/>
                                            <TextBlock Grid.Column="1" Text="Entry window — breakout signals evaluated each tick" Foreground="#8090A0" FontSize="12"/>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="After 12:45" Foreground="#8090A0" FontSize="12"/>
                                            <TextBlock Grid.Column="1" Text="Window closed — late entries suppressed to avoid choppy afternoon action" Foreground="#8090A0" FontSize="12"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <TextBlock TextWrapping="Wrap" Foreground="#8090A0" FontSize="12" LineHeight="17" Margin="0,0,0,6">A <Run Foreground="White" FontWeight="SemiBold">BULL</Run> signal fires when the bar close exceeds the OR high <Run FontStyle="Italic">and</Run> volume is ≥ 1.2× its 20-bar average. A <Run Foreground="White" FontWeight="SemiBold">BEAR</Run> signal fires when the close falls below the OR low with the same volume confirmation. <Run Foreground="White" FontWeight="SemiBold">WAIT</Run> means a breakout occurred without sufficient volume. <Run Foreground="White" FontWeight="SemiBold">WIDE</Run> means the OR exceeded 2× ATR(14) — the range is too large to offer a reliable R:R and is skipped.</TextBlock>
                                <TextBlock TextWrapping="Wrap" Foreground="#8090A0" FontSize="12" LineHeight="17">Stop = opposite extreme of the OR. Target = 1.5× OR width (minimum 1:1.5 R:R). <Run Foreground="White" FontWeight="SemiBold">This view shows signals only</Run> — ORB order placement is a separate feature.</TextBlock>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>
            </Border>
            <!-- ── Header: row 1 = selectors, row 2 = start/stop, AI, AI summary ── -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="6" Padding="14,10" Margin="0,8,0,0"
                    BorderBrush="{StaticResource AccentBrush}" BorderThickness="0,0,0,2">
                <StackPanel>

                    <!-- Row 1: Account, Timeframe, Entry Mode -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding Accounts}"
                                  SelectedItem="{Binding SelectedAccount}"
                                  DisplayMemberPath="DisplayName"
                                  Width="160" VerticalAlignment="Center"/>

                        <ComboBox Grid.Column="2"
                                  ItemsSource="{Binding Timeframes}"
                                  SelectedItem="{Binding SelectedTimeframe}"
                                  Width="90" VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Entry on Trend Arrow reversal — "
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <RadioButton Content="On Bar Close"
                                         IsChecked="{Binding UseEarlyMode, Converter={StaticResource BoolInverseConverter}}"
                                         Foreground="White" FontSize="12" Margin="0,0,8,0"
                                         ToolTip="Wait for the bar to fully close before entering. More conservative — avoids false flips mid-bar."/>
                            <RadioButton Content="Pre-emptive early entry"
                                         IsChecked="{Binding UseEarlyMode}"
                                         Foreground="Gold" FontSize="12" Margin="0,0,0,0"
                                         ToolTip="Enter before bar close using multi-timeframe reversal anticipation (5min + 15min + 1hr alignment). Higher reward potential but more exposure to mid-bar noise."/>
                            <Border Width="1" Background="#3A5A8A" Margin="12,2,12,2"/>
                            <CheckBox Content="🐞 Debug Capture"
                                      IsChecked="{Binding IsDebugCaptureEnabled, Mode=TwoWay}"
                                      Foreground="#FFB74D" FontSize="12" VerticalAlignment="Center"
                                      ToolTip="Records every 15-second tick + SL/AI/exit events for each open trade to debug_trades.db. Default OFF."/>
                        </StackPanel>
                    </Grid>

                    <!-- Row 2: Persona buttons, AI toggle, Start/Stop, status -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>  <!-- 0  Lewis -->
                            <ColumnDefinition Width="6"/>     <!-- 1  gap -->
                            <ColumnDefinition Width="Auto"/>  <!-- 2  Damian -->
                            <ColumnDefinition Width="6"/>     <!-- 3  gap -->
                            <ColumnDefinition Width="Auto"/>  <!-- 4  Joe -->
                            <ColumnDefinition Width="12"/>    <!-- 5  gap -->
                            <ColumnDefinition Width="Auto"/>  <!-- 6  AI toggle -->
                            <ColumnDefinition Width="8"/>     <!-- 7  gap -->
                            <ColumnDefinition Width="Auto"/>  <!-- 8  Start/Stop -->
                            <ColumnDefinition Width="*"/>     <!-- 9  stretch -->
                            <ColumnDefinition Width="Auto"/>  <!-- 10 Status badge -->
                        </Grid.ColumnDefinitions>

                        <!-- Lewis persona button -->
                        <Button Grid.Column="0"
                                Content="Lewis"
                                Command="{Binding SelectLewisCommand}"
                                Padding="12,6" VerticalAlignment="Center"
                                ToolTip="Risk-averse: MinADX 40, ST×3.5, RR 0.75">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="#2A3A5A"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                    <Setter Property="BorderBrush" Value="#3A5A8A"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLewisSelected}" Value="True">
                                            <Setter Property="Background" Value="#1565C0"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#42A5F5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Damian persona button -->
                        <Button Grid.Column="2"
                                Content="Damian"
                                Command="{Binding SelectDamianCommand}"
                                Padding="12,6" VerticalAlignment="Center"
                                ToolTip="Balanced: MinADX 30, ST×3.0, RR 1.5">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="#2A3A5A"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                    <Setter Property="BorderBrush" Value="#3A5A8A"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDamianSelected}" Value="True">
                                            <Setter Property="Background" Value="#1565C0"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#42A5F5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Joe persona button -->
                        <Button Grid.Column="4"
                                Content="Joe"
                                Command="{Binding SelectJoeCommand}"
                                Padding="12,6" VerticalAlignment="Center"
                                ToolTip="Reward-seeking: MinADX 20, ST×2.5, RR 2.0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="#2A3A5A"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                    <Setter Property="BorderBrush" Value="#3A5A8A"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsJoeSelected}" Value="True">
                                            <Setter Property="Background" Value="#1565C0"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#42A5F5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- AI On/Off toggle -->
                        <ToggleButton Grid.Column="6"
                                      IsChecked="{Binding IsAiEnabled, Mode=TwoWay}"
                                      ToolTip="Claude Haiku AI sense-check before each order. Resets to Off on restart."
                                      Padding="10,6" VerticalAlignment="Center">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Background"   Value="#1565C0"/>
                                    <Setter Property="BorderBrush"  Value="#1976D2"/>
                                    <Setter Property="Foreground"   Value="White"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Cursor"       Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="3"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter Property="Background"  Value="#C62828"/>
                                            <Setter Property="BorderBrush" Value="#E53935"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ToggleButton.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F916;" FontSize="14" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="White"/>
                                <TextBlock VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="White">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="AI Off"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAiEnabled}" Value="True">
                                                    <Setter Property="Text" Value="AI On"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </ToggleButton>

                        <!-- Start / Stop button -->
                        <Button Grid.Column="8"
                                Content="{Binding StartStopLabel}"
                                Command="{Binding StartStopCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Padding="14,6" VerticalAlignment="Center"/>

                        <!-- Status badge -->
                        <Border Grid.Column="10"
                                Background="{Binding StatusBackground}"
                                CornerRadius="4" Margin="8,0,0,0"
                                Visibility="{Binding StatusVisibility}"
                                VerticalAlignment="Center" Padding="8,4">
                            <TextBlock x:Name="StatusLabel"
                                       Text="{Binding StatusText}"
                                       Foreground="White" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                </StackPanel>
            </Border>


            <!-- ORB phase banner (visible 09:00-17:00 ET on weekdays) -->
            <Border Margin="0,8,0,0" CornerRadius="6" Padding="10,7"
                    Background="#16213A" BorderBrush="#3A5A8A" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsOrbBannerVisible}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding OrbPhaseLabel}"
                           Foreground="#90CAF9" FontSize="12" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </Border>
            <!-- â”€â”€ Watchlist panel â”€â”€ -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="6" Padding="14,10" Margin="0,10,0,0"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- column header -->
                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Symbol"    Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="Trend"     Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2" Text="Signal"    Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="3" Text="Strength"  Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="4" Text="+DI / -DI" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="5" Text="ORB Range" Foreground="#5C8FBF"    FontSize="11" FontWeight="SemiBold"
                                   ToolTip="Opening Range high / low (equity index futures, 5-min, 09:30–10:00 ET)"/>
                        <TextBlock Grid.Column="6" Text="ORB"       Foreground="#5C8FBF"    FontSize="11" FontWeight="SemiBold"
                                   ToolTip="ORB signal: BULL / BEAR / WAIT / BUILDING / WIDE / CLOSED"/>
                        <TextBlock Grid.Column="7" Text="What this means" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
                    </Grid>

                    <!-- rows -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding WatchlistItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Label, Mode=OneWay}"
                                               Foreground="White"
                                               FontFamily="Consolas" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Arrow, Mode=OneWay}"
                                               Foreground="{Binding RowColor}"
                                               FontFamily="Consolas" FontSize="13" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Signal, Mode=OneWay}"
                                               Foreground="{Binding RowColor}"
                                               FontFamily="Consolas" FontSize="12"/>
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding TrendStrength, Mode=OneWay}"
                                               Foreground="{Binding RowColor}"
                                               FontFamily="Consolas" FontSize="12"/>
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding DiDisplay, Mode=OneWay}"
                                               Foreground="{Binding RowColor}"
                                               FontFamily="Consolas" FontSize="12"/>
                                    <!-- ORB Range: shown for equity index instruments only -->
                                    <TextBlock Grid.Column="5"
                                               Text="{Binding OrbRangeDisplay, Mode=OneWay}"
                                               Foreground="{Binding OrbRowColor}"
                                               FontFamily="Consolas" FontSize="11"
                                               VerticalAlignment="Center"/>
                                    <!-- ORB Signal badge -->
                                    <Border Grid.Column="6" CornerRadius="3" Padding="4,2"
                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding OrbSignal}" Value="BULL">
                                                        <Setter Property="Background" Value="#1A3A1A"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding OrbSignal}" Value="BEAR">
                                                        <Setter Property="Background" Value="#3A1A1A"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding OrbSignal}" Value="BUILDING">
                                                        <Setter Property="Background" Value="#2A2000"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding OrbSignal}" Value="WIDE">
                                                        <Setter Property="Background" Value="#2A1800"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding OrbSignal, Mode=OneWay}"
                                                   Foreground="{Binding OrbRowColor}"
                                                   FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                    <TextBlock Grid.Column="7"
                                               Text="{Binding SignalReason, Mode=OneWay}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11" TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- ── Three slot cards ── -->
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <controls:SlotCardControl Grid.Column="0"
                                          DataContext="{Binding Slot1}"
                                          AiCommand="{Binding DataContext.AiCheckSlot1Command,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"/>

                <controls:SlotCardControl Grid.Column="2"
                                          DataContext="{Binding Slot2}"
                                          AiCommand="{Binding DataContext.AiCheckSlot2Command,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"/>

                <controls:SlotCardControl Grid.Column="4"
                                          DataContext="{Binding Slot3}"
                                          AiCommand="{Binding DataContext.AiCheckSlot3Command,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            </Grid>

            <!-- ── AI Check History Log ── -->
            <Border Margin="0,14,0,0"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="6" BorderBrush="#1565C0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition MaxHeight="200"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Background="#0D47A1" CornerRadius="5,5,0,0" Padding="10,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F916;" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="White"/>
                            <TextBlock Text="AI Check History" Foreground="White" FontSize="12"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Scrolling log -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding AiHistoryLog}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#263238" BorderThickness="0,0,0,1" Padding="10,5">
                                        <TextBlock Foreground="{Binding EntryColour}"
                                                   FontFamily="Consolas" FontSize="11"
                                                   Text="{Binding Display}"
                                                   TextWrapping="Wrap"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
