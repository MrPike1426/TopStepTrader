<UserControl x:Class="TopStepTrader.UI.Views.SuperTrendPlusView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:TopStepTrader.UI.Infrastructure"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,8">

            <!-- ── Page title + How-It-Works toggle on same row ── -->
            <Grid Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="&#x1F4C8;  SuperTrend+"
                           Style="{StaticResource PageTitleStyle}"
                           VerticalAlignment="Center"/>

                <Border Grid.Column="2"
                        Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6"
                        BorderBrush="#3A5A8A" BorderThickness="1"
                        VerticalAlignment="Center">
                    <ToggleButton x:Name="HowItWorksToggle"
                                  IsChecked="{Binding IsHowItWorksExpanded, Mode=TwoWay}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Cursor="Hand"
                                  Padding="12,6"
                                  HorizontalContentAlignment="Stretch">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4A1;" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="How does SuperTrend+ Autopilot work?"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock VerticalAlignment="Center" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="&#x25B2; hide"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, ElementName=HowItWorksToggle}" Value="False">
                                                <Setter Property="Text" Value="&#x25BC; show"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </ToggleButton>
                </Border>
            </Grid>

            <!-- How-It-Works collapsible body -->
            <Border Margin="0,6,0,0"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="6"
                    BorderBrush="#3A5A8A" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChecked, ElementName=HowItWorksToggle}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border Padding="16,6,16,16">
                    <StackPanel>

                        <!-- ── Personas ── -->
                        <Border Background="#16213A" CornerRadius="6" Padding="14,10" Margin="0,4,0,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="&#x1F464;" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Trading Personas" Foreground="White" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock Text="  —  choose before starting" Foreground="#607080" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Three persona cards -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Lewis -->
                                    <Border Grid.Column="0" Background="#0D1B2E" CornerRadius="5" Padding="10,8"
                                            BorderBrush="#1565C0" BorderThickness="1,3,1,1">
                                        <StackPanel>
                                            <TextBlock Text="Lewis" Foreground="#42A5F5" FontSize="12" FontWeight="Bold" Margin="0,0,0,4"/>
                                            <TextBlock Text="Risk-Averse" Foreground="#90CAF9" FontSize="10" Margin="0,0,0,6"/>
                                            <TextBlock Foreground="#8090A0" FontSize="10" LineHeight="16">
                                                <Run Foreground="White" FontWeight="SemiBold">Min ADX</Run>  40+&#xA;<Run Foreground="White" FontWeight="SemiBold">ST mult</Run>    3.5×&#xA;<Run Foreground="White" FontWeight="SemiBold">RR target</Run>  0.75&#xA;<Run Foreground="White" FontWeight="SemiBold">Entries</Run>    Latte / Espresso
                                            </TextBlock>
                                            <Border Background="#0A1520" CornerRadius="3" Padding="6,4" Margin="0,6,0,0">
                                                <TextBlock TextWrapping="Wrap" Foreground="#607080" FontSize="10" LineHeight="15">Fewer, higher-conviction entries. Tight selectivity with capital preservation as the primary goal.</TextBlock>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- Damian -->
                                    <Border Grid.Column="2" Background="#0D1B2E" CornerRadius="5" Padding="10,8"
                                            BorderBrush="#2E7D32" BorderThickness="1,3,1,1">
                                        <StackPanel>
                                            <TextBlock Text="Damian" Foreground="#66BB6A" FontSize="12" FontWeight="Bold" Margin="0,0,0,4"/>
                                            <TextBlock Text="Balanced  (default)" Foreground="#A5D6A7" FontSize="10" Margin="0,0,0,6"/>
                                            <TextBlock Foreground="#8090A0" FontSize="10" LineHeight="16">
                                                <Run Foreground="White" FontWeight="SemiBold">Min ADX</Run>  30+&#xA;<Run Foreground="White" FontWeight="SemiBold">ST mult</Run>    3.0×&#xA;<Run Foreground="White" FontWeight="SemiBold">RR target</Run>  1.5&#xA;<Run Foreground="White" FontWeight="SemiBold">Entries</Run>    All bands ≥ 30
                                            </TextBlock>
                                            <Border Background="#0A1520" CornerRadius="3" Padding="6,4" Margin="0,6,0,0">
                                                <TextBlock TextWrapping="Wrap" Foreground="#607080" FontSize="10" LineHeight="15">Balanced mix of frequency and quality. Momentum and continuation setups across all trend bands.</TextBlock>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- Joe -->
                                    <Border Grid.Column="4" Background="#0D1B2E" CornerRadius="5" Padding="10,8"
                                            BorderBrush="#E65100" BorderThickness="1,3,1,1">
                                        <StackPanel>
                                            <TextBlock Text="Joe" Foreground="#FFA726" FontSize="12" FontWeight="Bold" Margin="0,0,0,4"/>
                                            <TextBlock Text="Reward-Seeking" Foreground="#FFCC80" FontSize="10" Margin="0,0,0,6"/>
                                            <TextBlock Foreground="#8090A0" FontSize="10" LineHeight="16">
                                                <Run Foreground="White" FontWeight="SemiBold">Min ADX</Run>  20+&#xA;<Run Foreground="White" FontWeight="SemiBold">ST mult</Run>    2.5×&#xA;<Run Foreground="White" FontWeight="SemiBold">RR target</Run>  2.0&#xA;<Run Foreground="White" FontWeight="SemiBold">Entries</Run>    All bands ≥ 20
                                            </TextBlock>
                                            <Border Background="#0A1520" CornerRadius="3" Padding="6,4" Margin="0,6,0,0">
                                                <TextBlock TextWrapping="Wrap" Foreground="#607080" FontSize="10" LineHeight="15">Higher frequency, wider signals. Accepts more losses in exchange for larger winners. Precise entries critical.</TextBlock>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#607080" FontSize="10" LineHeight="15">
                                    <Run Foreground="#FFD54F" FontWeight="SemiBold">RR Target</Run> is a visual milestone only — no hard take-profit bracket is placed. The position runs until the trend weakens, managed entirely by the phased stop system. When the RR target is reached the slot title turns gold.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- ── Monitoring ── -->
                        <Border Background="#16213A" CornerRadius="6" Padding="14,10" Margin="0,0,0,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="&#x1F4E1;" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Monitoring" Foreground="White" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" Foreground="#8090A0" FontSize="11" LineHeight="17">Every 15 seconds SuperTrend+ scans all watchlist instruments on the selected timeframe. For each it computes the SuperTrend line, ADX, and Directional Indicators (+DI / -DI) to classify trend direction and strength. The watchlist updates live; the three slot boxes track any open positions.</TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- ── Signal Detection ── -->
                        <Border Background="#16213A" CornerRadius="6" Padding="14,10" Margin="0,0,0,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="&#x1F50D;" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Signal Detection" Foreground="White" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" Foreground="#8090A0" FontSize="11" LineHeight="17" Margin="0,0,0,6">A trade signal qualifies when all three conditions are met:</TextBlock>
                                <Border Background="#1A2440" CornerRadius="4" Padding="10,8" Margin="0,0,0,6">
                                    <StackPanel>
                                        <TextBlock Foreground="#8090A0" FontSize="11" LineHeight="18" Margin="0,0,0,2">
                                            <Run Foreground="#42A5F5" FontWeight="SemiBold">&#x2460;  SuperTrend direction</Run>  — price above ST line (long) or below (short)
                                        </TextBlock>
                                        <TextBlock Foreground="#8090A0" FontSize="11" LineHeight="18" Margin="0,0,0,2">
                                            <Run Foreground="#42A5F5" FontWeight="SemiBold">&#x2461;  DI alignment</Run>  — +DI &gt; −DI confirms long; −DI &gt; +DI confirms short
                                        </TextBlock>
                                        <TextBlock Foreground="#8090A0" FontSize="11" LineHeight="18">
                                            <Run Foreground="#42A5F5" FontWeight="SemiBold">&#x2462;  ADX gate</Run>  — ADX at or above the active persona's minimum (Lewis 40 / Damian 30 / Joe 20)
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                                <TextBlock TextWrapping="Wrap" Foreground="#607080" FontSize="10" LineHeight="15">In <Run Foreground="Gold" FontWeight="SemiBold">Early</Run> mode a fourth trigger is checked: multi-timeframe reversal anticipation (5min + 15min + 1hr alignment). In <Run Foreground="White" FontWeight="SemiBold">Confirmed</Run> mode only the bar-close signal is used.</TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- ── ADX Bands &amp; Contract Sizing ── -->
                        <Border Background="#16213A" CornerRadius="6" Padding="14,10" Margin="0,0,0,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="&#x2615;" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="ADX Bands &amp; Contract Sizing" Foreground="White" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" Foreground="#8090A0" FontSize="11" LineHeight="17" Margin="0,0,0,8">The ADX value at entry determines how many contracts the bot places. Bands are fixed regardless of persona — the persona only controls which bands are reachable via its ADX gate.</TextBlock>

                                <!-- Band cards -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="#1A2440" CornerRadius="4" Padding="10,8" BorderBrush="#2A3A5A" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="L1  Decaff" Foreground="#90CAF9" FontSize="11" FontWeight="Bold" Margin="0,0,0,3"/>
                                            <TextBlock Text="ADX 25 – 39" Foreground="#607080" FontSize="10" Margin="0,0,0,5"/>
                                            <Border Background="#0D1520" CornerRadius="3" Padding="8,5">
                                                <TextBlock Text="1 contract" Foreground="White" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="Mild trend. Damian and Joe may enter here." Foreground="#607080" FontSize="10" LineHeight="14" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" Background="#1A2440" CornerRadius="4" Padding="10,8" BorderBrush="#1565C0" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="L2  Latte" Foreground="#42A5F5" FontSize="11" FontWeight="Bold" Margin="0,0,0,3"/>
                                            <TextBlock Text="ADX 40 – 59" Foreground="#607080" FontSize="10" Margin="0,0,0,5"/>
                                            <Border Background="#0D1520" CornerRadius="3" Padding="8,5">
                                                <TextBlock Text="2 contracts" Foreground="White" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="Solid momentum. All personas may enter here." Foreground="#607080" FontSize="10" LineHeight="14" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="4" Background="#1A2440" CornerRadius="4" Padding="10,8" BorderBrush="#E65100" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="L3  Espresso" Foreground="#FFA726" FontSize="11" FontWeight="Bold" Margin="0,0,0,3"/>
                                            <TextBlock Text="ADX 60+" Foreground="#607080" FontSize="10" Margin="0,0,0,5"/>
                                            <Border Background="#0D1520" CornerRadius="3" Padding="8,5">
                                                <TextBlock Text="3 contracts" Foreground="White" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="High-conviction trend. All personas size up here." Foreground="#607080" FontSize="10" LineHeight="14" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <TextBlock TextWrapping="Wrap" Foreground="#607080" FontSize="10" LineHeight="15">Up to <Run Foreground="White" FontWeight="SemiBold">3 concurrent slots</Run> can be open across different instruments simultaneously. If ADX rises while a position is open, the bot scale-ins +1 contract to match the new band. If ADX falls mid-trade, exit management handles the position — contracts are never automatically reduced.</TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- ── Stop Phases ── -->
                        <Border Background="#16213A" CornerRadius="6" Padding="14,10" Margin="0,0,0,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="&#x1F6E1;" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Trade Management — Stop Phases" Foreground="White" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" Foreground="#8090A0" FontSize="11" LineHeight="17" Margin="0,0,0,8">
                                    There is <Run Foreground="White" FontWeight="SemiBold">no hard take-profit order</Run>. Every position is managed by a ratcheting stop that advances through six phases as profit grows. The stop never moves back.  <Run Foreground="#90CAF9">R = initial risk (entry price − stop at entry).</Run>
                                </TextBlock>

                                <!-- Phase timeline -->
                                <Border Background="#1A2440" CornerRadius="4" Padding="10,8">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Phase" Foreground="#42A5F5" FontSize="10" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="1" Text="Trigger" Foreground="#42A5F5" FontSize="10" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="2" Text="Stop moves to…" Foreground="#42A5F5" FontSize="10" FontWeight="SemiBold"/>
                                        </Grid>
                                        <Rectangle Height="1" Fill="#2A3A5A" Margin="0,0,0,4"/>
                                        <Grid Margin="0,0,0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Initial"      Foreground="#8090A0" FontSize="10"/>
                                            <TextBlock Grid.Column="1" Text="Entry"        Foreground="#607080" FontSize="10"/>
                                            <TextBlock Grid.Column="2" Text="SuperTrend line (follows trend)"  Foreground="#8090A0" FontSize="10"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Breakeven"   Foreground="#A5D6A7" FontSize="10"/>
                                            <TextBlock Grid.Column="1" Text="0.5R profit" Foreground="#607080" FontSize="10"/>
                                            <TextBlock Grid.Column="2" Text="Exact entry price — risk eliminated"  Foreground="#8090A0" FontSize="10"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="ProfitLock"  Foreground="#66BB6A" FontSize="10"/>
                                            <TextBlock Grid.Column="1" Text="1R profit"   Foreground="#607080" FontSize="10"/>
                                            <TextBlock Grid.Column="2" Text="Entry + 0.3R — partial profit banked"  Foreground="#8090A0" FontSize="10"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="ProfitTrail" Foreground="#FFD54F" FontSize="10"/>
                                            <TextBlock Grid.Column="1" Text="1.5R profit" Foreground="#607080" FontSize="10"/>
                                            <TextBlock Grid.Column="2" Text="ATR-based trailing stop — rides the move"  Foreground="#8090A0" FontSize="10"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Harvest"     Foreground="#FFA726" FontSize="10"/>
                                            <TextBlock Grid.Column="1" Text="2R profit"   Foreground="#607080" FontSize="10"/>
                                            <TextBlock Grid.Column="2" Text="Entry + 1.5R — locked in"  Foreground="#8090A0" FontSize="10"/>
                                        </Grid>
                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="FreeRide" Foreground="Gold" FontSize="10" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Text="3R profit"   Foreground="#607080" FontSize="10"/>
                                            <TextBlock Grid.Column="2" Text="Entry + 2R — house money, let it run"  Foreground="#8090A0" FontSize="10"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Foreground="#607080" FontSize="10" LineHeight="15">
                                    <Run Foreground="#FFD54F" FontWeight="SemiBold">Gold title bar</Run> lights up on a slot when the position P&amp;L reaches the active persona's RR target — the trade is now in extra profit. The stop phases continue advancing automatically until exit.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- ── Degradation Signals ── -->
                        <Border Background="#16213A" CornerRadius="6" Padding="14,10" Margin="0,0,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="&#x26A0;" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="Gold"/>
                                    <TextBlock Text="Intelligent Exit — Degradation Signals" Foreground="White" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" Foreground="#8090A0" FontSize="11" LineHeight="17" Margin="0,0,0,6">Nine signals are scored every bar. When the combined score crosses a threshold the slot health changes colour and an exit is triggered.</TextBlock>

                                <Border Background="#1A2440" CornerRadius="4" Padding="10,8" Margin="0,0,0,6">
                                    <StackPanel>
                                        <TextBlock Foreground="#EF9A9A" FontSize="10" LineHeight="17">E1  <Run FontWeight="SemiBold">(8 pts)</Run>  SuperTrend Flip — trend reversed — immediate exit</TextBlock>
                                        <TextBlock Foreground="#8090A0" FontSize="10" LineHeight="17">E2  <Run FontWeight="SemiBold">(3 pts)</Run>  Momentum Slowing — price converging toward ST line &gt; 0.5×ATR over 3 bars</TextBlock>
                                        <TextBlock Foreground="#8090A0" FontSize="10" LineHeight="17">E3  <Run FontWeight="SemiBold">(2 pts)</Run>  ADX Declining — ADX falling for 2 bars and 10+ pts below entry ADX</TextBlock>
                                        <TextBlock Foreground="#8090A0" FontSize="10" LineHeight="17">E4  <Run FontWeight="SemiBold">(2 pts)</Run>  DI Compression — DI spread narrowed ≥15% in one bar</TextBlock>
                                        <TextBlock Foreground="#FFCC80" FontSize="10" LineHeight="17">E5  <Run FontWeight="SemiBold">(4 pts)</Run>  DI Crossover — +DI/−DI crossed against trade direction</TextBlock>
                                        <TextBlock Foreground="#8090A0" FontSize="10" LineHeight="17">E6  <Run FontWeight="SemiBold">(2 pts)</Run>  Rejection Bar — wick &gt; 2× body, close past bar midpoint</TextBlock>
                                        <TextBlock Foreground="#8090A0" FontSize="10" LineHeight="17">E7  <Run FontWeight="SemiBold">(1 pt)</Run>   ATR Contraction — ATR falling for 2 bars and below 80% of entry ATR</TextBlock>
                                        <TextBlock Foreground="#8090A0" FontSize="10" LineHeight="17">E8  <Run FontWeight="SemiBold">(2 pts)</Run>  VWAP Cross — price crossed VWAP against trade direction</TextBlock>
                                        <TextBlock Foreground="#8090A0" FontSize="10" LineHeight="17">E9  <Run FontWeight="SemiBold">(3 pts)</Run>  RSI Hidden Divergence — price / RSI diverging against the trade</TextBlock>
                                    </StackPanel>
                                </Border>

                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#2D2000" CornerRadius="3" Padding="8,4" Margin="0,0,8,0">
                                        <TextBlock Foreground="Gold" FontSize="10" FontWeight="SemiBold">&#x25CF;  Score 3–5  Warning</TextBlock>
                                    </Border>
                                    <TextBlock Foreground="#607080" FontSize="10" VerticalAlignment="Center" Margin="0,0,12,0">Degradation building — no new slots open</TextBlock>
                                    <Border Background="#2D0A00" CornerRadius="3" Padding="8,4">
                                        <TextBlock Foreground="OrangeRed" FontSize="10" FontWeight="SemiBold">&#x25CF;  Score 6+  Exiting</TextBlock>
                                    </Border>
                                    <TextBlock Foreground="#607080" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0">Exit on next closed bar</TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>
            </Border>
            <!-- ── Header: row 1 = selectors, row 2 = start/stop, AI, AI summary ── -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="6" Padding="14,10" Margin="0,8,0,0"
                    BorderBrush="{StaticResource AccentBrush}" BorderThickness="0,0,0,2">
                <StackPanel>

                    <!-- Row 1: Account, Timeframe, Entry Mode -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding Accounts}"
                                  SelectedItem="{Binding SelectedAccount}"
                                  DisplayMemberPath="DisplayName"
                                  Width="160" VerticalAlignment="Center"/>

                        <ComboBox Grid.Column="2"
                                  ItemsSource="{Binding Timeframes}"
                                  SelectedItem="{Binding SelectedTimeframe}"
                                  Width="90" VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                            <RadioButton Content="Confirmed"
                                         IsChecked="{Binding UseEarlyMode, Converter={StaticResource BoolInverseConverter}}"
                                         Foreground="White" FontSize="11" Margin="0,0,8,0"/>
                            <RadioButton Content="Early (Multi-Signal)"
                                         IsChecked="{Binding UseEarlyMode}"
                                         Foreground="Gold" FontSize="11" Margin="0,0,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Row 2: Persona buttons, AI toggle, Start/Stop, status -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Lewis persona button -->
                        <Button Grid.Column="0"
                                Content="Lewis"
                                Command="{Binding SelectLewisCommand}"
                                Padding="12,6" VerticalAlignment="Center"
                                ToolTip="Risk-averse: MinADX 40, ST×3.5, RR 0.75">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="#2A3A5A"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                    <Setter Property="BorderBrush" Value="#3A5A8A"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLewisSelected}" Value="True">
                                            <Setter Property="Background" Value="#1565C0"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#42A5F5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Damian persona button -->
                        <Button Grid.Column="2"
                                Content="Damian"
                                Command="{Binding SelectDamianCommand}"
                                Padding="12,6" VerticalAlignment="Center"
                                ToolTip="Balanced: MinADX 30, ST×3.0, RR 1.5">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="#2A3A5A"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                    <Setter Property="BorderBrush" Value="#3A5A8A"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDamianSelected}" Value="True">
                                            <Setter Property="Background" Value="#1565C0"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#42A5F5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Joe persona button -->
                        <Button Grid.Column="4"
                                Content="Joe"
                                Command="{Binding SelectJoeCommand}"
                                Padding="12,6" VerticalAlignment="Center"
                                ToolTip="Reward-seeking: MinADX 20, ST×2.5, RR 2.0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="#2A3A5A"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                    <Setter Property="BorderBrush" Value="#3A5A8A"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsJoeSelected}" Value="True">
                                            <Setter Property="Background" Value="#1565C0"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#42A5F5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- AI On/Off toggle -->
                        <ToggleButton Grid.Column="6"
                                      IsChecked="{Binding IsAiEnabled, Mode=TwoWay}"
                                      ToolTip="Claude Haiku AI sense-check before each order. Resets to Off on restart."
                                      Padding="10,6" VerticalAlignment="Center">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Background"   Value="#1565C0"/>
                                    <Setter Property="BorderBrush"  Value="#1976D2"/>
                                    <Setter Property="Foreground"   Value="White"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Cursor"       Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="3"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter Property="Background"  Value="#C62828"/>
                                            <Setter Property="BorderBrush" Value="#E53935"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ToggleButton.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F916;" FontSize="14" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="White"/>
                                <TextBlock VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="White">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="AI Off"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAiEnabled}" Value="True">
                                                    <Setter Property="Text" Value="AI On"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </ToggleButton>

                        <!-- Start / Stop button -->
                        <Button Grid.Column="8"
                                Content="{Binding StartStopLabel}"
                                Command="{Binding StartStopCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Padding="14,6" VerticalAlignment="Center"/>

                        <!-- Status badge -->
                        <Border Grid.Column="10"
                                Background="{Binding StatusBackground}"
                                CornerRadius="4" Margin="8,0,0,0"
                                Visibility="{Binding StatusVisibility}"
                                VerticalAlignment="Center" Padding="8,4">
                            <TextBlock x:Name="StatusLabel"
                                       Text="{Binding StatusText}"
                                       Foreground="White" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- â”€â”€ Watchlist panel â”€â”€ -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="6" Padding="14,10" Margin="0,10,0,0"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- column header -->
                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Symbol"    Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="Trend"     Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="Signal"    Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="3" Text="Strength"  Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="4" Text="+DI / -DI" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="5" Text="What this means" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
                    </Grid>

                    <!-- rows -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding WatchlistItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Label, Mode=OneWay}"
                                               Foreground="White"
                                               FontFamily="Consolas" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Arrow, Mode=OneWay}"
                                               Foreground="{Binding RowColor}"
                                               FontFamily="Consolas" FontSize="13" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Signal, Mode=OneWay}"
                                               Foreground="{Binding RowColor}"
                                               FontFamily="Consolas" FontSize="12"/>
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding TrendStrength, Mode=OneWay}"
                                               Foreground="{Binding RowColor}"
                                               FontFamily="Consolas" FontSize="12"/>
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding DiDisplay, Mode=OneWay}"
                                               Foreground="{Binding RowColor}"
                                               FontFamily="Consolas" FontSize="12"/>
                                    <TextBlock Grid.Column="5"
                                               Text="{Binding SignalReason, Mode=OneWay}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11" TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- ── Three slot boxes ── -->
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Slot 1 box -->
                <Border Grid.Column="0"
                        Opacity="{Binding Slot1.BoxOpacity}"
                        Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Padding="12,10"
                        BorderBrush="{Binding Slot1.PnlBorderBrush}"
                        BorderThickness="3">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Slot1.IsBorderFlashing}" Value="True">
                                    <Setter Property="BorderBrush" Value="White"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Slot1.IsPnlFlashing}" Value="True">
                                    <Setter Property="BorderBrush" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Gold title bar background — lights up when RR target is reached -->
                        <Border Grid.Row="0"
                                Margin="-12,-10,-12,6"
                                Background="{Binding Slot1.TitleBarBackground}"
                                CornerRadius="6,6,0,0"/>

                        <!-- Header: instrument + direction + entry time, P&L right-aligned -->
                        <Grid Grid.Row="0" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Slot1.SlotLabel}"
                                       FontWeight="Bold" Foreground="White" FontSize="12"
                                       TextWrapping="Wrap"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                <TextBlock Text="&#x23F8; Paused"
                                           Visibility="{Binding Slot1.PausedBadgeVisibility}"
                                           Foreground="Orange" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <!-- P&L inline with header when position is open -->
                                <TextBlock Visibility="{Binding Slot1.PositionVisibility}"
                                           FontFamily="Consolas" FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{Binding Slot1.PnlTextBrush}"/>
                                            <Setter Property="FontWeight" Value="Normal"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Slot1.IsPnlTextFlashing}" Value="True">
                                                    <Setter Property="Foreground" Value="Yellow"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <Run Text="{Binding Slot1.PnlLine, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>

                        <Separator Grid.Row="1" Margin="0,0,0,6"/>

                        <!-- Symbol rows (ADX + signal watchlist) -->
                        <ItemsControl Grid.Row="2" ItemsSource="{Binding Slot1.Symbols}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="0,2"
                                               Foreground="{Binding RowColor}"
                                               FontFamily="Consolas" FontSize="12">
                                        <Run Text="{Binding Symbol, Mode=OneWay}"/>
                                        <Run Text="  "/>
                                        <Run Text="{Binding Arrow, Mode=OneWay}"/>
                                        <Run Text="  "/>
                                        <Run Text="{Binding AdxDisplay, Mode=OneWay}"/>
                                        <Run Text="  "/>
                                        <Run Text="{Binding Signal, Mode=OneWay}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Idle monitoring text (shown when no position is open) -->
                        <Border Grid.Row="3"
                                Visibility="{Binding Slot1.IdleVisibility}"
                                Padding="0,6,0,0">
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"       Value="{Binding Slot1.IdleMonitorText}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                        <Setter Property="FontFamily" Value="Consolas"/>
                                        <Setter Property="FontSize"   Value="10"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Slot1.IsIdleFlashing}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <!-- Position area: SP/SL/TP, entry reason, phase -->
                        <Border Grid.Row="4"
                                Visibility="{Binding Slot1.PositionVisibility}"
                                Background="#1A2A50" CornerRadius="4"
                                Padding="8,6" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding Slot1.PositionDisplay}"
                                           Foreground="White"
                                           FontFamily="Consolas" FontSize="12"
                                           TextWrapping="Wrap"/>
                                <TextBlock Margin="0,4,0,0"
                                           FontFamily="Consolas" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap">
                                    <Run Text="Phase: "/><Run Text="{Binding Slot1.StopPhaseLabel, Mode=OneWay}" Foreground="Gold"/>
                                </TextBlock>

                                <!-- Target P&L (shown from position open) -->
                                <TextBlock Margin="0,2,0,0"
                                           Text="{Binding Slot1.TargetPnlLine, Mode=OneWay}"
                                           Visibility="{Binding Slot1.TargetPnlVisibility}"
                                           Foreground="#FFD700"
                                           FontFamily="Consolas" FontSize="12"/>

                                <!-- RR Achieved milestone badge -->
                                <Border Margin="0,6,0,0" CornerRadius="4" Padding="6,4"
                                        Visibility="{Binding Slot1.RrAchievedVisibility}"
                                        Background="#2B2000" BorderBrush="#FFD700" BorderThickness="1">
                                    <TextBlock Text="&#x1F3C6; RR Achieved. Boom!!"
                                               Foreground="#FFD700" FontWeight="Bold" FontSize="12"
                                               HorizontalAlignment="Center"/>
                                </Border>

                                <!-- AI mid-trade result -->
                                <Border Margin="0,6,0,0" CornerRadius="4" Padding="6,4"
                                        Visibility="{Binding Slot1.AiResultVisibility}"
                                        BorderBrush="{Binding Slot1.AiVerdictBrush}" BorderThickness="1"
                                        Background="#0D1A2E">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Slot1.AiVerdictText}"
                                                   Foreground="{Binding Slot1.AiVerdictBrush}"
                                                   FontWeight="Bold" FontSize="12"/>
                                        <TextBlock Text="{Binding Slot1.AiExplanation}"
                                                   Foreground="White" FontSize="11"
                                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        <TextBlock FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap">
                                            <Run Text="Action: " Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <Run Text="{Binding Slot1.AiSuggestedAction}" Foreground="Cyan"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- AI sense-check button (blue theme) -->
                        <Button Grid.Row="5" Margin="0,8,0,0" HorizontalAlignment="Stretch"
                                Padding="6,4" FontSize="11"
                                Visibility="{Binding Slot1.PositionVisibility}"
                                IsEnabled="{Binding Slot1.IsAiChecking, Converter={StaticResource BoolInverseConverter}}"
                                Command="{Binding AiCheckSlot1Command}"
                                ToolTip="Ask Claude Haiku to sense-check this live position">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background"  Value="#1565C0"/>
                                    <Setter Property="BorderBrush" Value="#1976D2"/>
                                    <Setter Property="Foreground"  Value="White"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Cursor"      Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="3"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background"  Value="#2E7D32"/>
                                            <Setter Property="BorderBrush" Value="#388E3C"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding Slot1.IsAiChecking}" Value="True">
                                            <Setter Property="Background"  Value="#F57C00"/>
                                            <Setter Property="BorderBrush" Value="#FF9800"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F916;" FontSize="13" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="White"/>
                                <TextBlock VerticalAlignment="Center" Foreground="White">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="AI Sense Check"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Slot1.IsAiChecking}" Value="True">
                                                    <Setter Property="Text" Value="Checking&#x2026;"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- Slot 2 box -->
                <Border Grid.Column="2"
                        Opacity="{Binding Slot2.BoxOpacity}"
                        Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Padding="12,10"
                        BorderBrush="{Binding Slot2.PnlBorderBrush}"
                        BorderThickness="3">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Slot2.IsBorderFlashing}" Value="True">
                                    <Setter Property="BorderBrush" Value="White"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Slot2.IsPnlFlashing}" Value="True">
                                    <Setter Property="BorderBrush" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Gold title bar background — lights up when RR target is reached -->
                        <Border Grid.Row="0"
                                Margin="-12,-10,-12,6"
                                Background="{Binding Slot2.TitleBarBackground}"
                                CornerRadius="6,6,0,0"/>

                        <!-- Header: instrument + direction + entry time, P&L right-aligned -->
                        <Grid Grid.Row="0" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Slot2.SlotLabel}"
                                       FontWeight="Bold" Foreground="White" FontSize="12"
                                       TextWrapping="Wrap"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                <TextBlock Text="&#x23F8; Paused"
                                           Visibility="{Binding Slot2.PausedBadgeVisibility}"
                                           Foreground="Orange" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <!-- P&L inline with header when position is open -->
                                <TextBlock Visibility="{Binding Slot2.PositionVisibility}"
                                           FontFamily="Consolas" FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{Binding Slot2.PnlTextBrush}"/>
                                            <Setter Property="FontWeight" Value="Normal"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Slot2.IsPnlTextFlashing}" Value="True">
                                                    <Setter Property="Foreground" Value="Yellow"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <Run Text="{Binding Slot2.PnlLine, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>

                        <Separator Grid.Row="1" Margin="0,0,0,6"/>

                        <!-- Symbol rows (ADX + signal watchlist) -->
                        <ItemsControl Grid.Row="2" ItemsSource="{Binding Slot2.Symbols}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="0,2"
                                               Foreground="{Binding RowColor}"
                                               FontFamily="Consolas" FontSize="12">
                                        <Run Text="{Binding Symbol, Mode=OneWay}"/>
                                        <Run Text="  "/>
                                        <Run Text="{Binding Arrow, Mode=OneWay}"/>
                                        <Run Text="  "/>
                                        <Run Text="{Binding AdxDisplay, Mode=OneWay}"/>
                                        <Run Text="  "/>
                                        <Run Text="{Binding Signal, Mode=OneWay}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Idle monitoring text (shown when no position is open) -->
                        <Border Grid.Row="3"
                                Visibility="{Binding Slot2.IdleVisibility}"
                                Padding="0,6,0,0">
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"       Value="{Binding Slot2.IdleMonitorText}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                        <Setter Property="FontFamily" Value="Consolas"/>
                                        <Setter Property="FontSize"   Value="10"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Slot2.IsIdleFlashing}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <!-- Position area: SP/SL/TP, entry reason, phase -->
                        <Border Grid.Row="4"
                                Visibility="{Binding Slot2.PositionVisibility}"
                                Background="#1A2A50" CornerRadius="4"
                                Padding="8,6" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding Slot2.PositionDisplay}"
                                           Foreground="White"
                                           FontFamily="Consolas" FontSize="12"
                                           TextWrapping="Wrap"/>
                                <TextBlock Margin="0,4,0,0"
                                           FontFamily="Consolas" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap">
                                    <Run Text="Phase: "/><Run Text="{Binding Slot2.StopPhaseLabel, Mode=OneWay}" Foreground="Gold"/>
                                </TextBlock>

                                <!-- Target P&L (shown from position open) -->
                                <TextBlock Margin="0,2,0,0"
                                           Text="{Binding Slot2.TargetPnlLine, Mode=OneWay}"
                                           Visibility="{Binding Slot2.TargetPnlVisibility}"
                                           Foreground="#FFD700"
                                           FontFamily="Consolas" FontSize="12"/>

                                <!-- RR Achieved milestone badge -->
                                <Border Margin="0,6,0,0" CornerRadius="4" Padding="6,4"
                                        Visibility="{Binding Slot2.RrAchievedVisibility}"
                                        Background="#2B2000" BorderBrush="#FFD700" BorderThickness="1">
                                    <TextBlock Text="&#x1F3C6; RR Achieved. Boom!!"
                                               Foreground="#FFD700" FontWeight="Bold" FontSize="12"
                                               HorizontalAlignment="Center"/>
                                </Border>

                                <!-- AI mid-trade result -->
                                <Border Margin="0,6,0,0" CornerRadius="4" Padding="6,4"
                                        Visibility="{Binding Slot2.AiResultVisibility}"
                                        BorderBrush="{Binding Slot2.AiVerdictBrush}" BorderThickness="1"
                                        Background="#0D1A2E">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Slot2.AiVerdictText}"
                                                   Foreground="{Binding Slot2.AiVerdictBrush}"
                                                   FontWeight="Bold" FontSize="12"/>
                                        <TextBlock Text="{Binding Slot2.AiExplanation}"
                                                   Foreground="White" FontSize="11"
                                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        <TextBlock FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap">
                                            <Run Text="Action: " Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <Run Text="{Binding Slot2.AiSuggestedAction}" Foreground="Cyan"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- AI sense-check button (blue theme) -->
                        <Button Grid.Row="5" Margin="0,8,0,0" HorizontalAlignment="Stretch"
                                Padding="6,4" FontSize="11"
                                Visibility="{Binding Slot2.PositionVisibility}"
                                IsEnabled="{Binding Slot2.IsAiChecking, Converter={StaticResource BoolInverseConverter}}"
                                Command="{Binding AiCheckSlot2Command}"
                                ToolTip="Ask Claude Haiku to sense-check this live position">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background"  Value="#1565C0"/>
                                    <Setter Property="BorderBrush" Value="#1976D2"/>
                                    <Setter Property="Foreground"  Value="White"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Cursor"      Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="3"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background"  Value="#2E7D32"/>
                                            <Setter Property="BorderBrush" Value="#388E3C"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding Slot2.IsAiChecking}" Value="True">
                                            <Setter Property="Background"  Value="#F57C00"/>
                                            <Setter Property="BorderBrush" Value="#FF9800"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F916;" FontSize="13" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="White"/>
                                <TextBlock VerticalAlignment="Center" Foreground="White">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="AI Sense Check"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Slot2.IsAiChecking}" Value="True">
                                                    <Setter Property="Text" Value="Checking&#x2026;"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- Slot 3 box -->
                <Border Grid.Column="4"
                        Opacity="{Binding Slot3.BoxOpacity}"
                        Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Padding="12,10"
                        BorderBrush="{Binding Slot3.PnlBorderBrush}"
                        BorderThickness="3">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Slot3.IsBorderFlashing}" Value="True">
                                    <Setter Property="BorderBrush" Value="White"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Slot3.IsPnlFlashing}" Value="True">
                                    <Setter Property="BorderBrush" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Gold title bar background — lights up when RR target is reached -->
                        <Border Grid.Row="0"
                                Margin="-12,-10,-12,6"
                                Background="{Binding Slot3.TitleBarBackground}"
                                CornerRadius="6,6,0,0"/>

                        <!-- Header: instrument + direction + entry time, P&L right-aligned -->
                        <Grid Grid.Row="0" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Slot3.SlotLabel}"
                                       FontWeight="Bold" Foreground="White" FontSize="12"
                                       TextWrapping="Wrap"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                <TextBlock Text="&#x23F8; Paused"
                                           Visibility="{Binding Slot3.PausedBadgeVisibility}"
                                           Foreground="Orange" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <!-- P&L inline with header when position is open -->
                                <TextBlock Visibility="{Binding Slot3.PositionVisibility}"
                                           FontFamily="Consolas" FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{Binding Slot3.PnlTextBrush}"/>
                                            <Setter Property="FontWeight" Value="Normal"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Slot3.IsPnlTextFlashing}" Value="True">
                                                    <Setter Property="Foreground" Value="Yellow"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <Run Text="{Binding Slot3.PnlLine, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>

                        <Separator Grid.Row="1" Margin="0,0,0,6"/>

                        <!-- Symbol rows (ADX + signal watchlist) -->
                        <ItemsControl Grid.Row="2" ItemsSource="{Binding Slot3.Symbols}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="0,2"
                                               Foreground="{Binding RowColor}"
                                               FontFamily="Consolas" FontSize="12">
                                        <Run Text="{Binding Symbol, Mode=OneWay}"/>
                                        <Run Text="  "/>
                                        <Run Text="{Binding Arrow, Mode=OneWay}"/>
                                        <Run Text="  "/>
                                        <Run Text="{Binding AdxDisplay, Mode=OneWay}"/>
                                        <Run Text="  "/>
                                        <Run Text="{Binding Signal, Mode=OneWay}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Idle monitoring text (shown when no position is open) -->
                        <Border Grid.Row="3"
                                Visibility="{Binding Slot3.IdleVisibility}"
                                Padding="0,6,0,0">
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"       Value="{Binding Slot3.IdleMonitorText}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                        <Setter Property="FontFamily" Value="Consolas"/>
                                        <Setter Property="FontSize"   Value="10"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Slot3.IsIdleFlashing}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <!-- Position area: SP/SL/TP, entry reason, phase -->
                        <Border Grid.Row="4"
                                Visibility="{Binding Slot3.PositionVisibility}"
                                Background="#1A2A50" CornerRadius="4"
                                Padding="8,6" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding Slot3.PositionDisplay}"
                                           Foreground="White"
                                           FontFamily="Consolas" FontSize="12"
                                           TextWrapping="Wrap"/>
                                <TextBlock Margin="0,4,0,0"
                                           FontFamily="Consolas" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap">
                                    <Run Text="Phase: "/><Run Text="{Binding Slot3.StopPhaseLabel, Mode=OneWay}" Foreground="Gold"/>
                                </TextBlock>

                                <!-- Target P&L (shown from position open) -->
                                <TextBlock Margin="0,2,0,0"
                                           Text="{Binding Slot3.TargetPnlLine, Mode=OneWay}"
                                           Visibility="{Binding Slot3.TargetPnlVisibility}"
                                           Foreground="#FFD700"
                                           FontFamily="Consolas" FontSize="12"/>

                                <!-- RR Achieved milestone badge -->
                                <Border Margin="0,6,0,0" CornerRadius="4" Padding="6,4"
                                        Visibility="{Binding Slot3.RrAchievedVisibility}"
                                        Background="#2B2000" BorderBrush="#FFD700" BorderThickness="1">
                                    <TextBlock Text="&#x1F3C6; RR Achieved. Boom!!"
                                               Foreground="#FFD700" FontWeight="Bold" FontSize="12"
                                               HorizontalAlignment="Center"/>
                                </Border>

                                <!-- AI mid-trade result -->
                                <Border Margin="0,6,0,0" CornerRadius="4" Padding="6,4"
                                        Visibility="{Binding Slot3.AiResultVisibility}"
                                        BorderBrush="{Binding Slot3.AiVerdictBrush}" BorderThickness="1"
                                        Background="#0D1A2E">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Slot3.AiVerdictText}"
                                                   Foreground="{Binding Slot3.AiVerdictBrush}"
                                                   FontWeight="Bold" FontSize="12"/>
                                        <TextBlock Text="{Binding Slot3.AiExplanation}"
                                                   Foreground="White" FontSize="11"
                                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        <TextBlock FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap">
                                            <Run Text="Action: " Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <Run Text="{Binding Slot3.AiSuggestedAction}" Foreground="Cyan"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- AI sense-check button (blue theme) -->
                        <Button Grid.Row="5" Margin="0,8,0,0" HorizontalAlignment="Stretch"
                                Padding="6,4" FontSize="11"
                                Visibility="{Binding Slot3.PositionVisibility}"
                                IsEnabled="{Binding Slot3.IsAiChecking, Converter={StaticResource BoolInverseConverter}}"
                                Command="{Binding AiCheckSlot3Command}"
                                ToolTip="Ask Claude Haiku to sense-check this live position">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background"  Value="#1565C0"/>
                                    <Setter Property="BorderBrush" Value="#1976D2"/>
                                    <Setter Property="Foreground"  Value="White"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Cursor"      Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="3"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background"  Value="#2E7D32"/>
                                            <Setter Property="BorderBrush" Value="#388E3C"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding Slot3.IsAiChecking}" Value="True">
                                            <Setter Property="Background"  Value="#F57C00"/>
                                            <Setter Property="BorderBrush" Value="#FF9800"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F916;" FontSize="13" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="White"/>
                                <TextBlock VerticalAlignment="Center" Foreground="White">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="AI Sense Check"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Slot3.IsAiChecking}" Value="True">
                                                    <Setter Property="Text" Value="Checking&#x2026;"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

            </Grid>

            <!-- ── AI Check History Log ── -->
            <Border Margin="0,14,0,0"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="6" BorderBrush="#1565C0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition MaxHeight="200"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Background="#0D47A1" CornerRadius="5,5,0,0" Padding="10,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F916;" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="White"/>
                            <TextBlock Text="AI Check History" Foreground="White" FontSize="12"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Scrolling log -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding AiHistoryLog}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#263238" BorderThickness="0,0,0,1" Padding="10,5">
                                        <TextBlock Foreground="{Binding EntryColour}"
                                                   FontFamily="Consolas" FontSize="11"
                                                   Text="{Binding Display}"
                                                   TextWrapping="Wrap"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
