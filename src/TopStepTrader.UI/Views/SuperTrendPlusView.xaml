<UserControl x:Class="TopStepTrader.UI.Views.SuperTrendPlusView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:TopStepTrader.UI.Infrastructure"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,8">

            <!-- ── Page title + How-It-Works toggle on same row ── -->
            <Grid Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="&#x1F4C8;  SuperTrend+"
                           Style="{StaticResource PageTitleStyle}"
                           VerticalAlignment="Center"/>

                <Border Grid.Column="2"
                        Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6"
                        BorderBrush="#3A5A8A" BorderThickness="1"
                        VerticalAlignment="Center">
                    <ToggleButton x:Name="HowItWorksToggle"
                                  IsChecked="{Binding IsHowItWorksExpanded, Mode=TwoWay}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Cursor="Hand"
                                  Padding="12,6"
                                  HorizontalContentAlignment="Stretch">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4A1;" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="How does SuperTrend+ Autopilot work?"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock VerticalAlignment="Center" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="&#x25B2; hide"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, ElementName=HowItWorksToggle}" Value="False">
                                                <Setter Property="Text" Value="&#x25BC; show"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </ToggleButton>
                </Border>
            </Grid>

            <!-- How-It-Works collapsible body -->
            <Border Margin="0,6,0,0"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="6"
                    BorderBrush="#3A5A8A" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChecked, ElementName=HowItWorksToggle}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border Padding="16,4,16,14">
                    <StackPanel>

                            <!-- Monitoring -->
                            <Border Background="#16213A" CornerRadius="5" Padding="12,8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="&#x1F4E1;  Monitoring" Foreground="White" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17">SuperTrend+ scans your watchlist instruments every 15 seconds on the selected timeframe. For each instrument it computes the SuperTrend indicator, ADX (Average Directional Index), and the Directional Indicators (+DI and -DI) to assess trend direction and strength.</TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Signal Detection -->
                            <Border Background="#16213A" CornerRadius="5" Padding="12,8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="&#x1F50D;  Signal Detection" Foreground="White" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17" Margin="0,0,0,4">A trade signal is generated when:</TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17" Margin="8,0,0,2">&#x2022;  The SuperTrend line is bullish (price above) or bearish (price below)</TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17" Margin="8,0,0,2">&#x2022;  The Directional Indicators confirm the direction (+DI &gt; -DI for long, -DI &gt; +DI for short)</TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17" Margin="8,0,0,0">&#x2022;  ADX is at or above the minimum threshold (default: 25), indicating an active trend</TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Position Slots -->
                            <Border Background="#16213A" CornerRadius="5" Padding="12,8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="&#x1F4CA;  Position Slots" Foreground="White" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17" Margin="0,0,0,6">SuperTrend+ manages up to three Position Slots per instrument. The number of slots opened is determined by trend strength. Each new slot opens on the next closed bar after the ADX band increases. No two slots open on the same bar. Slots are not opened if the trend is showing signs of deterioration.</TextBlock>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Grid.Column="0" Background="#1A2440" CornerRadius="4" Padding="8,6" Margin="0,0,4,0"><StackPanel><TextBlock Text="ADX Range" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,3"/><TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">25 - 39  (1 slot)</TextBlock><TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">40 - 59  (up to 2 slots)</TextBlock><TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">60+      (up to 3 slots)</TextBlock></StackPanel></Border></Grid>
                                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17" Margin="0,8,0,0">Trend strength is displayed in the watchlist Strength column using a coffee scale. The level also determines how many positions (contracts) the bot places when it enters a trade:</TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17" Margin="8,4,0,2"><Run Foreground="White" FontWeight="SemiBold">L1: Decaff</Run>  — ADX 25–39. Trend is active but mild. Bot places 1 position.</TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17" Margin="8,0,0,2"><Run Foreground="White" FontWeight="SemiBold">L2: Latte</Run>    — ADX 40–59. Moderate trend with decent momentum. Bot places 2 positions.</TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17" Margin="8,0,0,0"><Run Foreground="White" FontWeight="SemiBold">L3: Espresso</Run> — ADX 60+. Strong, high-conviction trend. Bot places 3 positions.</TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Trade Management - Stop Phases -->
                            <Border Background="#16213A" CornerRadius="5" Padding="12,8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="&#x1F6E1;&#xFE0F;  Trade Management - Stop Phases" Foreground="White" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17" Margin="0,0,0,6">Each open slot advances through six stop phases as profit grows. The stop never retreats. R = initial risk (entry price minus stop at entry).</TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17"><Run Foreground="White" FontWeight="SemiBold">Initial:</Run>     Entry → 0.5R profit  |  Stop: SuperTrend line (ratchets with trend)</TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17"><Run Foreground="White" FontWeight="SemiBold">Breakeven:</Run>   0.5R profit  |  Stop: Exact entry price (risk eliminated)</TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17"><Run Foreground="White" FontWeight="SemiBold">ProfitLock:</Run>  1R profit    |  Stop: Entry + 0.3R (partial profit banked)</TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17"><Run Foreground="White" FontWeight="SemiBold">ProfitTrail:</Run> 1.5R profit  |  Stop: ATR-based trailing stop (rides the move)</TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17"><Run Foreground="White" FontWeight="SemiBold">Harvest:</Run>     2R profit    |  Stop: Locked at entry + 1.5R</TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17"><Run Foreground="White" FontWeight="SemiBold">FreeRide:</Run>    3R profit    |  Stop: Locked at entry + 2R (let it run)</TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17" Margin="0,6,0,0">All thresholds are configurable in <Run Foreground="{StaticResource AccentBrush}">SuperTrendPlusConfig</Run>.</TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Intelligent Exit - Degradation Signals -->
                            <Border Background="#16213A" CornerRadius="5" Padding="12,8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="&#x26A0;&#xFE0F;  Intelligent Exit - Degradation Signals" Foreground="White" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17" Margin="0,0,0,6">SuperTrend+ monitors seven degradation signals every bar. Each signal contributes a score. When the combined score reaches a threshold, the slot exits.</TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17">SuperTrend Flip - Trend has reversed - immediate exit</TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17">Momentum Slowing - Price converging toward ST line over 3 bars</TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17">ADX Declining - Trend strength fading from entry level</TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17">DI Compression - Buying/selling pressure equalising</TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17">DI Crossover - Leading indicator of direction change</TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17">Rejection Bar - Price rejected at extension - wick signal</TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17">ATR Contraction - Volatility driving the move is fading</TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17" Margin="0,6,0,0"><Run Foreground="Gold" FontWeight="SemiBold">Amber (Warning)</Run> = degradation building, no new slots. <Run Foreground="OrangeRed" FontWeight="SemiBold">Red (Exiting)</Run> = exit triggered.</TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Configuration -->
                            <Border Background="#16213A" CornerRadius="5" Padding="12,8" Margin="0,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="&#x2699;&#xFE0F;  Configuration" Foreground="White" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17" Margin="0,0,0,4">All settings are controlled from the configuration panel:</TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17" Margin="8,0,0,2">&#x2022;  Maximum slots (1-3)</TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17" Margin="8,0,0,2">&#x2022;  Contracts per slot</TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17" Margin="8,0,0,2">&#x2022;  ADX thresholds for each slot band</TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17" Margin="8,0,0,2">&#x2022;  Take profit multiple (reward:risk)</TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17" Margin="8,0,0,2">&#x2022;  SuperTrend multiplier</TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" LineHeight="17" Margin="8,0,0,0">&#x2022;  Chart timeframe</TextBlock>
                                </StackPanel>
                            </Border>

                    </StackPanel>
                </Border>
            </Border>
            <!-- ── Header: row 1 = selectors, row 2 = start/stop, AI, AI summary ── -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="6" Padding="14,10" Margin="0,8,0,0"
                    BorderBrush="{StaticResource AccentBrush}" BorderThickness="0,0,0,2">
                <StackPanel>

                    <!-- Row 1: Account, Timeframe, Entry Mode, TP, ST -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding Accounts}"
                                  SelectedItem="{Binding SelectedAccount}"
                                  DisplayMemberPath="DisplayName"
                                  Width="160" VerticalAlignment="Center"/>

                        <ComboBox Grid.Column="2"
                                  ItemsSource="{Binding Timeframes}"
                                  SelectedItem="{Binding SelectedTimeframe}"
                                  Width="90" VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                            <RadioButton Content="Confirmed"
                                         IsChecked="{Binding UseEarlyMode, Converter={StaticResource BoolInverseConverter}}"
                                         Foreground="White" FontSize="11" Margin="0,0,8,0"/>
                            <RadioButton Content="Early (Multi-Signal)"
                                         IsChecked="{Binding UseEarlyMode}"
                                         Foreground="Gold" FontSize="11" Margin="0,0,0,0"/>
                        </StackPanel>

                        <!-- TP Multiple -->
                        <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="TP:" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <ComboBox ItemsSource="{Binding TpMultiples}"
                                      SelectedItem="{Binding SelectedTpMultiple}"
                                      Width="Auto" MinWidth="60" VerticalAlignment="Center"
                                      ToolTip="Take-Profit multiple. The bot places a TP order at this multiple of initial risk (R). E.g. 2× means TP is twice the distance of your stop. 'None / flip only' means the position exits only on a SuperTrend flip or degradation signal.">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" MaxWidth="140"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <!-- ST Multiplier -->
                        <StackPanel Grid.Column="8" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="ST&#xD7;:" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <ComboBox ItemsSource="{Binding StMultipliers}"
                                      SelectedItem="{Binding StMultiplier}"
                                      Width="60" VerticalAlignment="Center"
                                      ToolTip="SuperTrend ATR multiplier. A higher value makes the SuperTrend band wider, resulting in fewer but more reliable signals and a larger initial stop. Lower values give tighter, more responsive signals but increase the chance of whipsaws."/>
                        </StackPanel>
                    </Grid>

                    <!-- Row 2: Start/Stop, AI toggle, AI summary, status -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Start / Stop button -->
                        <Button Grid.Column="0"
                                Content="{Binding StartStopLabel}"
                                Command="{Binding StartStopCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Padding="14,6" VerticalAlignment="Center"/>

                        <!-- AI On/Off toggle -->
                        <ToggleButton Grid.Column="2"
                                      IsChecked="{Binding IsAiEnabled, Mode=TwoWay}"
                                      ToolTip="Claude Haiku AI sense-check before each order. Resets to Off on restart."
                                      Padding="10,6" VerticalAlignment="Center"
                                      Cursor="Hand"
                                      Background="#1565C0" BorderBrush="#1976D2" BorderThickness="1">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
                                    <Setter Property="Background" Value="#1565C0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter Property="Background" Value="#1976D2"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ToggleButton.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F916;" FontSize="14" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="White"/>
                                <TextBlock VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="White">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="AI Off"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAiEnabled}" Value="True">
                                                    <Setter Property="Text" Value="AI On"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </ToggleButton>

                        <!-- Last AI summary label -->
                        <TextBlock Grid.Column="4"
                                   Text="{Binding LastAiCheckText}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11" TextWrapping="Wrap"
                                   VerticalAlignment="Center" Margin="4,0,0,0"/>

                        <!-- Status badge -->
                        <Border Grid.Column="5"
                                Background="{Binding StatusBackground}"
                                CornerRadius="4" Margin="8,0,0,0"
                                Visibility="{Binding StatusVisibility}"
                                VerticalAlignment="Center" Padding="8,4">
                            <TextBlock x:Name="StatusLabel"
                                       Text="{Binding StatusText}"
                                       Foreground="White" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- â”€â”€ Watchlist panel â”€â”€ -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="6" Padding="14,10" Margin="0,10,0,0"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- column header -->
                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Symbol"    Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="Trend"     Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="Signal"    Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="3" Text="Strength"  Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="4" Text="+DI / -DI" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="5" Text="What this means" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
                    </Grid>

                    <!-- rows -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding WatchlistItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Label, Mode=OneWay}"
                                               Foreground="White"
                                               FontFamily="Consolas" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Arrow, Mode=OneWay}"
                                               Foreground="{Binding RowColor}"
                                               FontFamily="Consolas" FontSize="13" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Signal, Mode=OneWay}"
                                               Foreground="{Binding RowColor}"
                                               FontFamily="Consolas" FontSize="12"/>
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding TrendStrength, Mode=OneWay}"
                                               Foreground="{Binding RowColor}"
                                               FontFamily="Consolas" FontSize="12"/>
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding DiDisplay, Mode=OneWay}"
                                               Foreground="{Binding RowColor}"
                                               FontFamily="Consolas" FontSize="12"/>
                                    <TextBlock Grid.Column="5"
                                               Text="{Binding SignalReason, Mode=OneWay}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11" TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- â”€â”€ Three persona boxes â”€â”€ -->
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

            <!-- ── Three slot boxes ── -->
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Slot 1 box -->
                <Border Grid.Column="0"
                        Opacity="{Binding Slot1.BoxOpacity}"
                        Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Padding="12,10"
                        BorderBrush="{Binding Slot1.PnlBorderBrush}"
                        BorderThickness="3">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Slot1.IsBorderFlashing}" Value="True">
                                    <Setter Property="BorderBrush" Value="White"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Slot1.IsPnlFlashing}" Value="True">
                                    <Setter Property="BorderBrush" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header: instrument + direction + entry time, P&L right-aligned -->
                        <Grid Grid.Row="0" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Slot1.SlotLabel}"
                                       FontWeight="Bold" Foreground="White" FontSize="12"
                                       TextWrapping="Wrap"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                <TextBlock Text="&#x23F8; Paused"
                                           Visibility="{Binding Slot1.PausedBadgeVisibility}"
                                           Foreground="Orange" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <!-- P&L inline with header when position is open -->
                                <TextBlock Visibility="{Binding Slot1.PositionVisibility}"
                                           FontFamily="Consolas" FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{Binding Slot1.PnlTextBrush}"/>
                                            <Setter Property="FontWeight" Value="Normal"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Slot1.IsPnlTextFlashing}" Value="True">
                                                    <Setter Property="Foreground" Value="Yellow"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <Run Text="{Binding Slot1.PnlLine, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>

                        <Separator Grid.Row="1" Margin="0,0,0,6"/>

                        <!-- Symbol rows (ADX + signal watchlist) -->
                        <ItemsControl Grid.Row="2" ItemsSource="{Binding Slot1.Symbols}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="0,2"
