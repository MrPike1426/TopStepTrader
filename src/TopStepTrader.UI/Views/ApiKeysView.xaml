<UserControl x:Class="TopStepTrader.UI.Views.ApiKeysView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>

        <!-- ── Input field styles ─────────────────────────────────────────── -->
        <Style x:Key="DarkPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Background"         Value="{StaticResource CardBrush}"/>
            <Setter Property="Foreground"         Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="CaretBrush"         Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush"        Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness"    Value="1"/>
            <Setter Property="Padding"            Value="8,0"/>
            <Setter Property="FontFamily"         Value="Segoe UI"/>
            <Setter Property="FontSize"           Value="13"/>
            <Setter Property="Height"             Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DarkTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background"         Value="{StaticResource CardBrush}"/>
            <Setter Property="Foreground"         Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="CaretBrush"         Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush"        Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness"    Value="1"/>
            <Setter Property="Padding"            Value="8,0"/>
            <Setter Property="FontFamily"         Value="Segoe UI"/>
            <Setter Property="FontSize"           Value="13"/>
            <Setter Property="Height"             Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Editable label for future slot provider names -->
        <Style x:Key="FutureLabelBoxStyle" TargetType="TextBox"
               BasedOn="{StaticResource DarkTextBoxStyle}">
            <Setter Property="Foreground"  Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontStyle"   Value="Italic"/>
        </Style>

        <!-- Shared field-label caption style -->
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="10"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Foreground"   Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Margin"       Value="0,0,0,4"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <!-- Provider sub-card: slightly recessed card inside the parent card -->
        <Style x:Key="ProviderCardStyle" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource CardBrush}"/>
            <Setter Property="CornerRadius"    Value="4"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

    </UserControl.Resources>

    <DockPanel>

        <!-- ══ Sticky save bar — docked to the bottom ═══════════════════════ -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Content="💾  Save Keys"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="24,8"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"/>
            </Grid>
        </Border>

        <!-- ══ Scrollable content ════════════════════════════════════════════ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="28,22,28,16" MaxWidth="860">

                <!-- ── Page header ───────────────────────────────────────────── -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="🔑  API Keys"
                                   Style="{StaticResource PageTitleStyle}"
                                   Margin="0"/>
                        <TextBlock Margin="0,4,0,0"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="Manage broker credentials and third-party service keys. All values are stored locally and never synced."/>
                    </StackPanel>

                    <!-- Show / Hide toggle aligned to top-right -->
                    <Button Grid.Column="1"
                            Content="{Binding ShowKeysLabel}"
                            Command="{Binding ToggleShowKeysCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="14,7"
                            VerticalAlignment="Top"/>
                </Grid>

                <!-- ── Active Broker card ─────────────────────────────────────── -->
                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Margin="0,0,0,16">
                    <!-- Coloured top accent bar -->
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.18" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Card title bar -->
                        <Border Background="#0D63B3ED" CornerRadius="6,6,0,0" Padding="20,11">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="ACTIVE BROKER"
                                           Style="{StaticResource SectionHeadingStyle}"
                                           Margin="0"/>
                                <!-- Active badge -->
                                <Border Grid.Column="1"
                                        Background="#1A52B788" BorderBrush="#52B788"
                                        BorderThickness="1" CornerRadius="10"
                                        Padding="10,3" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="7" Height="7" Fill="#52B788"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="ACTIVE"
                                                   FontSize="9" FontWeight="Bold"
                                                   Foreground="#52B788" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <StackPanel Margin="20,14,20,18">
                            <TextBlock Text="Select which broker is used for live trading. Orders, positions and market data are all routed through the active selection."
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                       TextWrapping="Wrap" Margin="0,0,0,14"/>

                            <!-- Broker option pill -->
                            <Border Background="#112E3F6E" BorderBrush="#2E3F6E"
                                    BorderThickness="1" CornerRadius="4" Padding="14,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <RadioButton Grid.Column="0"
                                                 IsChecked="{Binding IsTopStepXActive, Mode=TwoWay}"
                                                 VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="TopStepX"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="Futures · Funded account"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2"
                                               Text="topstepx.com"
                                               FontSize="10" FontFamily="Consolas"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── Named Providers card ──────────────────────────────────── -->
                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.18" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>

                        <!-- Card title bar -->
                        <Border Background="#0DFFA500" CornerRadius="6,6,0,0" Padding="20,11">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="API CREDENTIALS"
                                           Style="{StaticResource SectionHeadingStyle}"
                                           Margin="0"/>
                                <!-- Security notice -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="🔒" FontSize="10" Margin="0,0,5,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="Stored locally · Never synced"
                                               FontSize="10" FontFamily="Consolas"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Margin="20,16,20,20">

                            <!-- ── TopStepX ──────────────────────────────────── -->
                            <Border Style="{StaticResource ProviderCardStyle}"
                                    BorderBrush="#2B6CB0" BorderThickness="3,0,0,0"
                                    Padding="16,14" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Provider header -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                                        <TextBlock Text="TopStepX"
                                                   FontWeight="Bold" FontSize="13"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <Border Background="#1A63B3ED" BorderBrush="#63B3ED"
                                                BorderThickness="1" CornerRadius="3"
                                                Padding="7,2" Margin="10,0,0,0"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="FUTURES" FontSize="9" FontWeight="Bold"
                                                       Foreground="#63B3ED"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- Fields -->
                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="ACCOUNT EMAIL" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox Style="{StaticResource DarkTextBoxStyle}"
                                                     Text="{Binding TopStepXUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="API KEY" Style="{StaticResource FieldLabelStyle}"/>
                                            <Grid>
                                                <PasswordBox x:Name="pb_TopStepX"
                                                             Style="{StaticResource DarkPasswordBoxStyle}"
                                                             Visibility="{Binding HideKeys, Converter={StaticResource BoolToVisibilityConverter}}"
                                                             PasswordChanged="pb_TopStepX_PasswordChanged"/>
                                                <TextBox Style="{StaticResource DarkTextBoxStyle}"
                                                         Text="{Binding TopStepXApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Visibility="{Binding ShowKeys, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- ── Claude (Anthropic) ─────────────────────────── -->
                            <Border Style="{StaticResource ProviderCardStyle}"
                                    BorderBrush="#B794F4" BorderThickness="3,0,0,0"
                                    Padding="16,14" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Provider header -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                                        <TextBlock Text="Claude"
                                                   FontWeight="Bold" FontSize="13"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <Border Background="#1AB794F4" BorderBrush="#B794F4"
                                                BorderThickness="1" CornerRadius="3"
                                                Padding="7,2" Margin="10,0,0,0"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="ANTHROPIC" FontSize="9" FontWeight="Bold"
                                                       Foreground="#B794F4"/>
                                        </Border>
                                        <TextBlock Text="  ·  AI analysis engine"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Fields -->
                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="ORGANISATION / WORKSPACE ID  (optional)"
                                                       Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox Style="{StaticResource DarkTextBoxStyle}"
                                                     Text="{Binding ClaudeOrgId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="API KEY" Style="{StaticResource FieldLabelStyle}"/>
                                            <Grid>
                                                <PasswordBox x:Name="pb_Claude"
                                                             Style="{StaticResource DarkPasswordBoxStyle}"
                                                             Visibility="{Binding HideKeys, Converter={StaticResource BoolToVisibilityConverter}}"
                                                             PasswordChanged="pb_Claude_PasswordChanged"/>
                                                <TextBox Style="{StaticResource DarkTextBoxStyle}"
                                                         Text="{Binding ClaudeApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Visibility="{Binding ShowKeys, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- ── Binance ────────────────────────────────────── -->
                            <Border Style="{StaticResource ProviderCardStyle}"
                                    BorderBrush="#F6C90E" BorderThickness="3,0,0,0"
                                    Padding="16,14" Margin="0,0,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Provider header -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                                        <TextBlock Text="Binance"
                                                   FontWeight="Bold" FontSize="13"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <Border Background="#1AF6C90E" BorderBrush="#F6C90E"
                                                BorderThickness="1" CornerRadius="3"
                                                Padding="7,2" Margin="10,0,0,0"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="CRYPTO" FontSize="9" FontWeight="Bold"
                                                       Foreground="#F6C90E"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- Fields -->
                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="API KEY" Style="{StaticResource FieldLabelStyle}"/>
                                            <Grid>
                                                <PasswordBox x:Name="pb_Binance"
                                                             Style="{StaticResource DarkPasswordBoxStyle}"
                                                             Visibility="{Binding HideKeys, Converter={StaticResource BoolToVisibilityConverter}}"
                                                             PasswordChanged="pb_Binance_PasswordChanged"/>
                                                <TextBox Style="{StaticResource DarkTextBoxStyle}"
                                                         Text="{Binding BinanceApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Visibility="{Binding ShowKeys, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            </Grid>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="SECRET KEY" Style="{StaticResource FieldLabelStyle}"/>
                                            <Grid>
                                                <PasswordBox x:Name="pb_BinanceSecret"
                                                             Style="{StaticResource DarkPasswordBoxStyle}"
                                                             Visibility="{Binding HideKeys, Converter={StaticResource BoolToVisibilityConverter}}"
                                                             PasswordChanged="pb_BinanceSecret_PasswordChanged"/>
                                                <TextBox Style="{StaticResource DarkTextBoxStyle}"
                                                         Text="{Binding BinanceSecretKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Visibility="{Binding ShowKeys, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── Future Slots card ──────────────────────────────────────── -->
                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.18" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>

                        <!-- Card title bar -->
                        <Border Background="#08FFFFFF" CornerRadius="6,6,0,0" Padding="20,11">
                            <TextBlock Text="FUTURE SLOTS"
                                       Style="{StaticResource SectionHeadingStyle}"
                                       Margin="0"/>
                        </Border>

                        <StackPanel Margin="20,12,20,18">
                            <TextBlock Text="Reserved for future integrations. Give each slot a name when you are ready to configure it."
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                       TextWrapping="Wrap" Margin="0,0,0,14"/>

                            <!-- Column header row -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="PROVIDER NAME"
                                           Style="{StaticResource FieldLabelStyle}" Opacity="0.7"/>
                                <TextBlock Grid.Column="2" Text="USERNAME / EMAIL"
                                           Style="{StaticResource FieldLabelStyle}" Opacity="0.7"/>
                                <TextBlock Grid.Column="4" Text="API KEY"
                                           Style="{StaticResource FieldLabelStyle}" Opacity="0.7"/>
                            </Grid>

                            <!-- Future slot rows — uniform column widths match the header above -->
                            <!-- Future 1 -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Style="{StaticResource FutureLabelBoxStyle}"
                                         Text="{Binding Future1Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Grid.Column="2" Style="{StaticResource DarkTextBoxStyle}"
                                         Text="{Binding Future1Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <Grid Grid.Column="4">
                                    <PasswordBox x:Name="pb_Future1"
                                                 Style="{StaticResource DarkPasswordBoxStyle}"
                                                 Visibility="{Binding HideKeys, Converter={StaticResource BoolToVisibilityConverter}}"
                                                 PasswordChanged="pb_Future1_PasswordChanged"/>
                                    <TextBox Style="{StaticResource DarkTextBoxStyle}"
                                             Text="{Binding Future1Key, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{Binding ShowKeys, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </Grid>
                            </Grid>

                            <!-- Future 2 -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Style="{StaticResource FutureLabelBoxStyle}"
                                         Text="{Binding Future2Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Grid.Column="2" Style="{StaticResource DarkTextBoxStyle}"
                                         Text="{Binding Future2Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <Grid Grid.Column="4">
                                    <PasswordBox x:Name="pb_Future2"
                                                 Style="{StaticResource DarkPasswordBoxStyle}"
                                                 Visibility="{Binding HideKeys, Converter={StaticResource BoolToVisibilityConverter}}"
                                                 PasswordChanged="pb_Future2_PasswordChanged"/>
                                    <TextBox Style="{StaticResource DarkTextBoxStyle}"
                                             Text="{Binding Future2Key, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{Binding ShowKeys, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </Grid>
                            </Grid>

                            <!-- Future 3 -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Style="{StaticResource FutureLabelBoxStyle}"
                                         Text="{Binding Future3Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Grid.Column="2" Style="{StaticResource DarkTextBoxStyle}"
                                         Text="{Binding Future3Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <Grid Grid.Column="4">
                                    <PasswordBox x:Name="pb_Future3"
                                                 Style="{StaticResource DarkPasswordBoxStyle}"
                                                 Visibility="{Binding HideKeys, Converter={StaticResource BoolToVisibilityConverter}}"
                                                 PasswordChanged="pb_Future3_PasswordChanged"/>
                                    <TextBox Style="{StaticResource DarkTextBoxStyle}"
                                             Text="{Binding Future3Key, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{Binding ShowKeys, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </Grid>
                            </Grid>

                            <!-- Future 4 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Style="{StaticResource FutureLabelBoxStyle}"
                                         Text="{Binding Future4Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Grid.Column="2" Style="{StaticResource DarkTextBoxStyle}"
                                         Text="{Binding Future4Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <Grid Grid.Column="4">
                                    <PasswordBox x:Name="pb_Future4"
                                                 Style="{StaticResource DarkPasswordBoxStyle}"
                                                 Visibility="{Binding HideKeys, Converter={StaticResource BoolToVisibilityConverter}}"
                                                 PasswordChanged="pb_Future4_PasswordChanged"/>
                                    <TextBox Style="{StaticResource DarkTextBoxStyle}"
                                             Text="{Binding Future4Key, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{Binding ShowKeys, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </Grid>
                            </Grid>

                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</UserControl>
