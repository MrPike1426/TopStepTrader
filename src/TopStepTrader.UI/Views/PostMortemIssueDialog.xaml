<Window x:Class="TopStepTrader.UI.Views.PostMortemIssueDialog" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Post-Mortem Issue" Width="520" Height="280" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#0D1B2A"><Grid Margin="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBlock Grid.Row="0" Text="Describe the issue or reason for the post-mortem:" Foreground="White" FontSize="12" Margin="0,0,0,8"/><TextBox Grid.Row="1" x:Name="IssueTextBox" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="#1A2A3A" Foreground="White" BorderBrush="#2A4A6A" Padding="6" FontSize="12"/><StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0"><Button Content="OK" Click="OnOk" Width="80" Margin="0,0,8,0" Background="#1E5A88" Foreground="White" BorderBrush="#2A6AA0"/><Button Content="Cancel" Click="OnCancel" Width="80" Background="#2A3A5A" Foreground="White" BorderBrush="#3A4A6A"/></StackPanel></Grid></Window>