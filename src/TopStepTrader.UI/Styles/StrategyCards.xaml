<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ═══════════════════════════════════════════════════════════════════════
        Strategy card body templates — shared across HydraView, BacktestView,
        and any future view that presents strategy selection tiles.

        Usage in each view:
            <Button ...>
                <Button.Style>... (DataTrigger for highlight) ...</Button.Style>
                <ContentControl Template="{StaticResource EmaRsiCardContent}"/>
            </Button>

        Editing text, icons, or font sizes here updates every view in one place.
        Line 1  FontSize="12"  TextPrimaryBrush   — strategy name + icon
        Line 2  FontSize="10"  TextSecondaryBrush — indicator summary
        Line 3  FontSize="9"   TextSecondaryBrush — timeframe / notes
        ═══════════════════════════════════════════════════════════════════════
    -->

    <!-- ── Row 1: Live trading strategies ─────────────────────────────────── -->

    <!-- 1. EMA / RSI Combined -->
    <ControlTemplate x:Key="EmaRsiCardContent" TargetType="ContentControl">
        <StackPanel>
            <TextBlock Text="🎯  EMA/RSI Combined"
                       FontWeight="SemiBold" FontSize="14"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="EMA21 · EMA50 · RSI14 weighted"
                       FontSize="10" Margin="0,2,0,0"
                       Foreground="GhostWhite"/>
            <TextBlock Text="5-min bars · user confidence %"
                       FontSize="10" Margin="0,1,0,0"
                       Foreground="GhostWhite"/>
        </StackPanel>
    </ControlTemplate>

