<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── ComboBoxItem (dropdown rows) ──────────────────────────────────── -->
    <!--  Used by any ComboBox that sets ItemContainerStyle to this key.
          ContentPresenter has NO explicit Content/ContentTemplate bindings so
          WPF's auto-magic kicks in: it reads Content, ContentTemplate,
          ContentStringFormat, etc. directly from the templated ComboBoxItem.
          Text colour is enforced by the ItemTemplate's TextBlock (Foreground="White"
          as a local DP value) — not by this style.  -->
    <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="Background"                    Value="Transparent"/>
        <Setter Property="Padding"                       Value="8,5"/>
        <Setter Property="HorizontalContentAlignment"    Value="Left"/>
        <Setter Property="VerticalContentAlignment"      Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="ItemBorder"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="#FF2E3F6E"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ItemBorder" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── ComboBox base style (closed state + popup) ────────────────────── -->
    <!--  Does NOT set ItemContainerStyle — callers apply DarkComboBoxItemStyle
          themselves so they can also supply a matching ItemTemplate.  -->
    <Style x:Key="UnclippedComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Background"           Value="#FF243156"/>
        <Setter Property="Foreground"           Value="#FFE0E0F0"/>
        <Setter Property="BorderBrush"          Value="#FF2E3F6E"/>
        <Setter Property="BorderThickness"      Value="1"/>
        <Setter Property="Padding"              Value="8,5"/>
        <Setter Property="MaxDropDownHeight"    Value="300"/>
        <Setter Property="SnapsToDevicePixels"  Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid x:Name="Root">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="22"/>
                        </Grid.ColumnDefinitions>

                        <ToggleButton x:Name="ToggleButton"
                                      Grid.ColumnSpan="2"
                                      Focusable="False"
                                      ClickMode="Press"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                  RelativeSource={RelativeSource TemplatedParent}}"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="3"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#FF2E3F6E"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#FF1E2A4A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <!--  Non-editable closed-state display (IsEditable=False).
                              Hidden when IsEditable=True via trigger below.  -->
                        <ContentPresenter x:Name="ContentSite"
                                          Grid.Column="0"
                                          Margin="{TemplateBinding Padding}"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          IsHitTestVisible="False"/>

                        <!--  Editable closed-state display (IsEditable=True).
                              PART_EditableTextBox is the WPF-required named part that
                              renders the typed / selected text when IsEditable=True.
                              Hidden when IsEditable=False via trigger below.  -->
                        <TextBox x:Name="PART_EditableTextBox"
                                 Grid.Column="0"
                                 Margin="{TemplateBinding Padding}"
                                 Foreground="#FFE0E0F0"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 CaretBrush="#FFE0E0F0"
                                 SelectionBrush="#FF2E3F6E"
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Left"
                                 Focusable="True"
                                 Visibility="Collapsed"
                                 IsReadOnly="{Binding IsReadOnly,
                                              RelativeSource={RelativeSource TemplatedParent}}"/>

                        <Path Grid.Column="1"
                              Fill="#FFE0E0F0"
                              Data="M0,0 L4,5 L8,0 Z"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              IsHitTestVisible="False"/>

                        <Popup x:Name="PART_Popup"
                               Grid.ColumnSpan="2"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Border Background="#FF1E2A4A"
                                    BorderBrush="#FF2E3F6E"
                                    BorderThickness="1"
                                    MinWidth="{Binding ActualWidth,
                                               RelativeSource={RelativeSource TemplatedParent}}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <ScrollViewer CanContentScroll="True"
                                              SnapsToDevicePixels="True">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.5"/>
                        </Trigger>
                        <!-- When editable: show the TextBox, hide the ContentPresenter -->
                        <Trigger Property="IsEditable" Value="True">
                            <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="ContentSite"          Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Implicit (keyless) ComboBox style ──────────────────────────────
         Any ComboBox that does NOT explicitly set a Style will inherit this,
         ensuring dark theme is always applied. ComboBoxes that already set
         Style="{StaticResource UnclippedComboBoxStyle}" are unaffected.     -->
    <Style TargetType="ComboBox" BasedOn="{StaticResource UnclippedComboBoxStyle}"/>

</ResourceDictionary>
