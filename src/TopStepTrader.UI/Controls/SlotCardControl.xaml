<UserControl x:Class="TopStepTrader.UI.Controls.SlotCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <!--
        Reusable slot card — binds to SlotBoxVm.
        Drop on any view that uses the Position Slot model:
            <controls:SlotCardControl DataContext="{Binding SlotX}"
                                      AiCommand="{Binding AiCheckSlotXCommand}"/>
    -->
    <Border Opacity="{Binding BoxOpacity}"
            Background="{StaticResource SurfaceBrush}"
            CornerRadius="6" Padding="12,10"
            BorderBrush="{Binding PnlBorderBrush}"
            BorderThickness="3">
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsBorderFlashing}" Value="True">
                        <Setter Property="BorderBrush" Value="White"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsPnlFlashing}" Value="True">
                        <Setter Property="BorderBrush" Value="White"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- gold title bar overlay -->
                <RowDefinition Height="Auto"/>  <!-- Row 1: contract / direction / SP -->
                <RowDefinition Height="Auto"/>  <!-- separator -->
                <RowDefinition Height="Auto"/>  <!-- symbol watchlist rows -->
                <RowDefinition Height="Auto"/>  <!-- idle monitor text -->
                <RowDefinition Height="Auto"/>  <!-- position area (rows 2-5 + AI button) -->
            </Grid.RowDefinitions>

            <!-- Gold title bar highlight (lights up when RR target is reached) -->
            <Border Grid.Row="0"
                    Margin="-12,-10,-12,6"
                    Background="{Binding TitleBarBackground}"
                    CornerRadius="6,6,0,0"/>

            <!-- ── Row 1: Contract name — direction @ hh:mm:ss  |  SP: xxxx.xx ── -->
            <Grid Grid.Row="1" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: instrument + direction + time + SP (no wrapping; truncates if narrow) -->
                <TextBlock Grid.Column="0"
                           Text="{Binding SlotLabel, Mode=OneWay}"
                           FontWeight="Bold" Foreground="White" FontSize="12"
                           FontFamily="Consolas"
                           TextWrapping="NoWrap"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"/>

                <!-- Right: Paused badge only -->
                <TextBlock Grid.Column="1"
                           Text="⏸ Paused"
                           Visibility="{Binding PausedBadgeVisibility}"
                           Foreground="Orange" FontSize="11"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>

            <Separator Grid.Row="2" Margin="0,0,0,6"/>

            <!-- Symbol watchlist mini-rows (ADX + signal) -->
            <ItemsControl Grid.Row="3" ItemsSource="{Binding Symbols}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Margin="0,2"
                                   Foreground="{Binding RowColor}"
                                   FontFamily="Consolas" FontSize="12">
                            <Run Text="{Binding Symbol, Mode=OneWay}"/>
                            <Run Text="  "/>
                            <Run Text="{Binding Arrow, Mode=OneWay}"/>
                            <Run Text="  "/>
                            <Run Text="{Binding AdxDisplay, Mode=OneWay}"/>
                            <Run Text="  "/>
                            <Run Text="{Binding Signal, Mode=OneWay}"/>
                        </TextBlock>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Idle monitoring text -->
            <Border Grid.Row="4"
                    Visibility="{Binding IdleVisibility}"
                    Padding="0,6,0,0">
                <TextBlock>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text"       Value="{Binding IdleMonitorText}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            <Setter Property="FontFamily" Value="Consolas"/>
                            <Setter Property="FontSize"   Value="10"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsIdleFlashing}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>

            <!-- ── Position area (Rows 2–5 + AI button) ── -->
            <StackPanel Grid.Row="5"
                        Visibility="{Binding PositionVisibility}">

                <!-- ── Row 2: Price | SL | Strength ── (flashes every 15 s) -->
                <Border Background="#1A2A50" CornerRadius="4"
                        Padding="8,6" Margin="0,8,0,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRowFlashing}" Value="True">
                                    <Setter Property="BorderBrush"    Value="#42A5F5"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Live Price -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="Live Price: " Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="Consolas" FontSize="12"/>
                            <TextBlock Text="{Binding LivePriceDisplay, Mode=OneWay}"
                                       Foreground="White" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                        <!-- SL + $ risk -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                            <TextBlock Text="SL: " Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="Consolas" FontSize="12"/>
                            <TextBlock Text="{Binding SlDisplay, Mode=OneWay}"
                                       Foreground="#EF9A9A" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text=" " FontFamily="Consolas" FontSize="12"/>
                            <TextBlock Text="{Binding SlDollarDisplay, Mode=OneWay}"
                                       Foreground="#EF9A9A" FontFamily="Consolas" FontSize="11"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Phase label (below Row 2 box) -->
                <TextBlock Text="{Binding StopPhaseLabel, Mode=OneWay}"
                           Foreground="#80B0FF" FontFamily="Consolas" FontSize="11"
                           Margin="0,3,0,0"/>

                <!-- ── Row 3: Target | P&L | Next phase distance ── -->
                <Border Background="#141E30" CornerRadius="4"
                        Padding="8,6" Margin="0,4,0,0">
                    <StackPanel>
                        <!-- Size | Target | P&L on one line -->
                        <Grid Visibility="{Binding TargetPnlVisibility}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Size -->
                            <TextBlock Grid.Column="0"
                                       Text="{Binding SizeLabel, Mode=OneWay}"
                                       Foreground="#90CAF9"
                                       FontFamily="Consolas" FontSize="12" FontWeight="SemiBold"/>
                            <!-- separator -->
                            <TextBlock Grid.Column="1" Text="  |  "
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="Consolas" FontSize="12"/>
                            <!-- Target -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding TargetPnlLine, Mode=OneWay}"
                                       Foreground="ForestGreen"
                                       FontFamily="Consolas" FontSize="12"/>
                            <!-- P&L -->
                            <TextBlock Grid.Column="3"
                                       Text="{Binding PnlLine, Mode=OneWay}"
                                       Foreground="{Binding PnlTextBrush}"
                                       FontFamily="Consolas" FontSize="12" FontWeight="SemiBold"
                                       Margin="12,0,0,0"/>
                        </Grid>
                        <!-- Next phase distance -->
                        <TextBlock Text="{Binding NextPhaseLabel, Mode=OneWay}"
                                   Foreground="#FFD54F" FontFamily="Consolas" FontSize="11"
                                   Margin="0,3,0,0"
                                   Visibility="{Binding NextPhaseLabel,
                                       Converter={StaticResource StringToVisibilityConverter}}"/>
                    </StackPanel>
                </Border>

                <!-- RR Achieved badge -->
                <Border Margin="0,6,0,0" CornerRadius="4" Padding="6,4"
                        Visibility="{Binding RrAchievedVisibility}"
                        Background="#2B2000" BorderBrush="#FFD700" BorderThickness="1">
                    <TextBlock Text="&#x1F3C6; RR Achieved. Boom!!"
                               Foreground="#FFD700" FontWeight="Bold" FontSize="12"
                               HorizontalAlignment="Center"/>
                </Border>

                <!-- ── Row 4: Trend health composite (2-minute window) ── -->
                <Border Background="#0F1A2E" CornerRadius="4"
                        Padding="8,5" Margin="0,6,0,0">
                    <TextBlock Text="{Binding TrendHealthLabel, Mode=OneWay}"
                               Foreground="{Binding TrendHealthBrush}"
                               FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"/>
                </Border>

                <!-- AI mid-trade result -->
                <Border Margin="0,6,0,0" CornerRadius="4" Padding="6,4"
                        Visibility="{Binding AiResultVisibility}"
                        BorderBrush="{Binding AiVerdictBrush}" BorderThickness="1"
                        Background="#0D1A2E">
                    <StackPanel>
                        <TextBlock Text="{Binding AiVerdictText}"
                                   Foreground="{Binding AiVerdictBrush}"
                                   FontWeight="Bold" FontSize="12"/>
                        <TextBlock Text="{Binding AiExplanation}"
                                   Foreground="White" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                        <TextBlock FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap">
                            <Run Text="Action: " Foreground="{StaticResource TextSecondaryBrush}"/>
                            <Run Text="{Binding AiSuggestedAction}" Foreground="Cyan"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ── Row 5: AI Sense Check button ── -->
                <Button Margin="0,8,0,0" HorizontalAlignment="Stretch"
                        Padding="6,4" FontSize="11"
                        IsEnabled="{Binding IsAiChecking, Converter={StaticResource BoolInverseConverter}}"
                        Command="{Binding AiCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        ToolTip="Ask Claude Haiku to sense-check this live position">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background"     Value="#1565C0"/>
                            <Setter Property="BorderBrush"    Value="#1976D2"/>
                            <Setter Property="Foreground"     Value="White"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Cursor"         Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="3"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background"  Value="#2E7D32"/>
                                    <Setter Property="BorderBrush" Value="#388E3C"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding IsAiChecking}" Value="True">
                                    <Setter Property="Background"  Value="#F57C00"/>
                                    <Setter Property="BorderBrush" Value="#FF9800"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x1F916;" FontSize="13" VerticalAlignment="Center"
                                   Margin="0,0,4,0" Foreground="White"/>
                        <TextBlock VerticalAlignment="Center" Foreground="White">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="AI Sense Check"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAiChecking}" Value="True">
                                            <Setter Property="Text" Value="Checking…"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Grid>
    </Border>
</UserControl>
