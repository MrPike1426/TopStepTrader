{
  "ConnectionStrings": {
    "DefaultConnection": "TopStepTrader.db"
  },
  "Api": {
    "BaseUrl": "https://public-api.etoro.com",
    "ApiKey": "YOUR_ETORO_API_KEY_HERE",
    "UserKey": "YOUR_ETORO_USER_KEY_HERE",
    "HttpTimeoutSeconds": 30
  },
  "Risk": {
    "DailyLossLimitDollars": -1500.00,
    "MaxDrawdownDollars": -2000.00,
    "MaxPositionSizeContracts": 3,
    "MaxOrdersPerMinute": 10,
    "MinSignalConfidence": 0.65,
    "AutoExecutionEnabled": false
  },
  "Trading": {
    "DefaultOrderQuantity": 1,
    "DefaultTimeframe": 5,
    "ActiveContractIds": [ "18", "17", "28", "27" ]
  },
  "ML": {
    "ModelDirectory": "Models",
    "CurrentModelFile": "signal_v1.zip",
    "RetrainingMinSamples": 1000,
    "FeatureLookbackBars": 50
  },
  "Ingestion": {
    "BarIngestionIntervalSeconds": 60,
    "HistoricalBarsToFetchOnStartup": 5000,
    "Timeframes": [ 1, 5, 60 ]
  },
  "ProjectX": {
    "RestBaseUrl": "https://api.topstepx.com",
    "UserHubUrl": "https://rtc.topstepx.com/hubs/user",
    "MarketHubUrl": "https://rtc.topstepx.com/hubs/market",
    "TokenRefreshMinutesBeforeExpiry": 30,
    "DefaultSlTicks": 50,
    "DefaultTpTicks": 25
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore": "Warning",
      "TopStepTrader.API": "Debug"
    }
  }
}
